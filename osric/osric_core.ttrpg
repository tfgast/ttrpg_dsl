// ============================================================
// OSRIC 3.0 Core Types — shared enums, structs, entity definitions
//
// Foundation types for OSRIC (Old School Reference and Index
// Compilation), a retroclone of First Edition AD&D.
// All other OSRIC files import from this module.
//
// Reference: OSRIC 3.0 Player Guide, Chapters 1-3
// ============================================================

import "osric_combat.ttrpg"
import "osric_equipment.ttrpg"
import "osric_inventory.ttrpg"
import "osric_spells.ttrpg"
import "osric_weapon_spec.ttrpg"

use "OSRIC Equipment"
use "OSRIC Combat"
use "OSRIC Spells"
use "OSRIC Weapon Specialisation"
use "OSRIC Inventory"

system "OSRIC" {

    // --- Effect source tracking ---
    // User-defined EffectSource for condition provenance.
    // Allows dispel/anti-magic to identify what applied a condition.

    enum EffectSource {
        Unknown,
        Spell(name: string, caster_level: int),
        Item(name: string),
        Poison(name: string),
        MonsterAbility(name: string)
    }

    // --- Condition category tags ---
    // Static properties of condition types. Used by removal/immunity
    // effects (e.g. Neutralize Poison targets #poison conditions,
    // Cure Disease targets #disease conditions).

    tag poison
    tag disease
    tag curse
    tag mental
    tag physical
    tag death
    tag movement
    tag fear
    tag insanity

    // --- Unit types ---

    unit Feet suffix ft { value: int }

    // --- Ability scores (same six as all D&D) ---

    enum Ability { STR, DEX, CON, INT, WIS, CHA }

    // --- Alignment (nine-fold, unlike OSE's three-fold) ---

    enum Alignment {
        LawfulGood,
        LawfulNeutral,
        LawfulEvil,
        NeutralGood,
        TrueNeutral,
        NeutralEvil,
        ChaoticGood,
        ChaoticNeutral,
        ChaoticEvil
    }

    // --- Character classes (10 total) ---

    enum Class {
        Assassin,
        Cleric,
        Druid,
        Fighter,
        Illusionist,
        MagicUser,
        Monk,
        Paladin,
        Ranger,
        Thief
    }

    // --- Ancestry (7 options; "ancestry" replaces "race" in OSRIC 3.0) ---

    enum Ancestry {
        Dwarf,
        Elf,
        Gnome,
        HalfElf,
        HalfOrc,
        Halfling,
        Human
    }

    // --- Size categories ---

    enum Size ordered { Tiny, Small, Medium, Large, Huge, Gargantuan }

    // --- Encumbrance tiers (§1.5.3.3) ---

    enum EncumbranceTier ordered { Unencumbered, Light, Moderate, Heavy, Overloaded }

    // --- Damage types ---

    enum DamageType { Slashing, Piercing, Blunt, Fire, Cold, Lightning, Acid, Poison, Corrosion }

    // --- Weapon enums (bare types; lookup tables in OSRIC Equipment) ---

    enum MeleeWeapon {
        BattleAxe, HandAxe, Club, Dagger, FistOrKick,
        FlailHeavy, FlailLight, Halberd, Javelin, Lance,
        MaceHeavy, MaceLight, MorningStar,
        PickHeavy, PickLight, PoleArm, Spear, Staff,
        SwordBastard, SwordBroad, SwordLong, SwordScimitar,
        SwordShort, SwordTwoHanded, Trident,
        WarhammerHeavy, WarhammerLight
    }

    enum MissileWeapon {
        BowLong, BowShort, CompositeBowLong, CompositeBowShort,
        CrossbowHeavy, CrossbowLight,
        DaggerThrown, HandAxeThrown, ClubThrown, DartThrown,
        JavelinThrown, SpearThrown, Sling, SlingStone, WarhammerThrown
    }

    // --- Armour / shield enums (lookup tables in OSRIC Equipment) ---

    enum ArmourType {
        Banded, ChainMail, ElfinMail, Leather, Padded,
        PlateMail, RingMail, ScaleLamellar, Splint, StuddedLeather
    }

    enum ShieldType { SmallShield, MediumShield, LargeShield }

    // --- Equipment wrapper types ---

    enum WeaponMaterial { Normal, Silver, ColdIron }

    enum WieldedItem {
        Melee(weapon: MeleeWeapon, magic_bonus: int = 0, material: WeaponMaterial = WeaponMaterial.Normal),
        Missile(weapon: MissileWeapon, magic_bonus: int = 0, material: WeaponMaterial = WeaponMaterial.Normal)
    }

    struct Armor {
        armour_type: ArmourType,
        magic_bonus: int = 0
    }

    struct Shield {
        shield_type: ShieldType,
        magic_bonus: int = 0
    }

    // --- Saving throw categories (five in 1e/OSRIC) ---

    enum SaveCategory {
        AimedMagicItems,
        BreathWeapons,
        DeathParalysisPoison,
        PetrificationPolymorph,
        SpellsUnlisted
    }

    // --- Combat progression groups ---
    // Classes share to-hit tables. These group them.
    // Fighter progression: Fighter, Paladin, Ranger
    // Cleric progression: Cleric, Druid, Monk
    // Thief progression: Thief, Assassin
    // MagicUser progression: Magic-User, Illusionist

    enum CombatGroup { FighterGroup, ClericGroup, ThiefGroup, MagicUserGroup }

    // --- Spell progression categories ---

    enum SpellProgression {
        NonCaster,
        Cleric,
        Druid,
        MagicUser,
        Illusionist,
        Paladin,
        Ranger
    }

    // --- Spell classification types ---
    // Ref: OSRIC 3.0 PG §1.8.1.5

    // Tradition — the first word of every spell description
    enum SpellClassType {
        Arcane,         // Magic-User spells
        Divine,         // Cleric spells
        Druidic,        // Druid spells
        Phantasmal      // Illusionist spells
    }

    // Schools of magic (§1.8.1.4)
    enum SpellSchool {
        Abjuration,
        Conjuration,
        Divination,
        Enchantment,
        Evocation,
        Illusion,
        Necromancy,
        Transmutation
    }

    // Spell range categories (§1.8.1.5 Range)
    enum SpellRange {
        Nil,                            // originates from caster position, stationary
        Caster,                         // originates from and moves with caster
        Touch,                          // must touch the target
        Distance(distance: Feet),       // maximum distance in feet
        Special(description: string)    // see spell description
    }

    // Spell duration categories (§1.8.1.5 Duration)
    enum SpellDuration {
        Instantaneous,
        Permanent,
        Rounds(count: int),
        Turns(count: int),
        RoundsPerLevel(base: int, per_level: int),
        TurnsPerLevel(base: int, per_level: int),
        Continuing,                         // lasts while caster continues casting
        Special(description: string)        // see spell description
    }

    // Casting time (§1.8.1.5 Casting Time)
    enum CastingTime {
        Fast,                           // 1 segment, takes effect same segment
        Segments(count: int),
        Rounds(count: int),
        Turns(count: int),
        Special(description: string)
    }

    // Saving throw effect (§1.8.1.5)
    enum SpellSave {
        NoSave,
        Negates,                            // save negates entire effect
        Half,                               // save halves damage
        Special(description: string)        // see spell description
    }

    // --- Armour permission levels ---

    enum ArmourPermission {
        AnyArmour,         // Fighter, Paladin, Ranger, Cleric
        LeatherShield,     // Assassin (leather/studded + shield)
        LeatherWooden,     // Druid (leather + wooden shield only)
        LeatherOnly,       // Thief (leather, no shield for abilities)
        NoArmour           // Magic-User, Illusionist, Monk
    }

    // --- Thief skills (used by Thief, Assassin, Monk) ---

    enum ThiefSkill {
        ClimbWalls,
        FindTraps,
        HearNoise,
        HideInShadows,
        MoveSilently,
        OpenLocks,
        PickPockets,
        ReadLanguages
    }

    // --- Saving throw values (five categories) ---

    struct SavingThrows {
        aimed_magic: int
        breath: int
        death_paralysis_poison: int
        petrification_polymorph: int
        spells: int
    }

    // --- Static class definition ---
    // Core mechanical identity of each class, independent of level.

    struct ClassDef {
        class: Class
        hit_die: int                        // d4=4, d6=6, d8=8, d10=10
        bonus_first_hd: int                 // extra HD at level 1 (e.g. Ranger gets 1)
        max_hit_dice: int                   // level after which HP is fixed per level
        hp_after_max: int                   // fixed HP gained per level after max_hit_dice
        combat_group: CombatGroup
        armour: ArmourPermission
        shield_allowed: bool
        weapons_any: bool
        non_prof_penalty: int               // -2 to -5
        weapon_specialization: bool         // optional rule for fighter-types
        spell_progression: SpellProgression
        has_thief_skills: bool
        can_backstab: bool
        can_turn_undead: bool
        has_exceptional_str: bool           // fighters, paladins, rangers with STR 18
    }

    // --- Ancestry definition ---
    // Static data for each ancestry: ability adjustments, limits, features.

    struct AncestryDef {
        ancestry: Ancestry
        size: Size
        base_movement: Feet         // feet per round (120ft = human standard)
        infravision: Feet           // range in feet, 0ft = none
        str_adj: int                // ability score adjustment
        dex_adj: int
        con_adj: int
        int_adj: int
        wis_adj: int
        cha_adj: int
    }

    // --- Ability score range limits per ancestry ---

    struct AbilityRange {
        min: int
        max: int
    }

    // --- Spell component requirements ---

    struct SpellComponents {
        verbal: bool = true
        somatic: bool = true
        material: bool = false
    }

    // --- Spell definition ---
    // Core data for each spell, independent of casting context.
    // Individual spell data will be defined in per-class derive lookups.
    // Ref: OSRIC 3.0 PG §1.8.1.5

    struct SpellDef {
        name: string
        class_type: SpellClassType
        school: SpellSchool
        level: int
        range: SpellRange
        duration: SpellDuration
        area_of_effect: string
        components: SpellComponents
        casting_time: CastingTime
        saving_throw: SpellSave
        reversible: bool = false
        description: string
    }

    // --- Spell identity ---
    // Typed spell identifier — one variant per implemented spell.
    // Replaces string-based spell names for type-safe memorisation,
    // casting, and registry dispatch.

    enum SpellId {
        // Cleric level 1
        CureLightWounds,
        CauseLightWounds,
        Bless,
        Curse,
        // Cleric level 2
        HoldPerson,
        // Magic-User level 1
        MagicMissile,
        Sleep,
        // Magic-User level 3
        Fireball
    }

    struct SpellSlotTrack {
        class_type: SpellClassType
        spell_slots: list<int>
        slots_used: list<int> = []
    }

    // A memorised spell slot: bundles spell identity with the
    // spell level it occupies (for slot accounting).
    struct MemorizedSpell {
        id: SpellId
        level: int
        class_type: SpellClassType = SpellClassType.Divine
    }

    // --- Monster attack entry ---

    struct MonsterAttack {
        name: string
        damage: DiceExpr
    }

    // --- Breath weapon optional group (charge-based active ability) ---

    group BreathWeapon {
        breath_name: string
        breath_damage: DiceExpr
        breath_type: DamageType
        breath_charges_max: int
        restricted breath_charges: resource(0..=breath_charges_max)
    }

    // --- Per-class level and XP tracking ---

    struct ClassLevel {
        class: Class
        level: int
        xp: int
    }

    // --- Level drain history (§1.6.7) ---
    // Records each drain event so Restoration (§1.8.2.7) can
    // restore within the time window (1 day per caster cleric level).

    struct DrainEvent {
        class: Class         // which class was drained
        original_level: int  // level before this drain
        timestamp: int       // game-time in segments when drain occurred
    }

    // --- Per-level HP roll record ---
    // Tracks exactly how many HP were gained at each class level,
    // so level drain can subtract the correct amount and restoration
    // can re-roll. Populated by character creation / level-up.

    struct HpRoll {
        class: Class         // which class this HD was for
        level: int           // the class level when this roll was made
        amount: int          // final HP gained (after CON mod, multi-class division)
    }

    enum ClassingMode { Single, Multi, Dual }

    // --- Weapon specialisation types (§1.3.13) ---

    enum SpecLevel { Single, Double }

    enum SpecWeapon {
        SpecMelee(weapon: MeleeWeapon),
        SpecMissile(weapon: MissileWeapon)
    }

    // --- Character entity ---

    entity Character {
        name: string
        classes: list<ClassLevel>
        classing_mode: ClassingMode = ClassingMode.Single
        ancestry: Ancestry = Ancestry.Human
        alignment: Alignment = Alignment.TrueNeutral
        abilities: map<Ability, int>
        include HitPoints
        base_movement: Feet = 120ft
        drain_history: list<DrainEvent> = []
        hp_rolls: list<HpRoll> = []
        saving_throws: option<SavingThrows>
        include EquipmentSlots

        optional ExceptionalStrength {
            percentile: int
        }

        optional Spellcasting

        optional ThiefSkills {
            skills: map<ThiefSkill, int>
        }

        optional TurnUndead {}

        optional WeaponSpecialization

        optional Inventory

        optional HenchmanMorale {
            morale_base: int
            morale_checks_made: int = 0
        }
    }

    // --- Monster entity ---

    entity Monster {
        name: string
        hit_dice: DiceExpr
        max_hp: int
        hp: resource(0..=max_hp)
        ac: int = 10
        morale: int = 7
        morale_checks_made: int = 0
        xp_value: int = 0
        intelligence: int = 1
        alignment: Alignment = Alignment.TrueNeutral
        base_movement: Feet = 120ft
        attacks: list<MonsterAttack>
        size: Size = Size.Medium
        special: list<string>

        optional EquipmentSlots

        optional BreathWeapon
    }
}
