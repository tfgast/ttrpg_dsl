        [Class.Ranger, 11] => 650000,
        [Class.Ranger, 12] => 975000,
        [Class.Ranger, 13] => 1300000,
        [Class.Ranger, 14] => 1625000,
        [Class.Ranger, 15] => 1950000,
        [Class.Ranger, 16] => 2275000,
        [Class.Ranger, 17] => 2600000,
        [Class.Ranger, 18] => 2925000,
        [Class.Ranger, 19] => 3250000,
        [Class.Ranger, 20] => 3575000,

        // --- Thief ---
        [Class.Thief, 1]  => 0,
        [Class.Thief, 2]  => 1250,
        [Class.Thief, 3]  => 2500,
        [Class.Thief, 4]  => 5000,
        [Class.Thief, 5]  => 10000,
        [Class.Thief, 6]  => 20000,
        [Class.Thief, 7]  => 40000,
        [Class.Thief, 8]  => 70000,
        [Class.Thief, 9]  => 110000,
        [Class.Thief, 10] => 160000,
        [Class.Thief, 11] => 220000,
        [Class.Thief, 12] => 440000,
        [Class.Thief, 13] => 660000,
        [Class.Thief, 14] => 880000,
        [Class.Thief, 15] => 1100000,
        [Class.Thief, 16] => 1320000,
        [Class.Thief, 17] => 1540000,
        [Class.Thief, 18] => 1760000,
        [Class.Thief, 19] => 1980000,
        [Class.Thief, 20] => 2200000
    }


    // ========================================================
    //  MONK LEVEL-BASED TABLES
    //
    //  Monks replace standard STR/DEX bonuses with class
    //  features that scale by level (OSRIC 3.0, pp.51-54).
    // ========================================================

    // Monk armour class improvement (ascending AC).
    // This is a class feature, NOT a DEX bonus — conditions
    // that strip "DEX bonus to AC" do not affect it.
    table monk_ac(level: int) -> int {
        1       => 10,
        2       => 11,
        3       => 12,
        4..=5   => 13,
        6       => 14,
        7       => 15,
        8       => 16,
        9..=10  => 17,
        11      => 18,
        12      => 19,
        13      => 20,
        14..=15 => 21,
        16      => 22,
        _       => 23       // 17
    }

    // Monk movement rate by level (Table 1.3.7.4a).
    // Replaces ancestry base movement — monks are always faster.
    table monk_movement(level: int) -> int {
        1       => 150,
        2       => 160,
        3       => 170,
        4       => 180,
        5       => 190,
        6       => 200,
        7       => 210,
        8       => 220,
        9       => 230,
        10      => 240,
        11      => 250,
        12      => 260,
        13      => 270,
        14      => 280,
        15      => 290,
        16      => 300,
        _       => 310       // 17
    }

    // Monk weapon damage bonus (STR 15+ column).
    // For STR < 15, subtract 1 (min 0) at call site.
    // This replaces (not supplements) the normal STR damage bonus.
    table monk_weapon_damage(level: int) -> int {
        1       => 0,
        2..=3   => 1,
        4..=5   => 2,
        6..=7   => 3,
        8..=9   => 4,
        10..=11 => 5,
        12..=13 => 6,
        14..=15 => 7,
        _       => 8        // 16-17
    }


    // ========================================================
    //  LEVEL ADVANCEMENT CHECK
    // ========================================================

    derive check_level_up(class: Class, current_level: int, xp: int) -> bool {
        let next = current_level + 1
        xp >= xp_for_level(class, next)
    }


    // ========================================================
    //  CASTER LEVEL
    //
    //  Returns the character's level in the class that casts
    //  spells of the given tradition. 0 if no matching class.
    //  Used by spell resolution to scale damage, duration, and
    //  missile count.
    // ========================================================

    // Map spell tradition to the primary casting class.
    derive spell_casting_class(spell_class: SpellClassType) -> Class {
        match spell_class {
            Arcane     => MagicUser,
            Divine     => Class.Cleric,
            Druidic    => Class.Druid,
            Phantasmal => Class.Illusionist
        }
    }

    // Caster level for a character given a spell tradition.
    derive caster_level(char: Character, spell_class: SpellClassType) -> int {
        let c = spell_casting_class(spell_class)
        let matches = [cl.level for cl in char.classes if cl.class == c]
        if len(matches) > 0 { first(matches).unwrap() } else { 0 }
    }
}
