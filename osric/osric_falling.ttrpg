// ============================================================
// OSRIC 3.0 Falling Damage (§1.5.5)
//
// Damage from falling is determined by distance:
//
//   <10ft  — no damage
//   10ft   — 1d6
//   20ft   — 3d6
//   30ft   — 6d6
//   40ft   — 10d6
//   50ft   — 15d6
//   >50ft  — 20d6
//
// The GM may optionally allow a saving throw against falling
// damage; if successful, damage is halved.
//
// Reference: OSRIC 3.0 Player Guide, §1.5.5 (p.89)
// ============================================================

import "osric_core.ttrpg"
import "osric_saves.ttrpg"
import "osric_combat.ttrpg"

use "OSRIC"
use "OSRIC Saves"
use "OSRIC Combat"

system "OSRIC Falling" {

    struct FallingResult {
        distance_ft: int
        base_damage: int
        saved: bool
        damage_taken: int
    }

    // Falling damage dice by distance (§1.5.5).
    // Returns the dice expression for the given fall distance.
    derive falling_damage_dice(distance_ft: int) -> DiceExpr {
        if distance_ft < 10 {
            0d6
        } else if distance_ft < 20 {
            1d6
        } else if distance_ft < 30 {
            3d6
        } else if distance_ft < 40 {
            6d6
        } else if distance_ft < 50 {
            10d6
        } else if distance_ft == 50 {
            15d6
        } else {
            20d6
        }
    }

    // Falling damage dice for a specific entity. Wraps
    // falling_damage_dice so that conditions (e.g. Feather Fall)
    // can modify the result for their bearer.
    derive fall_damage_dice_for(target: entity, distance_ft: int) -> DiceExpr {
        falling_damage_dice(distance_ft)
    }

    // Apply falling damage. Rolls the appropriate dice for the
    // distance fallen. If allow_save is true, a save vs
    // DeathParalysisPoison is attempted; success halves damage.
    mechanic apply_falling_damage(
        distance_ft: int,
        saves: SavingThrows,
        allow_save: bool = false,
        save_bonus: int = 0
    ) -> FallingResult {
        let dice = falling_damage_dice(distance_ft)
        let base = roll(dice).total

        if allow_save && base > 0 {
            let saved = roll_saving_throw(saves, SaveCategory.DeathParalysisPoison, save_bonus)
            if saved {
                let halved = max(1, base div 2)
                FallingResult {
                    distance_ft: distance_ft,
                    base_damage: base,
                    saved: true,
                    damage_taken: halved
                }
            } else {
                FallingResult {
                    distance_ft: distance_ft,
                    base_damage: base,
                    saved: false,
                    damage_taken: base
                }
            }
        } else {
            FallingResult {
                distance_ft: distance_ft,
                base_damage: base,
                saved: false,
                damage_taken: base
            }
        }
    }

    // Apply falling damage to a character through the standard
    // damage pipeline. Uses DamageType.Fall so item saves and
    // damage processing work correctly.
    action FallDamage on target: Character (
        distance_ft: int,
        allow_save: bool = false,
        save_bonus: int = 0
    ) {
        cost free
        requires { target.saving_throws != none }
        resolve {
            // Use the entity-aware derive so condition modifiers
            // (e.g. FeatherFalling) can zero out the dice.
            let dice = fall_damage_dice_for(target, distance_ft)
            let base = roll(dice).total

            if base > 0 {
                if allow_save {
                    let saved = roll_saving_throw(target.saving_throws.unwrap(), SaveCategory.DeathParalysisPoison, save_bonus)
                    if saved {
                        let halved = max(1, base div 2)
                        target.TakeDamage(target, halved, DamageType.Fall)
                    } else {
                        target.TakeDamage(target, base, DamageType.Fall)
                    }
                } else {
                    target.TakeDamage(target, base, DamageType.Fall)
                }
            }
        }
    }

}
