// ============================================================
// OSRIC 3.0 Monster Bestiary — factory functions
//
// ~27 iconic monsters across humanoids, undead, animals,
// classic monsters, giants, dragons, and outsiders.
// Each factory returns a Monster entity with appropriate
// innate trait conditions applied.
//
// AC values use ascending notation (10 = unarmoured).
// HP is set to max_hp (average/typical values).
//
// Reference: OSRIC 3.0 Gamemaster Guide, Chapter 10
// ============================================================

import "osric_combat.ttrpg"
import "osric_core.ttrpg"
import "osric_monster_traits.ttrpg"

use "OSRIC"
use "OSRIC Combat"
use "OSRIC Monster Traits"

system "OSRIC Bestiary" {

    // ========================================================
    //  HUMANOIDS
    // ========================================================

    function create_kobold() -> Monster {
        Monster {
            name: "Kobold",
            hit_dice: 1d4,
            max_hp: 2,
            hp: 2,
            ac: 13,
            morale: 6,
            xp_value: 5,
            intelligence: 8,
            alignment: Alignment.LawfulEvil,
            base_movement: 60ft,
            attacks: [MonsterAttack { name: "Short sword", damage: 1d4 }],
            size: Size.Small,
            special: ["Infravision"]
        } with [Infravision(range: 60ft)]
    }

    function create_goblin() -> Monster {
        Monster {
            name: "Goblin",
            hit_dice: 1d8 - 1,
            max_hp: 3,
            hp: 3,
            ac: 14,
            morale: 7,
            xp_value: 10,
            intelligence: 9,
            alignment: Alignment.LawfulEvil,
            base_movement: 60ft,
            attacks: [MonsterAttack { name: "Short sword", damage: 1d6 }],
            size: Size.Small,
            special: ["Infravision"]
        } with [Infravision(range: 60ft)]
    }

