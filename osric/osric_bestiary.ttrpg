    // ========================================================
    //  DRAGONS
    //
    //  Dragons are parameterised by age category (1-8).
    //  HP per die equals age category. Breath weapon damage
    //  equals current HP. 3 charges per day.
    // ========================================================

    function create_white_dragon(age: int) -> Monster {
        // HD 5-7 depending on sub-type; using 6 as middle value
        let hd = 6
        let hp = hd * age
        Monster {
            name: "White Dragon",
            hit_dice: 6d8,
            max_hp: hp,
            hp: hp,
            ac: 17,
            morale: 10,
            xp_value: 500 + 100 * age,
            intelligence: 6,
            alignment: Alignment.ChaoticEvil,
            base_movement: 120ft,
            attacks: [
                MonsterAttack { name: "Claw", damage: 1d4 },
                MonsterAttack { name: "Claw", damage: 1d4 },
                MonsterAttack { name: "Bite", damage: 2d8 }
            ],
            size: Size.Large,
            special: ["BreathWeapon", "Infravision", "FearAura"],
            BreathWeapon {
                breath_name: "Frost Breath",
                breath_damage: 6d8,
                breath_type: DamageType.Cold,
                breath_charges_max: 3,
                breath_charges: 3
            }
        } with [
            Infravision(range: 60ft),
            FearAura(range: 30ft),
            ImmuneToCold,
            VulnerableToFire(extra_damage: 1),
        ]
    }

    function create_black_dragon(age: int) -> Monster {
        // HD 6-8; using 7 as middle value
        let hd = 7
