    function create_piercer(hd: int) -> Monster {
        // Piercers range from 1-4 HD. Drop from ceiling for hd*d6 damage.
        let hp = hd * 4
        let hd_dice = if hd == 1 { 1d8 } else if hd == 2 { 2d8 } else if hd == 3 { 3d8 } else { 4d8 }
        let dmg = if hd == 1 { 1d6 } else if hd == 2 { 2d6 } else if hd == 3 { 3d6 } else { 4d6 }
        let sz = if hd <= 2 { Size.Small } else { Size.Medium }
        let xp = if hd == 1 { 15 } else if hd == 2 { 30 } else if hd == 3 { 50 } else { 75 }
        Monster {
            name: "Piercer",
            hit_dice: hd_dice,
            max_hp: hp,
            hp: hp,
            ac: 17,
            morale: 12,
            xp_value: xp,
            intelligence: 0,
            alignment: Alignment.TrueNeutral,
            base_movement: 10ft,
            attacks: [MonsterAttack { name: "Drop", damage: dmg }],
            size: sz,
            special: ["CeilingDrop"]
        } with [CeilingDrop, ImmuneToMindControl]
    }

    // ── Oozes and Fungi ─────────────────────────────────────

    function create_green_slime() -> Monster {
        // Not a true combatant — dissolves organic material on contact.
        // AC 11 is nominal; immune to normal weapons per special rules.
        Monster {
            name: "Green Slime",
            hit_dice: 2d8,
            max_hp: 9,
            hp: 9,
            ac: 11,
            morale: 12,
            xp_value: 26,
            intelligence: 0,
            alignment: Alignment.TrueNeutral,
            base_movement: 3ft,
            attacks: [],
            size: Size.Small,
            special: ["DissolvesOrganic"]
        } with [Ooze, DissolvesOrganic, ImmuneToMindControl]
    }

    function create_yellow_mold() -> Monster {
        // Stationary fungus — releases spores when disturbed.
        // AC 11 is nominal; immune to physical damage per special rules.
        Monster {
            name: "Yellow Mold",
            hit_dice: 2d8,
            max_hp: 9,
            hp: 9,
            ac: 11,
            morale: 12,
            xp_value: 26,
            intelligence: 0,
            alignment: Alignment.TrueNeutral,
            base_movement: 0ft,
            attacks: [],
            size: Size.Small,
            special: ["SporeAttack"]
        } with [Fungus, SporeAttack, ImmuneToMindControl]
    }

    function create_grey_ooze() -> Monster {
        // Corrodes metal on contact; immune to cold and fire.
        Monster {
            name: "Grey Ooze",
            hit_dice: 3d8 + 3,
            max_hp: 16,
            hp: 16,
            ac: 12,
            morale: 12,
            xp_value: 155,
            intelligence: 0,
            alignment: Alignment.TrueNeutral,
            base_movement: 10ft,
            attacks: [MonsterAttack { name: "Strike", damage: 2d8 }],
            size: Size.Medium,
            special: ["DissolvesMetal"]
        } with [Ooze, DissolvesMetal, ImmuneToMindControl, ImmuneToCold, ImmuneToFire]
    }


    // ========================================================
    //  OUTSIDERS
    // ========================================================

    function create_efreet() -> Monster {
        Monster {
            name: "Efreet",
            hit_dice: 10d8,
            max_hp: 45,
            hp: 45,
            ac: 18,
            morale: 12,
            xp_value: 7000,
            intelligence: 12,
            alignment: Alignment.LawfulEvil,
            base_movement: 90ft,
            attacks: [MonsterAttack { name: "Fist", damage: 1d8 }],
            size: Size.Large,
            special: ["ImmuneToFire", "SpellLikeAbilities"],
            SpellAbility {
                innate_caster_level: 12,
                abilities: [
                    SpellLikeEntry { spell: SpellId.WallOfFire, uses: SpellUseLimit.AtWill }
                ]
            }
        } with [
            ImmuneToFire,
            Infravision(range: 60ft),
        ]
    }
}
