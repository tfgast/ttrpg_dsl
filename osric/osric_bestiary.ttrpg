    // ========================================================
    //  UNDEAD
    // ========================================================

    function create_skeleton() -> Monster {
        let m = Monster {
            name: "Skeleton",
            hit_dice: 1d8,
            max_hp: 4,
            hp: 4,
            ac: 13,
            morale: 12,
            xp_value: 15,
            intelligence: 0,
            alignment: Alignment.TrueNeutral,
            base_movement: 120ft,
            attacks: [MonsterAttack { name: "Strike", damage: 1d6 }],
            size: Size.Medium,
            special: ["Undead", "ResistantToBlunt"]
        }
        apply_condition(m, Undead, Duration.Indefinite)
        apply_condition(m, TurnedAsUndead(effective_hd: 1), Duration.Indefinite)
        apply_condition(m, ImmuneToCold, Duration.Indefinite)
        apply_condition(m, ImmuneToMindControl, Duration.Indefinite)
        apply_condition(m, ResistantToBlunt, Duration.Indefinite)
        m
    }

