    // ========================================================
    //  DRAGONS
    //
    //  Dragons are parameterised by age category (1-8).
    //  HP per die equals age category. Breath weapon damage
    //  equals current HP. 3 charges per day.
    // ========================================================

    function create_white_dragon(age: int) -> Monster {
        // HD 5-7 depending on sub-type; using 6 as middle value
        let hd = 6
        let hp = hd * age
        let m = Monster {
            name: "White Dragon",
            hit_dice: 6d8,
            max_hp: hp,
            hp: hp,
            ac: 17,
            morale: 10,
            xp_value: 500 + 100 * age,
            intelligence: 6,
            alignment: Alignment.ChaoticEvil,
            base_movement: 120ft,
            attacks: [
                MonsterAttack { name: "Claw", damage: 1d4 },
                MonsterAttack { name: "Claw", damage: 1d4 },
                MonsterAttack { name: "Bite", damage: 2d8 }
            ],
            size: Size.Large,
            special: ["BreathWeapon", "Infravision", "FearAura"],
            BreathWeapon {
                breath_name: "Frost Breath",
                breath_damage: 6d8,
                breath_type: DamageType.Cold,
                breath_charges_max: 3,
                breath_charges: 3
            }
        }
        apply_condition(m, Infravision(range: 60ft), Duration.Indefinite)
        apply_condition(m, FearAura(range: 30ft), Duration.Indefinite)
        apply_condition(m, ImmuneToCold, Duration.Indefinite)
        apply_condition(m, VulnerableToFire(extra_damage: 1), Duration.Indefinite)
        m
    }

    function create_black_dragon(age: int) -> Monster {
        // HD 6-8; using 7 as middle value
        let hd = 7
        let hp = hd * age
        let m = Monster {
            name: "Black Dragon",
            hit_dice: 7d8,
            max_hp: hp,
            hp: hp,
            ac: 17,
            morale: 11,
            xp_value: 700 + 100 * age,
            intelligence: 9,
            alignment: Alignment.ChaoticEvil,
            base_movement: 120ft,
            attacks: [
                MonsterAttack { name: "Claw", damage: 1d4 },
                MonsterAttack { name: "Claw", damage: 1d4 },
                MonsterAttack { name: "Bite", damage: 3d6 }
            ],
            size: Size.Large,
            special: ["BreathWeapon", "Infravision", "FearAura"],
            BreathWeapon {
                breath_name: "Acid Stream",
                breath_damage: 7d8,
                breath_type: DamageType.Acid,
                breath_charges_max: 3,
                breath_charges: 3
            }
        }
        apply_condition(m, Infravision(range: 60ft), Duration.Indefinite)
        apply_condition(m, FearAura(range: 30ft), Duration.Indefinite)
        apply_condition(m, ImmuneToAcid, Duration.Indefinite)
        m
    }

    function create_red_dragon(age: int) -> Monster {
        // HD 9-11; using 10 as middle value
        let hd = 10
        let hp = hd * age
        let m = Monster {
            name: "Red Dragon",
            hit_dice: 10d8,
            max_hp: hp,
            hp: hp,
            ac: 21,
            morale: 12,
            xp_value: 2000 + 200 * age,
            intelligence: 16,
            alignment: Alignment.ChaoticEvil,
            base_movement: 90ft,
            attacks: [
                MonsterAttack { name: "Claw", damage: 1d8 },
                MonsterAttack { name: "Claw", damage: 1d8 },
                MonsterAttack { name: "Bite", damage: 3d10 }
            ],
            size: Size.Huge,
            special: ["BreathWeapon", "Infravision", "FearAura"],
            BreathWeapon {
                breath_name: "Fire Breath",
                breath_damage: 10d8,
                breath_type: DamageType.Fire,
                breath_charges_max: 3,
                breath_charges: 3
            }
        }
        apply_condition(m, Infravision(range: 60ft), Duration.Indefinite)
        apply_condition(m, FearAura(range: 60ft), Duration.Indefinite)
        apply_condition(m, ImmuneToFire, Duration.Indefinite)
        m
    }


    // ========================================================
