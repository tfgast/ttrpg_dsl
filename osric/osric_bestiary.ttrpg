            size: Size.Medium,
            special: ["Undead", "ResistantToSlashingAndPiercing"]
        } with [
            Undead,
            TurnedAsUndead(effective_hd: 1),
            ImmuneToCold,
            ImmuneToMindControl,
            ResistantToSlashingAndPiercing,
        ]
    }

