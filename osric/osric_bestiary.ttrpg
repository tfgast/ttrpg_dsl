            alignment: Alignment.TrueNeutral,
            base_movement: 60ft,
            attacks: [MonsterAttack { name: "Strike", damage: 1d8 }],
            size: Size.Medium,
            special: ["Undead", "AlwaysLastInitiative"]
        }
        apply_condition(m, Undead, Duration.Indefinite)
        apply_condition(m, TurnedAsUndead(effective_hd: 2), Duration.Indefinite)
        apply_condition(m, ImmuneToCold, Duration.Indefinite)
        apply_condition(m, ImmuneToMindControl, Duration.Indefinite)
        m
    }

