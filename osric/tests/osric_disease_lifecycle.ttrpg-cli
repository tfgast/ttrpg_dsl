// OSRIC Diseased condition lifecycle integration tests
//
// Tests the multi-phase disease lifecycle: Incubation → Active → Recovery.
// Verifies state field progression via on DayEnded handler, penalty application
// during the active phase, and automatic condition removal after recovery.

load osric/*.ttrpg

// ── Incubation phase: no penalties applied ──────────────────────

spawn Character dis_inc { name: "Incubating", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }

call apply_condition(dis_inc, Diseased(stat_penalty: 4, roll_penalty: 3, is_fatal: false, source: DiseaseSource.Plague, incubation_days: 3, duration_days: 2), Duration.Indefinite)
assert_condition dis_inc, Diseased

// Days 1-2: still incubating
repeat 2 {
    emit DayEnded(combatant: dis_inc)
    assert_condition dis_inc, Diseased
}

// ── Transition to Active phase at incubation end ────────────────

// Day 3: incubation_days reached → transitions to Active
emit DayEnded(combatant: dis_inc)
assert_condition dis_inc, Diseased

// Day 4: first day of active phase (days_elapsed resets; this is day 1 of active)
emit DayEnded(combatant: dis_inc)
assert_condition dis_inc, Diseased

// ── Transition to Recovery after active duration ────────────────

// Day 5: duration_days (2) reached → transitions to Recovery
emit DayEnded(combatant: dis_inc)
assert_condition dis_inc, Diseased

// ── Recovery phase: penalties decrease 1/day ────────────────────

// Recovery days 1-3: penalties decrease 1/day, condition persists
repeat 3 {
    emit DayEnded(combatant: dis_inc)
    assert_condition dis_inc, Diseased
}

// Recovery day 4: penalty drops 1→0 / already 0 → condition removed
emit DayEnded(combatant: dis_inc)
assert_no_condition dis_inc, Diseased


// ── Fatal disease: death at end of active phase ─────────────────

spawn Character dis_fatal { name: "Doomed", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

call apply_condition(dis_fatal, Diseased(stat_penalty: 3, roll_penalty: 2, is_fatal: true, source: DiseaseSource.Infection, incubation_days: 2, duration_days: 2), Duration.Indefinite)
assert_condition dis_fatal, Diseased
assert_no_condition dis_fatal, Dead

// Incubation: 2 days
repeat 2 {
    emit DayEnded(combatant: dis_fatal)
}
assert_condition dis_fatal, Diseased
assert_no_condition dis_fatal, Dead

// Active: 2 days → fatal death
emit DayEnded(combatant: dis_fatal)
assert_condition dis_fatal, Diseased
assert_no_condition dis_fatal, Dead

emit DayEnded(combatant: dis_fatal)
assert_no_condition dis_fatal, Diseased
assert_condition dis_fatal, Dead


// ── Cure during incubation: removes condition before symptoms ───

spawn Character dis_cured { name: "CuredEarly", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }

call apply_condition(dis_cured, Diseased(stat_penalty: 4, roll_penalty: 3, is_fatal: true, source: DiseaseSource.Plague, incubation_days: 5, duration_days: 3), Duration.Indefinite)
assert_condition dis_cured, Diseased

// Tick 1 day, then cure
emit DayEnded(combatant: dis_cured)
call remove_condition(dis_cured, "Diseased")
assert_no_condition dis_cured, Diseased
assert_no_condition dis_cured, Dead

// Further ticks have no effect
emit DayEnded(combatant: dis_cured)
assert_no_condition dis_cured, Diseased
assert_no_condition dis_cured, Dead
