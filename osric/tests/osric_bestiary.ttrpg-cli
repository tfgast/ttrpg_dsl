// OSRIC Bestiary integration tests
//
// Equivalent of the runtime portions of
// crates/ttrpg_interp/tests/osric_bestiary_integration.rs.
// Parser/typechecker coverage remains in Rust.

load osric/*.ttrpg

// ── Factory creation: humanoids ────────────────────────────────

assert_eq create_goblin().name, "Goblin"
assert_eq create_goblin().ac, 14
assert_eq create_goblin().morale, 7
assert_eq create_goblin().xp_value, 10
assert_eq create_goblin().intelligence, 9

assert_eq create_orc().name, "Orc"
assert_eq create_orc().max_hp, 4

assert_eq create_ogre().name, "Ogre"
assert_eq create_ogre().ac, 15
assert_eq create_ogre().size, Size.Large

// ── Undead and classic monsters ────────────────────────────────

let skeleton = create_skeleton()
assert any([c.name == "Undead" for c in conditions(skeleton)])
assert any([c.name == "TurnedAsUndead" for c in conditions(skeleton)])
assert any([c.name == "ImmuneToCold" for c in conditions(skeleton)])
assert any([c.name == "ImmuneToMindControl" for c in conditions(skeleton)])
assert any([c.name == "ResistantToSlashingAndPiercing" for c in conditions(skeleton)])
assert !any([c.name == "ResistantToBlunt" for c in conditions(skeleton)])

let wight = create_wight()
assert any([c.name == "ImmuneToNormalWeaponsExceptSilver" for c in conditions(wight)])
assert !any([c.name == "ImmuneToNormalWeapons" for c in conditions(wight)])

let wraith = create_wraith()
assert any([c.name == "ImmuneToNormalWeaponsExceptSilver" for c in conditions(wraith)])
assert !any([c.name == "ImmuneToNormalWeapons" for c in conditions(wraith)])

let vampire = create_vampire()
assert_eq vampire.name, "Vampire"
assert_eq vampire.ac, 19
assert any([c.name == "Undead" for c in conditions(vampire)])
assert any([c.name == "Regeneration" for c in conditions(vampire)])
assert any([c.name == "ImmuneToNormalWeapons" for c in conditions(vampire)])
assert any([c.name == "ImmuneToMindControl" for c in conditions(vampire)])
assert any([c.name == "ShapeChanger" for c in conditions(vampire)])

let troll = create_troll()
assert_eq troll.name, "Troll"
assert any([c.name == "Regeneration" for c in conditions(troll)])
assert any([c.name == "VulnerableToFire" for c in conditions(troll)])
assert any([c.name == "VulnerableToAcid" for c in conditions(troll)])

// ── Regeneration periodic heals at round start ───────────────
// Monster with Regeneration(3) heals 3 HP/round, capped at max_hp.
spawn Monster regen_troll { name: "Regen Troll", hit_dice: 6d8 + 6, max_hp: 33, hp: 33, ac: 16, attacks: [MonsterAttack { name: "Claw", damage: 1d6 + 4 }], special: [] }
call apply_condition(regen_troll, Regeneration(hp_per_round: 3), Duration.Indefinite)
set regen_troll.hp = 20
assert_eq regen_troll.hp, 20
emit RoundStartHealing(combatant: regen_troll)
assert_eq regen_troll.hp, 23
emit RoundStartHealing(combatant: regen_troll)
assert_eq regen_troll.hp, 26
// Healing caps at max_hp
set regen_troll.hp = 32
emit RoundStartHealing(combatant: regen_troll)
assert_eq regen_troll.hp, 33
// At full HP, no change
emit RoundStartHealing(combatant: regen_troll)
assert_eq regen_troll.hp, 33

let basilisk = create_basilisk()
assert any([c.name == "PetrifyingGaze" for c in conditions(basilisk)])

let cube = create_gelatinous_cube()
assert_eq cube.intelligence, 0
assert any([c.name == "Construct" for c in conditions(cube)])
assert any([c.name == "ImmuneToLightning" for c in conditions(cube)])
assert any([c.name == "ImmuneToMindControl" for c in conditions(cube)])

// ── Dragons and giants ─────────────────────────────────────────

let red_dragon = create_red_dragon(5)
assert_eq red_dragon.name, "Red Dragon"
assert_eq red_dragon.max_hp, 50
assert_eq red_dragon.ac, 21
assert_eq red_dragon.size, Size.Huge
assert any([c.name == "ImmuneToFire" for c in conditions(red_dragon)])
assert any([c.name == "Infravision" for c in conditions(red_dragon)])
assert any([c.name == "FearAura" for c in conditions(red_dragon)])

let white_dragon = create_white_dragon(3)
assert_eq white_dragon.max_hp, 18
assert any([c.name == "ImmuneToCold" for c in conditions(white_dragon)])
assert any([c.name == "VulnerableToFire" for c in conditions(white_dragon)])

let fire_giant = create_fire_giant()
assert any([c.name == "ImmuneToFire" for c in conditions(fire_giant)])
assert_eq fire_giant.ac, 17

// ── Monster saving throws ──────────────────────────────────────

assert_eq monster_saves_normal(1).aimed_magic, 16
assert_eq monster_saves_normal(1).breath, 17
assert_eq monster_saves_normal(1).death_paralysis_poison, 14

assert_eq monster_saves_nonintelligent(9).aimed_magic, 13
assert_eq monster_saves_nonintelligent(9).petrification_polymorph, 12

// ── Animals and outsiders ──────────────────────────────────────

let giant_spider = create_giant_spider()
assert any([c.name == "ImmuneToPoison" for c in conditions(giant_spider)])
assert_eq giant_spider.size, Size.Large

assert_eq create_owlbear().attacks.len(), 3

let efreet = create_efreet()
assert any([c.name == "ImmuneToFire" for c in conditions(efreet)])
assert any([c.name == "Infravision" for c in conditions(efreet)])
assert_eq efreet.xp_value, 7000

// ── Warding taxonomy markers exist and can be applied ──────────

spawn Monster ward_demon { name: "Demon Test", hit_dice: 4d8, max_hp: 18, hp: 18, ac: 15, attacks: [MonsterAttack { name: "Claw", damage: 1d6 }], special: [] }
call apply_condition(ward_demon, Demon, Duration.Indefinite)
assert any([c.name == "Demon" for c in conditions(ward_demon)])

spawn Monster ward_elemental { name: "Elemental Test", hit_dice: 8d8, max_hp: 36, hp: 36, ac: 16, attacks: [MonsterAttack { name: "Slam", damage: 2d6 }], special: [] }
call apply_condition(ward_elemental, FireElemental, Duration.Indefinite)
assert any([c.name == "FireElemental" for c in conditions(ward_elemental)])

spawn Monster ward_lycanthrope { name: "Werewolf Test", hit_dice: 4d8, max_hp: 20, hp: 20, ac: 14, attacks: [MonsterAttack { name: "Bite", damage: 1d6 }], special: [] }
call apply_condition(ward_lycanthrope, Werewolf, Duration.Indefinite)
call apply_condition(ward_lycanthrope, Lycanthrope, Duration.Indefinite)
assert any([c.name == "Werewolf" for c in conditions(ward_lycanthrope)])
assert any([c.name == "Lycanthrope" for c in conditions(ward_lycanthrope)])

// ── Low-level dungeon monsters ───────────────────────────────

let trog = create_troglodyte()
assert_eq trog.name, "Troglodyte"
assert_eq trog.ac, 15
assert_eq trog.max_hp, 9
assert_eq trog.attacks.len(), 3
assert any([c.name == "Stench" for c in conditions(trog)])
assert any([c.name == "Infravision" for c in conditions(trog)])

let lizardman = create_lizard_man()
assert_eq lizardman.name, "Lizard Man"
assert_eq lizardman.ac, 15
assert_eq lizardman.max_hp, 10
assert_eq lizardman.attacks.len(), 3
assert_eq lizardman.size, Size.Medium

let shrieker = create_shrieker()
assert_eq shrieker.name, "Shrieker"
assert_eq shrieker.ac, 13
assert_eq shrieker.attacks.len(), 0
assert any([c.name == "Fungus" for c in conditions(shrieker)])
assert any([c.name == "ImmuneToMindControl" for c in conditions(shrieker)])

let centipede = create_giant_centipede()
assert_eq centipede.name, "Giant Centipede"
assert_eq centipede.ac, 11
assert_eq centipede.max_hp, 1
assert_eq centipede.size, Size.Small
assert any([c.name == "WeakPoison" for c in conditions(centipede)])

let ant_w = create_giant_ant_worker()
assert_eq ant_w.name, "Giant Ant (Worker)"
assert_eq ant_w.ac, 17
assert_eq ant_w.max_hp, 9
assert_eq ant_w.size, Size.Small
assert any([c.name == "ImmuneToMindControl" for c in conditions(ant_w)])

let ant_s = create_giant_ant_soldier()
assert_eq ant_s.name, "Giant Ant (Soldier)"
assert_eq ant_s.ac, 17
assert_eq ant_s.max_hp, 13
assert_eq ant_s.size, Size.Medium
assert any([c.name == "VenomousSting" for c in conditions(ant_s)])

let stirge = create_stirge()
assert_eq stirge.name, "Stirge"
assert_eq stirge.ac, 12
assert_eq stirge.max_hp, 5
assert any([c.name == "BloodDrain" for c in conditions(stirge)])

let harpy = create_harpy()
assert_eq harpy.name, "Harpy"
assert_eq harpy.ac, 13
assert_eq harpy.max_hp, 13
assert_eq harpy.attacks.len(), 3
assert any([c.name == "CharmSong" for c in conditions(harpy)])

// Piercer — parameterized by HD (1-4)
let piercer1 = create_piercer(1)
assert_eq piercer1.name, "Piercer"
assert_eq piercer1.ac, 17
assert_eq piercer1.max_hp, 4
assert_eq piercer1.size, Size.Small
assert any([c.name == "CeilingDrop" for c in conditions(piercer1)])
assert any([c.name == "ImmuneToMindControl" for c in conditions(piercer1)])

let piercer4 = create_piercer(4)
assert_eq piercer4.max_hp, 16
assert_eq piercer4.size, Size.Medium
assert_eq piercer4.xp_value, 75

// ── Oozes and fungi ──────────────────────────────────────────

let gslime = create_green_slime()
assert_eq gslime.name, "Green Slime"
assert_eq gslime.ac, 11
assert_eq gslime.attacks.len(), 0
assert any([c.name == "Ooze" for c in conditions(gslime)])
assert any([c.name == "DissolvesOrganic" for c in conditions(gslime)])
assert any([c.name == "ImmuneToMindControl" for c in conditions(gslime)])

let ymold = create_yellow_mold()
assert_eq ymold.name, "Yellow Mold"
assert_eq ymold.attacks.len(), 0
assert any([c.name == "Fungus" for c in conditions(ymold)])
assert any([c.name == "SporeAttack" for c in conditions(ymold)])

let gooze = create_grey_ooze()
assert_eq gooze.name, "Grey Ooze"
assert_eq gooze.ac, 12
assert_eq gooze.max_hp, 16
assert any([c.name == "Ooze" for c in conditions(gooze)])
assert any([c.name == "DissolvesMetal" for c in conditions(gooze)])
assert any([c.name == "ImmuneToCold" for c in conditions(gooze)])
assert any([c.name == "ImmuneToFire" for c in conditions(gooze)])

// ── Stench zone — mechanical effects ─────────────────────────
// Troglodyte stench creates a 30ft zone. Creatures inside
// receive StenchNauseated: -2 attack, +2 (worse) saves.
// Troglodytes themselves are immune.

pos stench_origin 100 100

// Create stench zone anchored to the troglodyte
let stench_trog = create_troglodyte()
let stench_zone = create_stench_zone(stench_trog, stench_origin, "stench-zone-1")
place stench_zone 100 100

// Spawn a victim fighter
spawn Character stench_victim { name: "Stench Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 16, INT: 12, WIS: 12, DEX: 14, CON: 14, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 } }

// Before entering zone: no StenchNauseated
assert_no_condition stench_victim, StenchNauseated

// Enter the stench zone
emit ZoneEntered(target: stench_victim, zone: stench_zone)
assert_condition stench_victim, StenchNauseated

// Verify saves are worsened (+2 penalty = higher target numbers).
// Capture saves while nauseated, then remove and compare.
let nauseated_saves = entity_best_saves(stench_victim)

// Exit the stench zone — condition removed
emit ZoneExited(target: stench_victim, zone: stench_zone)
assert_no_condition stench_victim, StenchNauseated

// Now compare: clean saves should be 2 lower (better) than nauseated
let clean_saves = entity_best_saves(stench_victim)
assert_eq nauseated_saves.aimed_magic, clean_saves.aimed_magic + 2
assert_eq nauseated_saves.breath, clean_saves.breath + 2
assert_eq nauseated_saves.death_paralysis_poison, clean_saves.death_paralysis_poison + 2
assert_eq nauseated_saves.petrification_polymorph, clean_saves.petrification_polymorph + 2
assert_eq nauseated_saves.spells, clean_saves.spells + 2

// Troglodyte enters own stench zone — should NOT get nauseated
emit ZoneEntered(target: stench_trog, zone: stench_zone)
assert_no_condition stench_trog, StenchNauseated

// ── Overlapping stench zones ─────────────────────────────────
// Two troglodytes = two zones. Exiting one still leaves the other.

let stench_trog2 = create_troglodyte()
let stench_zone2 = create_stench_zone(stench_trog2, stench_origin, "stench-zone-2")
place stench_zone2 100 100

spawn Character stench_overlap { name: "Overlap Victim", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

emit ZoneEntered(target: stench_overlap, zone: stench_zone)
emit ZoneEntered(target: stench_overlap, zone: stench_zone2)
assert_condition stench_overlap, StenchNauseated

// Exit one zone — still nauseated by the other
emit ZoneExited(target: stench_overlap, zone: stench_zone)
assert_condition stench_overlap, StenchNauseated

// Exit second zone — fully clear
emit ZoneExited(target: stench_overlap, zone: stench_zone2)
assert_no_condition stench_overlap, StenchNauseated
