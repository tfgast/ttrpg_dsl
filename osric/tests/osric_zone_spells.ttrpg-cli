// OSRIC Zone Spells integration tests
//
// Proves two zone patterns:
//
// Occupant-condition pattern (ZoneEntered / ZoneExited):
//   1. Silence zone: enter → Silenced, exit → removed
//   2. Overlapping silence zones: exit one → still silenced
//   3. Protection from Evil zone: enter → protected, exit → removed
//   4. Overlapping PFE zones: exit one → still protected
//   5. Non-matching zone: no conditions applied
//   6. Darkness zone: enter → InMagicalDarkness, exit → removed
//   7. Overlapping darkness zones: exit one → still in darkness
//   8. Darkness/Continual Light cancellation: both zones despawned
//   9. Non-matching zone: no InMagicalDarkness applied
//
// Barrier-crossing pattern (ZoneCrossed / condition-based per-round):
//   6. Wall of Fire: crossing deals 2d6+level fire damage
//   7. Wall of Fire: non-matching zone crossing deals no damage
//   8. Blade Barrier: crossing deals 8d8 slashing damage
//   9. Blade Barrier: ZoneEntered applies InsideBladeBarrier condition
//  10. Blade Barrier: periodic condition block deals per-round damage
//  11. Blade Barrier: ZoneExited removes InsideBladeBarrier condition

load osric/*.ttrpg


// ══════════════════════════════════════════════════════════════════
//  SILENCE 15' RADIUS — STATIONARY ZONE
// ══════════════════════════════════════════════════════════════════


// ── Basic enter / exit ───────────────────────────────────────────

spawn Character sil_target { name: "Cleric", classes: [ClassLevel { class: Cleric, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, Spellcasting { spell_slots: [3, 2], slots_used: [0, 0], memorised_spells: [] } }

spawn Zone sil_zone_1 { name: "silence-zone-1", source: EffectSource.Spell(name: "Silence 15' Radius", caster_level: 5), shape: ZoneShape.Radius(radius: 15ft) }
place sil_zone_1 5 5

// Before entering: no condition
assert_no_condition sil_target, Silenced

// Host emits ZoneEntered
emit ZoneEntered(target: sil_target, zone: sil_zone_1)
assert_condition sil_target, Silenced

// Verify spellcasting is blocked
assert_eq can_begin_casting(sil_target), false

// Host emits ZoneExited
emit ZoneExited(target: sil_target, zone: sil_zone_1)
assert_no_condition sil_target, Silenced

// Spellcasting restored
assert_eq can_begin_casting(sil_target), true


// ── Overlapping silence zones ────────────────────────────────────
// Two silence zones overlap. Target enters both. Exiting one zone
// removes only that zone's condition; the other remains.

spawn Character sil_overlap_target { name: "Wizard", classes: [ClassLevel { class: MagicUser, level: 7 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 }, Spellcasting { spell_slots: [4, 3, 2, 1], slots_used: [0, 0, 0, 0], memorised_spells: [] } }

spawn Zone sil_zone_2a { name: "silence-zone-2a", source: EffectSource.Spell(name: "Silence 15' Radius", caster_level: 5), shape: ZoneShape.Radius(radius: 15ft) }
place sil_zone_2a 10 10

spawn Zone sil_zone_2b { name: "silence-zone-2b", source: EffectSource.Spell(name: "Silence 15' Radius", caster_level: 3), shape: ZoneShape.Radius(radius: 15ft) }
place sil_zone_2b 12 10

// Enter both zones
emit ZoneEntered(target: sil_overlap_target, zone: sil_zone_2a)
emit ZoneEntered(target: sil_overlap_target, zone: sil_zone_2b)
assert_condition sil_overlap_target, Silenced
assert_eq can_begin_casting(sil_overlap_target), false

// Exit zone 2a — still silenced by 2b
emit ZoneExited(target: sil_overlap_target, zone: sil_zone_2a)
assert_condition sil_overlap_target, Silenced
assert_eq can_begin_casting(sil_overlap_target), false

// Exit zone 2b — fully unsilenced
emit ZoneExited(target: sil_overlap_target, zone: sil_zone_2b)
assert_no_condition sil_overlap_target, Silenced
assert_eq can_begin_casting(sil_overlap_target), true


// ══════════════════════════════════════════════════════════════════
//  PROTECTION FROM EVIL 10' RADIUS — ANCHORED ZONE
// ══════════════════════════════════════════════════════════════════


// ── Basic enter / exit ───────────────────────────────────────────

spawn Character pfe_target { name: "Fighter PFE", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 } }

spawn Zone pfe_zone { name: "pfe-zone-1", source: EffectSource.Spell(name: "Protection from Evil 10' Radius", caster_level: 7), moves_with_anchor: true, shape: ZoneShape.Radius(radius: 10ft) }
place pfe_zone 5 5

// Before entering: no condition
assert_no_condition pfe_target, ProtectedFromEvil10Zone

// Enter zone
emit ZoneEntered(target: pfe_target, zone: pfe_zone)
assert_condition pfe_target, ProtectedFromEvil10Zone

// Exit zone
emit ZoneExited(target: pfe_target, zone: pfe_zone)
assert_no_condition pfe_target, ProtectedFromEvil10Zone


// ── Overlapping PFE zones ────────────────────────────────────────

spawn Character pfe_target_2 { name: "Ranger PFE", classes: [ClassLevel { class: Ranger, level: 5 }], abilities: { STR: 15, INT: 12, WIS: 14, DEX: 15, CON: 12, CHA: 12 }, HitPoints { max_hp: 35, hp: 35 } }

spawn Zone pfe_zone_2a { name: "pfe-zone-2a", source: EffectSource.Spell(name: "Protection from Evil 10' Radius", caster_level: 7), shape: ZoneShape.Radius(radius: 10ft), moves_with_anchor: true }
place pfe_zone_2a 5 5

spawn Zone pfe_zone_2b { name: "pfe-zone-2b", source: EffectSource.Spell(name: "Protection from Evil 10' Radius", caster_level: 5), shape: ZoneShape.Radius(radius: 10ft), moves_with_anchor: true }
place pfe_zone_2b 6 5

// Enter both
emit ZoneEntered(target: pfe_target_2, zone: pfe_zone_2a)
emit ZoneEntered(target: pfe_target_2, zone: pfe_zone_2b)
assert_condition pfe_target_2, ProtectedFromEvil10Zone

// Exit one — still protected by the other
emit ZoneExited(target: pfe_target_2, zone: pfe_zone_2a)
assert_condition pfe_target_2, ProtectedFromEvil10Zone

// Exit the other — fully unprotected
emit ZoneExited(target: pfe_target_2, zone: pfe_zone_2b)
assert_no_condition pfe_target_2, ProtectedFromEvil10Zone


// ══════════════════════════════════════════════════════════════════
//  NON-MATCHING ZONE — HOOK SELECTIVITY
// ══════════════════════════════════════════════════════════════════

// A zone with a different source should not trigger any conditions.

spawn Character nm_target { name: "Bystander", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

spawn Zone nm_zone { name: "fire-zone-1", source: EffectSource.Spell(name: "Wall of Fire", caster_level: 9), shape: ZoneShape.Wall(length: 60ft, thickness: 5ft), contact_mode: Crossed }
place nm_zone 0 0

emit ZoneEntered(target: nm_target, zone: nm_zone)
assert_no_condition nm_target, Silenced
assert_no_condition nm_target, ProtectedFromEvil10Zone


// ══════════════════════════════════════════════════════════════════
//  DARKNESS 15' RADIUS — OCCUPANT-CONDITION ZONE
// ══════════════════════════════════════════════════════════════════


// ── Basic enter / exit ───────────────────────────────────────────

spawn Character dark_target { name: "Wizard Dark", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 15, hp: 15 }, Spellcasting { spell_slots: [4, 2, 1], slots_used: [0, 0, 0], memorised_spells: [] } }

spawn Zone dark_zone_1 { name: "darkness-zone-1", source: EffectSource.Spell(name: "Darkness 15' Radius", caster_level: 5), shape: ZoneShape.Sphere(radius: 15ft) }
place dark_zone_1 50 50

// Before entering: no condition
assert_no_condition dark_target, InMagicalDarkness

// Host emits ZoneEntered
emit ZoneEntered(target: dark_target, zone: dark_zone_1)
assert_condition dark_target, InMagicalDarkness

// Verify spellcasting is blocked
assert_eq can_begin_casting(dark_target), false

// Host emits ZoneExited
emit ZoneExited(target: dark_target, zone: dark_zone_1)
assert_no_condition dark_target, InMagicalDarkness

// Spellcasting restored
assert_eq can_begin_casting(dark_target), true


// ── Overlapping darkness zones ────────────────────────────────────
// Two darkness zones overlap. Target enters both. Exiting one zone
// removes only that zone's condition; the other remains.

spawn Character dark_overlap { name: "Wizard Overlap Dark", classes: [ClassLevel { class: MagicUser, level: 7 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 }, Spellcasting { spell_slots: [4, 3, 2, 1], slots_used: [0, 0, 0, 0], memorised_spells: [] } }

spawn Zone dark_zone_2a { name: "darkness-zone-2a", source: EffectSource.Spell(name: "Darkness 15' Radius", caster_level: 5), shape: ZoneShape.Sphere(radius: 15ft) }
place dark_zone_2a 60 60

spawn Zone dark_zone_2b { name: "darkness-zone-2b", source: EffectSource.Spell(name: "Darkness 15' Radius", caster_level: 3), shape: ZoneShape.Sphere(radius: 15ft) }
place dark_zone_2b 62 60

// Enter both zones
emit ZoneEntered(target: dark_overlap, zone: dark_zone_2a)
emit ZoneEntered(target: dark_overlap, zone: dark_zone_2b)
assert_condition dark_overlap, InMagicalDarkness
assert_eq can_begin_casting(dark_overlap), false

// Exit zone 2a — still in darkness from 2b
emit ZoneExited(target: dark_overlap, zone: dark_zone_2a)
assert_condition dark_overlap, InMagicalDarkness
assert_eq can_begin_casting(dark_overlap), false

// Exit zone 2b — fully clear
emit ZoneExited(target: dark_overlap, zone: dark_zone_2b)
assert_no_condition dark_overlap, InMagicalDarkness
assert_eq can_begin_casting(dark_overlap), true


// ── Darkness / Continual Light cancellation ───────────────────────
// When the host detects a Darkness zone overlapping a Continual Light
// zone, it emits DarknessCancelsLight. Both zones are despawned.

spawn Character dark_light_target { name: "Bystander DL", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }

spawn Zone dark_cancel_zone { name: "darkness-cancel", source: EffectSource.Spell(name: "Darkness 15' Radius", caster_level: 5), shape: ZoneShape.Sphere(radius: 15ft) }
place dark_cancel_zone 70 70

spawn Zone light_cancel_zone { name: "continual-light", source: EffectSource.Spell(name: "Continual Light", caster_level: 7), shape: ZoneShape.Sphere(radius: 60ft) }
place light_cancel_zone 72 70

// Target enters darkness zone first
emit ZoneEntered(target: dark_light_target, zone: dark_cancel_zone)
assert_condition dark_light_target, InMagicalDarkness

// Host detects overlap and emits ZoneExited for occupants before cancellation
// (per spatial_zone_protocol.md: host emits ZoneExited before despawn)
emit ZoneExited(target: dark_light_target, zone: dark_cancel_zone)
assert_no_condition dark_light_target, InMagicalDarkness

// Host then emits the cancellation event to despawn both zones
emit DarknessCancelsLight(darkness_zone: dark_cancel_zone, light_zone: light_cancel_zone)


// ── Non-matching zone does not apply InMagicalDarkness ────────────

spawn Character dark_bystander { name: "Dark Bystander", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

spawn Zone dark_wrong_zone { name: "silence-not-dark", source: EffectSource.Spell(name: "Silence 15' Radius", caster_level: 5), shape: ZoneShape.Radius(radius: 15ft) }
place dark_wrong_zone 80 80

emit ZoneEntered(target: dark_bystander, zone: dark_wrong_zone)
assert_no_condition dark_bystander, InMagicalDarkness


// ══════════════════════════════════════════════════════════════════
//  WALL OF FIRE — BARRIER ZONE (CROSSING DAMAGE)
// ══════════════════════════════════════════════════════════════════


// ── Basic crossing damage ──────────────────────────────────────
// Crossing a Wall of Fire deals 2d6 + caster_level fire damage.
// With caster_level 9, minimum damage is 2+9 = 11, max is 12+9 = 21.

spawn Character wof_target { name: "Wall Runner", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 16, INT: 12, WIS: 12, DEX: 14, CON: 14, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 } }

spawn Zone wof_zone { name: "wall-of-fire-1", source: EffectSource.Spell(name: "Wall of Fire", caster_level: 9), shape: ZoneShape.Wall(length: 60ft, thickness: 5ft), contact_mode: Crossed, tracks_occupancy: true }
place wof_zone 10 10

// Before crossing: full HP
assert_eq wof_target.hp, 40

// Host emits ZoneCrossed (target walked through the wall)
emit ZoneCrossed(target: wof_target, zone: wof_zone)

// Damage dealt: 2d6+9 (range 11–21), so HP should be 19–29
assert_eq wof_target.hp < 40, true
assert_eq wof_target.hp >= 19, true


// ── Non-matching zone crossing ─────────────────────────────────
// Crossing a zone with a different source should not trigger
// Wall of Fire damage.

spawn Character wof_bystander { name: "Wall Bystander", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

spawn Zone wof_wrong_zone { name: "silence-zone-crossed", source: EffectSource.Spell(name: "Silence 15' Radius", caster_level: 5), shape: ZoneShape.Radius(radius: 15ft), contact_mode: Crossed }
place wof_wrong_zone 20 20

emit ZoneCrossed(target: wof_bystander, zone: wof_wrong_zone)
assert_eq wof_bystander.hp, 20


// ══════════════════════════════════════════════════════════════════
//  BLADE BARRIER — BARRIER ZONE (CROSSING + PER-ROUND DAMAGE)
// ══════════════════════════════════════════════════════════════════


// ── Crossing damage ────────────────────────────────────────────
// Crossing a Blade Barrier deals 8d8 slashing damage.
// Range: 8–64. With 100 HP we can safely verify damage occurred.

spawn Character bb_target { name: "Blade Runner", classes: [ClassLevel { class: Fighter, level: 10 }], abilities: { STR: 18, INT: 12, WIS: 12, DEX: 16, CON: 16, CHA: 12 }, HitPoints { max_hp: 100, hp: 100 } }

spawn Zone bb_zone { name: "blade-barrier-1", source: EffectSource.Spell(name: "Blade Barrier", caster_level: 12), shape: ZoneShape.Sphere(radius: 15ft), contact_mode: Crossed, tracks_occupancy: true }
place bb_zone 30 30

// Before crossing: full HP
assert_eq bb_target.hp, 100

// Host emits ZoneCrossed (target charged through the blades)
emit ZoneCrossed(target: bb_target, zone: bb_zone)

// Damage dealt: 8d8 (range 8–64), so HP should be 36–92
assert_eq bb_target.hp < 100, true
assert_eq bb_target.hp >= 36, true


// ── Condition applied on zone entry ────────────────────────────
// Entering a Blade Barrier zone should apply the InsideBladeBarrier
// condition via the ZoneEntered hook.

emit ZoneEntered(target: bb_target, zone: bb_zone)
assert_condition bb_target, InsideBladeBarrier


// ── Per-round occupant damage via condition event handler ─────
// Per-round damage uses the on RoundEndDamage handler on
// InsideBladeBarrier, triggered by emitting per-combatant events.

let bb_hp_after_cross = bb_target.hp

emit RoundEndDamage(combatant: bb_target)

// Additional 8d8 damage applied
assert_eq bb_target.hp < bb_hp_after_cross, true


// ── Condition removed on zone exit ────────────────────────────
// Exiting a Blade Barrier zone removes the InsideBladeBarrier condition.

emit ZoneExited(target: bb_target, zone: bb_zone)
assert_no_condition bb_target, InsideBladeBarrier


// ── Non-matching zone entry ───────────────────────────────────
// Entering a non-Blade Barrier zone should not apply InsideBladeBarrier.

spawn Character bb_bystander { name: "Tick Bystander", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

spawn Zone bb_wrong_zone { name: "wrong-zone-tick", source: EffectSource.Spell(name: "Wall of Fire", caster_level: 9), shape: ZoneShape.Wall(length: 60ft, thickness: 5ft), contact_mode: Crossed }
place bb_wrong_zone 40 40

emit ZoneEntered(target: bb_bystander, zone: bb_wrong_zone)
assert_no_condition bb_bystander, InsideBladeBarrier

// RoundEndDamage should not deal damage to target without the condition
emit RoundEndDamage(combatant: bb_bystander)
assert_eq bb_bystander.hp, 20


// ══════════════════════════════════════════════════════════════════
//  ZONE_SYNC — AUTOMATED MEMBERSHIP DIFFING
// ══════════════════════════════════════════════════════════════════


// ── Basic zone_sync: enter a silence zone ────────────────────────
// Place a target inside a silence zone's radius, then run zone_sync.
// Should auto-emit ZoneEntered and apply the Silenced condition.
// Coordinates use 200+ to avoid overlap with zones from prior tests.

spawn Character zs_target { name: "Sync Target", classes: [ClassLevel { class: Cleric, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, Spellcasting { spell_slots: [3, 2], slots_used: [0, 0], memorised_spells: [] } }

spawn Zone zs_zone { name: "zs-silence-1", source: EffectSource.Spell(name: "Silence 15' Radius", caster_level: 5), shape: ZoneShape.Radius(radius: 15ft) }
place zs_zone 200 200

// Target outside the zone (distance = 100 > 3 squares)
place zs_target 300 300
zone_sync
assert_no_condition zs_target, Silenced

// Move target inside the zone (distance = 2 <= 3 squares)
place zs_target 202 200
zone_sync
assert_condition zs_target, Silenced
assert_eq can_begin_casting(zs_target), false

// Move target back out (distance = 100 > 3 squares)
place zs_target 300 300
zone_sync
assert_no_condition zs_target, Silenced
assert_eq can_begin_casting(zs_target), true


// ── zone_sync with overlapping zones ─────────────────────────────
// Two silence zones. Target enters both, exits one — still silenced.

spawn Character zs_overlap { name: "Sync Overlap", classes: [ClassLevel { class: MagicUser, level: 7 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 }, Spellcasting { spell_slots: [4, 3, 2, 1], slots_used: [0, 0, 0, 0], memorised_spells: [] } }

spawn Zone zs_zone_a { name: "zs-silence-a", source: EffectSource.Spell(name: "Silence 15' Radius", caster_level: 5), shape: ZoneShape.Radius(radius: 15ft) }
place zs_zone_a 210 200

spawn Zone zs_zone_b { name: "zs-silence-b", source: EffectSource.Spell(name: "Silence 15' Radius", caster_level: 3), shape: ZoneShape.Radius(radius: 15ft) }
place zs_zone_b 212 200

// Move into both zones (distance to 210,200 = 1, to 212,200 = 1)
place zs_overlap 211 200
zone_sync
assert_condition zs_overlap, Silenced
assert_eq can_begin_casting(zs_overlap), false

// Move to overlap with zone_b only (distance to 212,200 = 2, to 210,200 = 4)
place zs_overlap 214 200
zone_sync
assert_condition zs_overlap, Silenced

// Move fully out of both
place zs_overlap 500 500
zone_sync
assert_no_condition zs_overlap, Silenced


// ── zone_sync + condition-based per-round damage ─────────────────
// Place a target inside a Blade Barrier via zone_sync (which emits
// ZoneEntered and applies InsideBladeBarrier), then verify
// RoundEndDamage event triggers per-round damage.

spawn Character zt_target { name: "Tick Target", classes: [ClassLevel { class: Fighter, level: 10 }], abilities: { STR: 18, INT: 12, WIS: 12, DEX: 16, CON: 16, CHA: 12 }, HitPoints { max_hp: 100, hp: 100 } }

spawn Zone zt_bb_zone { name: "zt-blade-barrier", source: EffectSource.Spell(name: "Blade Barrier", caster_level: 12), shape: ZoneShape.Sphere(radius: 15ft), contact_mode: Crossed, tracks_occupancy: true }
place zt_bb_zone 220 200

// Place target inside and sync to register membership + apply condition
place zt_target 220 200
zone_sync
assert_condition zt_target, InsideBladeBarrier

// Process per-round damage: should deal 8d8
assert_eq zt_target.hp, 100
emit RoundEndDamage(combatant: zt_target)
assert_eq zt_target.hp < 100, true
