// ── Armed monster charge ─────────────────────────────────────

// resolve_armed_melee_attack with +2 charge bonus
// Ogre 4d8+1 HD → BTHB 5, +2 charge = +7 total. Target AC 14.
// Roll 10: 10+7=17 >= 14 → Hit; damage roll 7
spawn Monster mc_ogre { name: "Ogre", hit_dice: 4d8 + 1, max_hp: 26, hp: 26, ac: 15, attacks: [MonsterAttack { name: "Club", damage: 1d10 }], EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }
spawn Character mc_target { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

rolls clear
rolls 10 7
do Charge(mc_ogre, mc_target)
assert_eq mc_target.hp, 13
assert_condition mc_ogre, ChargeRecovery

// Monster charge miss: low roll doesn't hit
spawn Monster mc_rat { name: "Rat", hit_dice: 1d8 - 1, max_hp: 3, hp: 3, ac: 10, attacks: [MonsterAttack { name: "Bite", damage: 1d2 }], EquipmentSlots { wielded_main: some(Melee(Dagger)) } }
spawn Character mc_tough { name: "Warrior", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail }) } }

rolls clear
rolls 5
do Charge(mc_rat, mc_tough)
assert_eq mc_tough.hp, 30
assert_condition mc_rat, ChargeRecovery

// Monster charge against another monster
spawn Monster mc_hobgoblin { name: "Hobgoblin", hit_dice: 1d8 + 1, max_hp: 8, hp: 8, ac: 15, attacks: [MonsterAttack { name: "Sword", damage: 1d8 }], EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }
spawn Monster mc_goblin { name: "Goblin", hit_dice: 1d8 - 1, max_hp: 5, hp: 5, ac: 14, attacks: [MonsterAttack { name: "Sword", damage: 1d6 }] }

rolls clear
rolls 14 5
do Charge(mc_hobgoblin, mc_goblin)
assert_eq mc_goblin.hp, 0
assert_condition mc_goblin, Dead
assert_condition mc_hobgoblin, ChargeRecovery

// Monster charge blocked by ChargeRecovery cooldown
spawn Monster mc_cooldown { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Sword", damage: 1d6 }], EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }
spawn Character mc_cd_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

call apply_condition(mc_cooldown, ChargeRecovery, Duration.Rounds(10))
do Charge(mc_cooldown, mc_cd_tgt)
assert_eq mc_cd_tgt.hp, 10

// ── Natural-weapon monster charge (MonsterCharge) ───────────

// Bear charges with Claw natural attack, +2 charge bonus.
// Bear 5d8 HD → BTHB 5, +2 charge = +7 total. Target AC 14.
// Roll 10: 10+7=17 >= 14 → Hit; damage roll 6
spawn Monster nc_bear { name: "Bear", hit_dice: 5d8, max_hp: 30, hp: 30, ac: 14, attacks: [MonsterAttack { name: "Claw", damage: 1d8 }, MonsterAttack { name: "Bite", damage: 2d6 }] }
spawn Character nc_victim { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

rolls clear
rolls 10 6
do MonsterCharge(nc_bear, nc_victim, MonsterAttack { name: "Claw", damage: 1d8 })
assert_eq nc_victim.hp, 14
assert_condition nc_bear, ChargeRecovery

// Natural charge miss: low roll doesn't hit
spawn Monster nc_wolf { name: "Wolf", hit_dice: 2d8 + 2, max_hp: 12, hp: 12, ac: 13, attacks: [MonsterAttack { name: "Bite", damage: 1d4 + 1 }] }
spawn Character nc_tank { name: "Tank", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail }) } }

rolls clear
rolls 3
do MonsterCharge(nc_wolf, nc_tank, MonsterAttack { name: "Bite", damage: 1d4 + 1 })
assert_eq nc_tank.hp, 30
assert_condition nc_wolf, ChargeRecovery

// Natural charge blocked by ChargeRecovery cooldown
spawn Monster nc_cooldown { name: "Boar", hit_dice: 3d8, max_hp: 15, hp: 15, ac: 13, attacks: [MonsterAttack { name: "Tusk", damage: 3d4 }] }
spawn Character nc_cd_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

call apply_condition(nc_cooldown, ChargeRecovery, Duration.Rounds(10))
do MonsterCharge(nc_cooldown, nc_cd_tgt, MonsterAttack { name: "Tusk", damage: 3d4 })
assert_eq nc_cd_tgt.hp, 10

// Natural charge monster vs monster
spawn Monster nc_bull { name: "Bull", hit_dice: 4d8, max_hp: 20, hp: 20, ac: 13, attacks: [MonsterAttack { name: "Horn", damage: 1d6 }] }
spawn Monster nc_goblin_tgt { name: "Goblin", hit_dice: 1d8 - 1, max_hp: 4, hp: 4, ac: 14, attacks: [MonsterAttack { name: "Sword", damage: 1d6 }] }

rolls clear
rolls 12 5
do MonsterCharge(nc_bull, nc_goblin_tgt, MonsterAttack { name: "Horn", damage: 1d6 })
assert_eq nc_goblin_tgt.hp, 0
assert_condition nc_goblin_tgt, Dead
assert_condition nc_bull, ChargeRecovery

// ── Armed monster SetWeaponStrike ────────────────────────────

// Monster set weapon strike: double damage on hit
// Hobgoblin 1d8+1 HD → BTHB 2. Target AC 14.
// Roll 15: 15+2=17 >= 14 → Hit; damage 4, doubled = 8
spawn Monster ms_hobgoblin { name: "Hobgoblin", hit_dice: 1d8 + 1, max_hp: 8, hp: 8, ac: 15, attacks: [MonsterAttack { name: "Spear", damage: 1d6 }], EquipmentSlots { wielded_main: some(Melee(Spear)) } }
spawn Character ms_charger { name: "Charger", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

rolls clear
rolls 15 4
do SetWeaponStrike(ms_hobgoblin, ms_charger)
assert_eq ms_charger.hp, 12

// ── target_size ────────────────────────────────────────────────

spawn Character size_human { name: "Human", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, ancestry: Human, HitPoints { max_hp: 10, hp: 10 } }
spawn Monster size_ogre { name: "Ogre", hit_dice: 4d8 + 1, max_hp: 26, hp: 26, ac: 15, size: Size.Medium, attacks: [MonsterAttack { name: "Club", damage: 1d10 }] }

assert_eq target_size(size_human), Size.Medium
assert_eq target_size(size_ogre), Size.Medium

// ── Unarmed to-hit target number (Table 1.6.12a) ─────────────
// Ascending AC 10 (unarmoured) = target 2, each AC step adds 2.

assert_eq unarmed_target_number(10), 2
assert_eq unarmed_target_number(11), 4
assert_eq unarmed_target_number(12), 6
assert_eq unarmed_target_number(13), 8
assert_eq unarmed_target_number(14), 10
assert_eq unarmed_target_number(15), 12
assert_eq unarmed_target_number(16), 14
assert_eq unarmed_target_number(17), 16
assert_eq unarmed_target_number(18), 18
assert_eq unarmed_target_number(19), 20
assert_eq unarmed_target_number(20), 22
// Clamped at extremes
assert_eq unarmed_target_number(9), 2
assert_eq unarmed_target_number(25), 22

// ── Unarmed attacker DEX modifier ─────────────────────────────
// DEX 14 or lower: +0, DEX 15-18: +1, DEX 19+: +2

assert_eq unarmed_attacker_dex_mod(10), 0
assert_eq unarmed_attacker_dex_mod(14), 0
assert_eq unarmed_attacker_dex_mod(15), 1
assert_eq unarmed_attacker_dex_mod(18), 1
assert_eq unarmed_attacker_dex_mod(19), 2
assert_eq unarmed_attacker_dex_mod(22), 2

// ── Unarmed attacker movement rate modifier ───────────────────
// <30: +0, 30: +2, 60: +4, 90: +6, 120: +8, 150+: +10

assert_eq unarmed_attacker_move_mod(0), 0
assert_eq unarmed_attacker_move_mod(29), 0
assert_eq unarmed_attacker_move_mod(30), 2
assert_eq unarmed_attacker_move_mod(59), 2
assert_eq unarmed_attacker_move_mod(60), 4
assert_eq unarmed_attacker_move_mod(89), 4
assert_eq unarmed_attacker_move_mod(90), 6
assert_eq unarmed_attacker_move_mod(119), 6
assert_eq unarmed_attacker_move_mod(120), 8
assert_eq unarmed_attacker_move_mod(149), 8
assert_eq unarmed_attacker_move_mod(150), 10
assert_eq unarmed_attacker_move_mod(200), 10

// ── Unarmed defender armour modifier ──────────────────────────
// Ascending AC <=11: +0, 12-14: +2, 15-16: +4, 17-19: +5, 20+: +7

assert_eq unarmed_defender_armour_mod(10), 0
assert_eq unarmed_defender_armour_mod(11), 0
assert_eq unarmed_defender_armour_mod(12), 2
assert_eq unarmed_defender_armour_mod(14), 2
assert_eq unarmed_defender_armour_mod(15), 4
assert_eq unarmed_defender_armour_mod(16), 4
assert_eq unarmed_defender_armour_mod(17), 5
assert_eq unarmed_defender_armour_mod(19), 5
assert_eq unarmed_defender_armour_mod(20), 7
assert_eq unarmed_defender_armour_mod(25), 7

// ── Unarmed defender movement rate modifier ───────────────────
// <30: +0, 30: -2, 60: -4, 90: -6, 120: -8, 150+: -10

assert_eq unarmed_defender_move_mod(0), 0
assert_eq unarmed_defender_move_mod(29), 0
assert_eq unarmed_defender_move_mod(30), -2
assert_eq unarmed_defender_move_mod(59), -2
assert_eq unarmed_defender_move_mod(60), -4
assert_eq unarmed_defender_move_mod(90), -6
assert_eq unarmed_defender_move_mod(120), -8
assert_eq unarmed_defender_move_mod(150), -10

// ── Unarmed attacker/defender armor AC derives ────────────────

// Unarmoured character → ascending AC 10
spawn Character ua_unarmoured { name: "Brawler", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
assert_eq unarmed_attacker_armor_ac(ua_unarmoured), 10
assert_eq unarmed_defender_armor_ac(ua_unarmoured), 10

// Armoured character → armour type AC
spawn Character ua_armoured { name: "Knight", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail }) } }
assert_eq unarmed_attacker_armor_ac(ua_armoured), 17
assert_eq unarmed_defender_armor_ac(ua_armoured), 17

// Monster uses stat-block AC
spawn Monster ua_orc { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }
assert_eq unarmed_attacker_armor_ac(ua_orc), 14
assert_eq unarmed_defender_armor_ac(ua_orc), 14

// ── Combined unarmed attacker mod ─────────────────────────────

// Character with DEX 16 (+1), movement 120 (+8) → total +9
spawn Character ua_fast { name: "Fast", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 16, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
assert_eq unarmed_attacker_mod(ua_fast, 120), 9

// Character with DEX 12 (+0), movement 60 (+4) → total +4
assert_eq unarmed_attacker_mod(ua_unarmoured, 60), 4

// Monster gets no DEX bonus, movement 90 → +6
assert_eq unarmed_attacker_mod(ua_orc, 90), 6

// ── Combined unarmed defender mod ─────────────────────────────

// Unarmoured (AC 10, mod +0) + movement 120 (-8) → -8
assert_eq unarmed_defender_mod(ua_unarmoured, 120), -8

// Plate mail (AC 17, mod +5) + movement 60 (-4) → +1
assert_eq unarmed_defender_mod(ua_armoured, 60), 1

// Orc (AC 14, mod +2) + movement 90 (-6) → -4
assert_eq unarmed_defender_mod(ua_orc, 90), -4

// ── resolve_unarmed_to_hit mechanic ───────────────────────────

// Unarmoured attacker (AC 10 → target 2), DEX 16 (+1), move 120 (+8).
// Defender unarmoured (AC 10 → armour mod +0), move 60 (-4).
// Effective target: 2 + (+0 + -4) = -2.
// Attacker mod: +1 + +8 = +9.
// Roll 5: 5 + 9 = 14 >= -2 → Hit
rolls clear
rolls 5
let ua_hit = resolve_unarmed_to_hit(ua_fast, ua_unarmoured, 120, 60)
assert_eq ua_hit.outcome, AttackOutcome.Hit
assert_eq ua_hit.target_number, 2
assert_eq ua_hit.attacker_mod, 9
assert_eq ua_hit.defender_mod, -4
assert_eq ua_hit.effective_target, -2

// Roll of 1 always misses, even with huge bonuses
rolls clear
rolls 1
let ua_nat1 = resolve_unarmed_to_hit(ua_fast, ua_unarmoured, 120, 60)
assert_eq ua_nat1.outcome, AttackOutcome.Miss

// Hard target: plate mail defender (AC 17 → armour mod +5), move 0 (+0).
// Attacker unarmoured (target 2), DEX 12, move 30 (+2).
// Effective target: 2 + 5 = 7. Attacker mod: +0 + +2 = +2.
// Roll 4: 4 + 2 = 6 < 7 → Miss
rolls clear
rolls 4
let ua_miss = resolve_unarmed_to_hit(ua_unarmoured, ua_armoured, 30, 0)
assert_eq ua_miss.outcome, AttackOutcome.Miss
assert_eq ua_miss.target_number, 2
assert_eq ua_miss.attacker_mod, 2
assert_eq ua_miss.defender_mod, 5
assert_eq ua_miss.effective_target, 7

// Same scenario, roll 5: 5 + 2 = 7 >= 7 → Hit
rolls clear
rolls 5
let ua_just_hit = resolve_unarmed_to_hit(ua_unarmoured, ua_armoured, 30, 0)
assert_eq ua_just_hit.outcome, AttackOutcome.Hit

// With extra attack_mod (e.g. from condition like prone +4)
// Roll 3 + atk_mod(2) + attack_mod(4) = 9 >= 7 → Hit
rolls clear
rolls 3
let ua_cond = resolve_unarmed_to_hit(ua_unarmoured, ua_armoured, 30, 0, 4)
assert_eq ua_cond.outcome, AttackOutcome.Hit
assert_eq ua_cond.attacker_mod, 6

// ── Brawling via MeleeAttack fallback (§1.6.12, PG p105) ─────
// Unarmed characters fall back to FistOrKick (1d2 Blunt, normal damage).

// Unarmed Fighter level 5 (BTHB +4), STR 12, vs unarmoured target (AC 10).
// Roll 15: 15 + 4 = 19 >= 10 → Hit. Damage roll 1 → 1.
spawn Character brawl_atk { name: "Brawler", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character brawl_tgt { name: "BrawlTarget", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
rolls 15 1
do MeleeAttack(brawl_atk, brawl_tgt)
assert_eq brawl_tgt.hp, 9
assert_eq brawl_tgt.temp_damage, 0

// Unarmed miss does no damage.
rolls clear
rolls 2
do MeleeAttack(brawl_atk, brawl_tgt)
assert_eq brawl_tgt.hp, 9

// ── Overbearing results table (Table 1.6.12b) ─────────────────

// ── Overbearing attacker strength modifiers ─────────────────
// Character STR < 16 → 0, STR 16-18 → +1, STR 18 w/exceptional → +2.
spawn Character ob_str12 { name: "OBStr12", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character ob_str16 { name: "OBStr16", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 16, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character ob_str17 { name: "OBStr17", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 17, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character ob_str18 { name: "OBStr18", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 18, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character ob_str18exc { name: "OBStr18Exc", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 18, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 }, ExceptionalStrength { percentile: 50 } }

assert_eq overbearing_attacker_str_mod(ob_str12), 0
assert_eq overbearing_attacker_str_mod(ob_str16), 1
assert_eq overbearing_attacker_str_mod(ob_str17), 1
assert_eq overbearing_attacker_str_mod(ob_str18), 1
assert_eq overbearing_attacker_str_mod(ob_str18exc), 2

// Monster HD: <4 → 0, 4-8 → +1, 9+ → +2.
spawn Monster ob_mon2hd { name: "Goblin", hit_dice: 2d8, max_hp: 10, hp: 10, ac: 10, size: Size.Small, attacks: [MonsterAttack { name: "Fist", damage: 1d4 }] }
spawn Monster ob_mon5hd { name: "Ogre", hit_dice: 5d8, max_hp: 30, hp: 30, ac: 10, size: Size.Large, attacks: [MonsterAttack { name: "Fist", damage: 1d6 }] }
spawn Monster ob_mon10hd { name: "Giant", hit_dice: 10d8, max_hp: 60, hp: 60, ac: 10, size: Size.Huge, attacks: [MonsterAttack { name: "Fist", damage: 2d6 }] }

assert_eq overbearing_attacker_str_mod(ob_mon2hd), 0
assert_eq overbearing_attacker_str_mod(ob_mon5hd), 1
assert_eq overbearing_attacker_str_mod(ob_mon10hd), 2

// ── Overbearing defender strength modifiers ─────────────────
// Inverse of attacker: STR < 16 → 0, STR 16-18 → -1, exc → -2.
assert_eq overbearing_defender_str_mod(ob_str12), 0
assert_eq overbearing_defender_str_mod(ob_str16), -1
assert_eq overbearing_defender_str_mod(ob_str17), -1
assert_eq overbearing_defender_str_mod(ob_str18), -1
assert_eq overbearing_defender_str_mod(ob_str18exc), -2

// Monster HD: <4 → 0, 4-8 → -1, 9+ → -2.
assert_eq overbearing_defender_str_mod(ob_mon2hd), 0
assert_eq overbearing_defender_str_mod(ob_mon5hd), -1
assert_eq overbearing_defender_str_mod(ob_mon10hd), -2

// ── Overbearing size modifiers ──────────────────────────────
// Attacker: Tiny -4, Small -2, Medium +0, Large +2, Huge +6, Gargantuan +10
assert_eq overbearing_attacker_size_mod(Size.Tiny), -4
assert_eq overbearing_attacker_size_mod(Size.Small), -2
assert_eq overbearing_attacker_size_mod(Size.Medium), 0
assert_eq overbearing_attacker_size_mod(Size.Large), 2
assert_eq overbearing_attacker_size_mod(Size.Huge), 6
assert_eq overbearing_attacker_size_mod(Size.Gargantuan), 10

// Defender: inverse of attacker
assert_eq overbearing_defender_size_mod(Size.Tiny), 4
assert_eq overbearing_defender_size_mod(Size.Small), 2
assert_eq overbearing_defender_size_mod(Size.Medium), 0
assert_eq overbearing_defender_size_mod(Size.Large), -2
assert_eq overbearing_defender_size_mod(Size.Huge), -6
assert_eq overbearing_defender_size_mod(Size.Gargantuan), -10

// ── Overbearing four-legs modifier ──────────────────────────
assert_eq overbearing_attacker_four_legs_mod(false), 0
assert_eq overbearing_attacker_four_legs_mod(true), 2

// ── Overbearing tier by modified roll ───────────────────────
assert_eq overbearing_tier(0), OverbearingTier.TotalFailure
assert_eq overbearing_tier(1), OverbearingTier.TotalFailure
assert_eq overbearing_tier(2), OverbearingTier.PartialFailure
assert_eq overbearing_tier(3), OverbearingTier.PartialSuccess
assert_eq overbearing_tier(4), OverbearingTier.PartialSuccess
assert_eq overbearing_tier(5), OverbearingTier.Success
assert_eq overbearing_tier(6), OverbearingTier.Success
assert_eq overbearing_tier(7), OverbearingTier.TotalSuccess
assert_eq overbearing_tier(10), OverbearingTier.TotalSuccess

// ── Overbearing damage by modified roll ─────────────────────
// No damage for TotalFailure (≤1), PartialFailure (2), PartialSuccess (3-4).
assert_eq overbearing_temp_damage(0), 0
assert_eq overbearing_temp_damage(1), 0
assert_eq overbearing_temp_damage(2), 0
assert_eq overbearing_temp_damage(3), 0
assert_eq overbearing_temp_damage(4), 0

// Success (5-6): damage = roll, 1 real, rest temp.
// Modified 5 → 4 temp, 1 real. Modified 6 → 5 temp, 1 real.
assert_eq overbearing_temp_damage(5), 4
assert_eq overbearing_real_damage(5), 1
assert_eq overbearing_temp_damage(6), 5
assert_eq overbearing_real_damage(6), 1

// Total Success (7+): damage = roll, 2 real, rest temp.
// Modified 7 → 5 temp, 2 real. Modified 10 → 8 temp, 2 real.
assert_eq overbearing_temp_damage(7), 5
assert_eq overbearing_real_damage(7), 2
assert_eq overbearing_temp_damage(10), 8
assert_eq overbearing_real_damage(10), 2

// No damage for low tiers
assert_eq overbearing_real_damage(0), 0
assert_eq overbearing_real_damage(1), 0
assert_eq overbearing_real_damage(2), 0
assert_eq overbearing_real_damage(3), 0
assert_eq overbearing_real_damage(4), 0

// ── Overbearing grappling follow-up bonus ───────────────────
assert_eq overbearing_grappling_bonus(1), 0
assert_eq overbearing_grappling_bonus(5), 0
assert_eq overbearing_grappling_bonus(6), 0
assert_eq overbearing_grappling_bonus(7), 2
assert_eq overbearing_grappling_bonus(10), 2

// ── resolve_overbearing_attack mechanic ─────────────────────
// Both combatants Medium, STR 12. All mods = 0.

// Miss on unarmed to-hit → OverbearingResult with Miss outcome.
// Unarmoured attacker (target 2), DEX 12 (+0), move 60 (+4).
// Plate defender (AC 17 → armour +5), move 0 (+0). Effective target: 7.
// Roll 2: 2 + 4 = 6 < 7 → Miss.
rolls clear
rolls 2
let ob_miss = resolve_overbearing_attack(ua_unarmoured, ua_armoured, 60, 0)
assert_eq ob_miss.outcome, AttackOutcome.Miss
assert_eq ob_miss.roll, 0
assert_eq ob_miss.temp_damage, 0
assert_eq ob_miss.real_damage, 0

// Hit → rolls 1d6 for overbearing result.
// Unarmoured attacker vs unarmoured defender, both move 120.
// Roll 10 (to-hit hit), roll 1 (d6): modified 1 → TotalFailure.
rolls clear
rolls 10 1
let ob_tf = resolve_overbearing_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq ob_tf.outcome, AttackOutcome.Hit
assert_eq ob_tf.tier, OverbearingTier.TotalFailure
assert_eq ob_tf.roll, 1
assert_eq ob_tf.modified_roll, 1
assert_eq ob_tf.temp_damage, 0
assert_eq ob_tf.real_damage, 0
assert_eq ob_tf.grappling_followup_bonus, 0

// Roll 2 → PartialFailure.
rolls clear
rolls 10 2
let ob_pf = resolve_overbearing_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq ob_pf.tier, OverbearingTier.PartialFailure
assert_eq ob_pf.temp_damage, 0
assert_eq ob_pf.real_damage, 0

// Roll 3 → PartialSuccess.
rolls clear
rolls 10 3
let ob_ps = resolve_overbearing_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq ob_ps.tier, OverbearingTier.PartialSuccess
assert_eq ob_ps.temp_damage, 0
assert_eq ob_ps.real_damage, 0

// Roll 5 → Success. Damage = 5 (4 temp, 1 real).
rolls clear
rolls 10 5
let ob_suc = resolve_overbearing_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq ob_suc.tier, OverbearingTier.Success
assert_eq ob_suc.roll, 5
assert_eq ob_suc.modified_roll, 5
assert_eq ob_suc.temp_damage, 4
assert_eq ob_suc.real_damage, 1
assert_eq ob_suc.grappling_followup_bonus, 0

// Roll 6 → Success. Damage = 6 (5 temp, 1 real).
rolls clear
rolls 10 6
let ob_suc6 = resolve_overbearing_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq ob_suc6.tier, OverbearingTier.Success
assert_eq ob_suc6.temp_damage, 5
assert_eq ob_suc6.real_damage, 1

// ── Size modifiers in overbearing mechanic ──────────────────
// Large attacker (+2) vs Small defender (+2) → total size +4.
// Both have STR mod 0 (monster 2HD and 5HD).
// Roll 10 (to-hit), roll 2 (d6): modified = 2 + 0 + 4 = 6 → Success.
rolls clear
rolls 10 2
let ob_size = resolve_overbearing_attack(ob_mon5hd, ob_mon2hd, 90, 60)
assert_eq ob_size.roll, 2
// STR: 5HD atk +1, 2HD def +0 = +1. Size: Large +2, Small +2 = +4. Total +5.
assert_eq ob_size.modified_roll, 7
assert_eq ob_size.tier, OverbearingTier.TotalSuccess
assert_eq ob_size.grappling_followup_bonus, 2

// ── Defender four legs: cannot be overborne ─────────────────
rolls clear
rolls 10 6
let ob_4legs = resolve_overbearing_attack(ua_unarmoured, ua_unarmoured, 120, 120, false, true)
assert_eq ob_4legs.outcome, AttackOutcome.Miss
assert_eq ob_4legs.roll, 0

// ── Attacker four legs: +2 bonus ────────────────────────────
// Roll 10 (to-hit), roll 5 (d6). Medium vs Medium, no STR mods.
// Modified = 5 + 0 + 0 + 2 = 7 → TotalSuccess.
rolls clear
rolls 10 5
let ob_4atk = resolve_overbearing_attack(ua_unarmoured, ua_unarmoured, 120, 120, true, false)
assert_eq ob_4atk.modified_roll, 7
assert_eq ob_4atk.tier, OverbearingTier.TotalSuccess
assert_eq ob_4atk.grappling_followup_bonus, 2

// ── STR modifiers in overbearing mechanic ───────────────────
// STR 18 exc attacker (+2) vs STR 16 defender (-1) → total +1.
// Roll 10 (to-hit), roll 4 (d6): modified = 4 + 1 = 5 → Success.
rolls clear
rolls 10 4
let ob_str = resolve_overbearing_attack(ob_str18exc, ob_str16, 120, 120)
assert_eq ob_str.roll, 4
assert_eq ob_str.modified_roll, 5
assert_eq ob_str.tier, OverbearingTier.Success
assert_eq ob_str.temp_damage, 4
assert_eq ob_str.real_damage, 1

// ── OverbearingAttack action (applies damage) ───────────────
spawn Character ob_atk { name: "Overbearer", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }
spawn Character ob_tgt { name: "OBTarget", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

// Hit: roll 10 (to-hit), roll 5 (d6) → Success. 4 temp, 1 real.
rolls clear
rolls 10 5
do OverbearingAttack(ob_atk, ob_tgt, 120, 120)
assert_eq ob_tgt.temp_damage, 4
assert_eq ob_tgt.hp, 19

// Miss: roll 1 (natural 1 always misses). No damage.
rolls clear
rolls 1
do OverbearingAttack(ob_atk, ob_tgt, 120, 120)
assert_eq ob_tgt.temp_damage, 4
assert_eq ob_tgt.hp, 19

// ── Grappling results table (Table 1.6.12c) ──────────────────

// ── Grappling size modifiers ──────────────────────────────────
// Attacker: Tiny -4, Small -2, Medium +0, Large +2, Huge +6, Gargantuan +10
assert_eq grappling_attacker_size_mod(Size.Tiny), -4
assert_eq grappling_attacker_size_mod(Size.Small), -2
assert_eq grappling_attacker_size_mod(Size.Medium), 0
assert_eq grappling_attacker_size_mod(Size.Large), 2
assert_eq grappling_attacker_size_mod(Size.Huge), 6
assert_eq grappling_attacker_size_mod(Size.Gargantuan), 10

// Defender: inverse of attacker
assert_eq grappling_defender_size_mod(Size.Tiny), 4
assert_eq grappling_defender_size_mod(Size.Small), 2
assert_eq grappling_defender_size_mod(Size.Medium), 0
assert_eq grappling_defender_size_mod(Size.Large), -2
assert_eq grappling_defender_size_mod(Size.Huge), -6
assert_eq grappling_defender_size_mod(Size.Gargantuan), -10

// ── Grappling appendage modifiers ─────────────────────────────
// Attacker: 1 arm → -1, 2 arms → 0, 3+ → +1
assert_eq grappling_attacker_appendage_mod(1), -1
assert_eq grappling_attacker_appendage_mod(2), 0
assert_eq grappling_attacker_appendage_mod(3), 1
assert_eq grappling_attacker_appendage_mod(4), 1

// Defender: 1 arm → +1, 2 arms → 0, 3+ → -1
assert_eq grappling_defender_appendage_mod(1), 1
assert_eq grappling_defender_appendage_mod(2), 0
assert_eq grappling_defender_appendage_mod(3), -1

// ── Grappling damage by modified roll ─────────────────────────
// Temp damage: 1→1, 2→1, 3→2, 4→3, 5→4, 6→4, 7→5, 8→6, 9+→6
assert_eq grappling_temp_damage(0), 1
assert_eq grappling_temp_damage(1), 1
assert_eq grappling_temp_damage(2), 1
assert_eq grappling_temp_damage(3), 2
assert_eq grappling_temp_damage(4), 3
assert_eq grappling_temp_damage(5), 4
assert_eq grappling_temp_damage(6), 4
assert_eq grappling_temp_damage(7), 5
assert_eq grappling_temp_damage(8), 6
assert_eq grappling_temp_damage(9), 6
assert_eq grappling_temp_damage(12), 6

// Real damage: 1→0, 2-5→1, 6-8→2, 9+→3
assert_eq grappling_real_damage(0), 0
assert_eq grappling_real_damage(1), 0
assert_eq grappling_real_damage(2), 1
assert_eq grappling_real_damage(4), 1
assert_eq grappling_real_damage(5), 1
assert_eq grappling_real_damage(6), 2
assert_eq grappling_real_damage(7), 2
assert_eq grappling_real_damage(8), 2
assert_eq grappling_real_damage(9), 3
assert_eq grappling_real_damage(12), 3

// ── Grappling hold types by modified roll ─────────────────────
// Controlling: 1→None, 2-4→ArmGrab, 5→WaistLock, 6→RearChoke,
//   7→ArmLock, 8→HeadLock, 9+→DecisiveThrow
assert_eq grappling_controlling_hold(1), GrapplingHold.None
assert_eq grappling_controlling_hold(2), GrapplingHold.ArmGrab
assert_eq grappling_controlling_hold(4), GrapplingHold.ArmGrab
assert_eq grappling_controlling_hold(5), GrapplingHold.WaistLock
assert_eq grappling_controlling_hold(6), GrapplingHold.RearChoke
assert_eq grappling_controlling_hold(7), GrapplingHold.ArmLock
assert_eq grappling_controlling_hold(8), GrapplingHold.HeadLock
assert_eq grappling_controlling_hold(9), GrapplingHold.DecisiveThrow
assert_eq grappling_controlling_hold(12), GrapplingHold.DecisiveThrow

// Inferior: 1→None, 2-4→ElbowBash, 5→LegHold, 6→HeadButt,
//   7→WickedElbowBash, 8→Gouge, 9+→DecisiveThrow
assert_eq grappling_inferior_hold(1), GrapplingHold.None
assert_eq grappling_inferior_hold(2), GrapplingHold.ElbowBash
assert_eq grappling_inferior_hold(4), GrapplingHold.ElbowBash
assert_eq grappling_inferior_hold(5), GrapplingHold.LegHold
assert_eq grappling_inferior_hold(6), GrapplingHold.HeadButt
assert_eq grappling_inferior_hold(7), GrapplingHold.WickedElbowBash
assert_eq grappling_inferior_hold(8), GrapplingHold.Gouge
assert_eq grappling_inferior_hold(9), GrapplingHold.DecisiveThrow

// ── resolve_grappling_attack mechanic ─────────────────────────
// Both combatants Medium, 2 appendages each → size/appendage mods = 0.

// Miss on unarmed to-hit → GrapplingResult with Miss outcome.
// Unarmoured attacker (target 2), DEX 12 (+0), move 60 (+4).
// Plate defender (AC 17 → armour +5), move 0 (+0). Effective target: 7.
// Roll 2: 2 + 4 = 6 < 7 → Miss.
rolls clear
rolls 2
let grap_miss = resolve_grappling_attack(ua_unarmoured, ua_armoured, 60, 0)
assert_eq grap_miss.outcome, AttackOutcome.Miss
assert_eq grap_miss.roll, 0
assert_eq grap_miss.temp_damage, 0
assert_eq grap_miss.real_damage, 0
assert_eq grap_miss.hold, GrapplingHold.None

// Hit → rolls 1d8 for grappling result.
// Unarmoured attacker vs unarmoured defender, both move 120.
// To-hit: target 2, atk_mod +8, def_mod -8. Effective: -6.
// Roll 10 (to-hit): 10 + 8 = 18 >= -6 → Hit.
// Roll 3 (1d8): modified 3. Temp 2, real 1. ArmGrab (controlling).
rolls clear
rolls 10 3
let grap_arm = resolve_grappling_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq grap_arm.outcome, AttackOutcome.Hit
assert_eq grap_arm.roll, 3
assert_eq grap_arm.modified_roll, 3
assert_eq grap_arm.temp_damage, 2
assert_eq grap_arm.real_damage, 1
assert_eq grap_arm.hold, GrapplingHold.ArmGrab
assert_eq grap_arm.is_controlling, true

// Inferior hold: same rolls but is_controlling=false → ElbowBash.
rolls clear
rolls 10 3
let grap_inf = resolve_grappling_attack(ua_unarmoured, ua_unarmoured, 120, 120, 2, 2, 0, false)
assert_eq grap_inf.hold, GrapplingHold.ElbowBash
assert_eq grap_inf.is_controlling, false

// Roll 1 on d8 → Awkward Scuffling (1 temp, 0 real, no hold).
rolls clear
rolls 10 1
let grap_scuffle = resolve_grappling_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq grap_scuffle.modified_roll, 1
assert_eq grap_scuffle.temp_damage, 1
assert_eq grap_scuffle.real_damage, 0
assert_eq grap_scuffle.hold, GrapplingHold.None

// Roll 5 → Waist Lock (4 temp, 1 real).
rolls clear
rolls 10 5
let grap_waist = resolve_grappling_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq grap_waist.modified_roll, 5
assert_eq grap_waist.temp_damage, 4
assert_eq grap_waist.real_damage, 1
assert_eq grap_waist.hold, GrapplingHold.WaistLock

// Roll 6 → Rear Choke (4 temp, 2 real).
rolls clear
rolls 10 6
let grap_choke = resolve_grappling_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq grap_choke.modified_roll, 6
assert_eq grap_choke.temp_damage, 4
assert_eq grap_choke.real_damage, 2
assert_eq grap_choke.hold, GrapplingHold.RearChoke

// Roll 7 → Arm Lock (5 temp, 2 real).
rolls clear
rolls 10 7
let grap_armlock = resolve_grappling_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq grap_armlock.modified_roll, 7
assert_eq grap_armlock.temp_damage, 5
assert_eq grap_armlock.real_damage, 2
assert_eq grap_armlock.hold, GrapplingHold.ArmLock

// Roll 8 → Head Lock (6 temp, 2 real).
rolls clear
rolls 10 8
let grap_headlock = resolve_grappling_attack(ua_unarmoured, ua_unarmoured, 120, 120)
assert_eq grap_headlock.modified_roll, 8
assert_eq grap_headlock.temp_damage, 6
assert_eq grap_headlock.real_damage, 2
assert_eq grap_headlock.hold, GrapplingHold.HeadLock

// ── Size modifiers in grappling mechanic ──────────────────────
// Large attacker (+2) vs Small defender (+2) → total +4 on d8.
// Roll 10 (to-hit), roll 3 (d8): modified = 3 + 2 + 2 = 7 → ArmLock.
spawn Monster grap_large { name: "Ogre", hit_dice: 4d8 + 1, max_hp: 26, hp: 26, ac: 10, size: Size.Large, attacks: [MonsterAttack { name: "Fist", damage: 1d4 }] }
spawn Monster grap_small { name: "Goblin", hit_dice: 1d8 - 1, max_hp: 4, hp: 4, ac: 10, size: Size.Small, attacks: [MonsterAttack { name: "Fist", damage: 1d4 }] }

rolls clear
rolls 10 3
let grap_size = resolve_grappling_attack(grap_large, grap_small, 90, 60)
assert_eq grap_size.roll, 3
assert_eq grap_size.modified_roll, 7
assert_eq grap_size.hold, GrapplingHold.ArmLock
assert_eq grap_size.temp_damage, 5
assert_eq grap_size.real_damage, 2

// ── Appendage modifiers in grappling mechanic ─────────────────
// Attacker with 1 arm (-1) vs defender with 3 arms (-1) → total -2.
// Roll 10 (to-hit), roll 5 (d8): modified = 5 - 1 + (-1) = 3 → ArmGrab.
rolls clear
rolls 10 5
let grap_app = resolve_grappling_attack(ua_unarmoured, ua_unarmoured, 120, 120, 1, 3)
assert_eq grap_app.roll, 5
assert_eq grap_app.modified_roll, 3
assert_eq grap_app.hold, GrapplingHold.ArmGrab
assert_eq grap_app.temp_damage, 2
assert_eq grap_app.real_damage, 1

// ── Decisive Throw (modified 9+) ─────────────────────────────
// Roll 10 (to-hit), roll 8 (d8), Large attacker (+2) vs Medium (+0).
// Modified = 8 + 2 = 10. Capped for table but 9+ = DecisiveThrow.
// Damage: 6 temp, 3 real.
rolls clear
rolls 10 8
let grap_throw = resolve_grappling_attack(grap_large, ua_unarmoured, 90, 120)
assert_eq grap_throw.modified_roll, 10
assert_eq grap_throw.hold, GrapplingHold.DecisiveThrow
assert_eq grap_throw.temp_damage, 6
assert_eq grap_throw.real_damage, 3

// ── GrapplingAttack action (applies damage) ──────────────────
spawn Character grap_atk { name: "Grappler", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }
spawn Character grap_tgt { name: "GrapTarget", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

// Hit: roll 10 (to-hit), roll 5 (d8) → Waist Lock. 4 temp, 1 real.
// Both sides get Grappling condition: attacker (WaistLock, controlling),
// target (LegHold, inferior).
rolls clear
rolls 10 5
do GrapplingAttack(grap_atk, grap_tgt, 120, 120)
assert_eq grap_tgt.temp_damage, 4
assert_eq grap_tgt.hp, 19
assert_condition grap_atk, Grappling
assert_condition grap_tgt, Grappling

// Miss: roll 1 (natural 1 always misses). No damage.
// Existing Grappling conditions remain (miss doesn't change state).
rolls clear
rolls 1
do GrapplingAttack(grap_atk, grap_tgt, 120, 120)
assert_eq grap_tgt.temp_damage, 4
assert_eq grap_tgt.hp, 19
assert_condition grap_atk, Grappling
assert_condition grap_tgt, Grappling

// ── MaintainGrapplingHold action ─────────────────────────────
// Maintaining a hold re-inflicts the same damage as the initial hold.
// Hold roll 5 → 4 temp, 1 real (same as WaistLock above).
// Prior state: grap_tgt has 4 temp, hp 19.
do MaintainGrapplingHold(grap_atk, grap_tgt, GrapplingHold.WaistLock, 5)
assert_eq grap_tgt.temp_damage, 8
assert_eq grap_tgt.hp, 18
assert_condition grap_atk, Grappling
assert_condition grap_tgt, Grappling

// ── DisengageGrapple action ──────────────────────────────────
// Voluntary disengage removes Grappling from both sides.
do DisengageGrapple(grap_atk, grap_tgt)
assert_no_condition grap_atk, Grappling
assert_no_condition grap_tgt, Grappling

// ── GrapplingAttack hold replacement ─────────────────────────
// New grappling attack replaces old holds. Re-establish grapple,
// then attack again with a different result.
// First attack: roll 10 (to-hit), roll 3 (d8) → ArmGrab. 2 temp, 1 real.
spawn Character grap_atk2 { name: "Grappler2", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }
spawn Character grap_tgt2 { name: "GrapTarget2", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

rolls clear
rolls 10 3
do GrapplingAttack(grap_atk2, grap_tgt2, 120, 120)
assert_condition grap_atk2, Grappling
assert_condition grap_tgt2, Grappling
assert_eq grap_tgt2.temp_damage, 2
assert_eq grap_tgt2.hp, 19

// Second attack: roll 10 (to-hit), roll 8 (d8) → HeadLock.
// Old holds removed, new holds applied. 6 temp, 2 real.
rolls clear
rolls 10 8
do GrapplingAttack(grap_atk2, grap_tgt2, 120, 120)
assert_condition grap_atk2, Grappling
assert_condition grap_tgt2, Grappling
assert_eq grap_tgt2.temp_damage, 8
assert_eq grap_tgt2.hp, 17


// ── Grappling suppresses spellcasting ────────────────────────
// Grappling condition modifies can_begin_casting via #spellcasting_gate
// to return false, preventing CastSpell from proceeding.

// can_begin_casting returns true for ungrappled entity.
spawn Character grap_caster { name: "GrapCaster", classes: [ClassLevel { class: Cleric, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, Spellcasting { spell_slots: [2], slots_used: [0], memorised_spells: [] } }
spawn Character grap_foe { name: "GrapFoe", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

assert_eq can_begin_casting(grap_caster), true

// Memorise a spell, apply Grappling, then try to cast.
do MemoriseSpell(grap_caster, CureLightWounds, 1)
assert_eq grap_caster.Spellcasting.memorised_spells.len(), 1

// Apply Grappling condition (simulating being grappled).
rolls clear
rolls 10 5
do GrapplingAttack(grap_foe, grap_caster, 120, 120)
assert_condition grap_caster, Grappling

// can_begin_casting now returns false.
assert_eq can_begin_casting(grap_caster), false

// CastSpell does nothing: spell not consumed, no CastingSpell applied.
do CastSpell(grap_caster, CureLightWounds, 1, 5)
assert_eq grap_caster.Spellcasting.memorised_spells.len(), 1
assert_no_condition grap_caster, CastingSpell

// After disengaging, casting works again.
do DisengageGrapple(grap_foe, grap_caster)
assert_no_condition grap_caster, Grappling
assert_eq can_begin_casting(grap_caster), true

do CastSpell(grap_caster, CureLightWounds, 1, 5)
assert_eq grap_caster.Spellcasting.memorised_spells.len(), 0
assert_condition grap_caster, CastingSpell


// ── Fend-off mechanic (§1.6.12, First Step) ──────────────────

// is_armed_melee: armed character returns true
spawn Character fo_armed { name: "ArmedDef", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 16, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }
assert_eq is_armed_melee(fo_armed), true

// is_armed_melee: unarmed character returns false
spawn Character fo_unarmed_check { name: "UnarmedChk", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
assert_eq is_armed_melee(fo_unarmed_check), false

// Fend-off success: armed defender rolls high vs unarmoured attacker.
// Fighter level 5 → BTHB 4, STR 16 → +0 to-hit, Long Sword.
// Target (unarmed attacker) is unarmoured → effective AC 10.
// Roll 15: 15 + 4 = 19 >= 10 → Hit → FendedOff.
spawn Character fo_attacker { name: "UnarmedAtk", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 16, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
rolls 15
let fo_hit = resolve_fend_off_attempt(fo_armed, fo_attacker)
assert_eq fo_hit.outcome, FendOffOutcome.FendedOff

// Fend-off failure: armed defender rolls low.
// Roll 2: 2 + 4 = 6 < 10 → Miss → Failed.
rolls clear
rolls 2
let fo_miss = resolve_fend_off_attempt(fo_armed, fo_attacker)
assert_eq fo_miss.outcome, FendOffOutcome.Failed

// Natural 1 always misses, even with high BTHB.
rolls clear
rolls 1
let fo_nat1 = resolve_fend_off_attempt(fo_armed, fo_attacker)
assert_eq fo_nat1.outcome, FendOffOutcome.Failed

// Fend-off by unarmed entity always fails (no weapon).
spawn Character fo_unarmed_def { name: "UnarmedDef", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 16, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }

rolls clear
rolls 20
let fo_no_weapon = resolve_fend_off_attempt(fo_unarmed_def, fo_attacker)
assert_eq fo_no_weapon.outcome, FendOffOutcome.Failed

// Fend-off vs armoured attacker: higher AC makes it harder.
// Attacker in plate mail → effective AC 17. BTHB 4.
// Roll 10: 10 + 4 = 14 < 17 → Miss → Failed.
spawn Character fo_armoured_atk { name: "ArmouredAtk", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail }) } }

rolls clear
rolls 10
let fo_vs_armoured = resolve_fend_off_attempt(fo_armed, fo_armoured_atk)
assert_eq fo_vs_armoured.outcome, FendOffOutcome.Failed

// Same scenario but high roll succeeds.
// Roll 18: 18 + 4 = 22 >= 17 → Hit → FendedOff.
rolls clear
rolls 18
let fo_vs_armoured_hit = resolve_fend_off_attempt(fo_armed, fo_armoured_atk)
assert_eq fo_vs_armoured_hit.outcome, FendOffOutcome.FendedOff

// Fend-off does NOT deal damage (no HP change on attacker).
assert_eq fo_attacker.hp, 10
assert_eq fo_armoured_atk.hp, 10

// Armed monster fend-off: Hobgoblin with sword.
// 1d8+1 HD → BTHB 2. Target unarmoured AC 10.
// Roll 12: 12 + 2 = 14 >= 10 → FendedOff.
spawn Monster fo_hobgoblin { name: "Hobgoblin", hit_dice: 1d8 + 1, max_hp: 8, hp: 8, ac: 15, attacks: [MonsterAttack { name: "Sword", damage: 1d8 }], EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }

rolls clear
rolls 12
let fo_monster = resolve_fend_off_attempt(fo_hobgoblin, fo_attacker)
assert_eq fo_monster.outcome, FendOffOutcome.FendedOff

// Unarmed monster cannot fend off.
spawn Monster fo_unarmed_mon { name: "Rat", hit_dice: 0d8, max_hp: 1, hp: 1, ac: 10, attacks: [MonsterAttack { name: "Bite", damage: 1d2 }] }

rolls clear
rolls 20
let fo_unarmed_monster = resolve_fend_off_attempt(fo_unarmed_mon, fo_attacker)
assert_eq fo_unarmed_monster.outcome, FendOffOutcome.Failed
