// OSRIC Conditions integration tests
//
// Equivalent of crates/ttrpg_interp/tests/osric_conditions_integration.rs
// Tests condition modifiers on attack resolution, DEX/shield AC negation,
// attacker suppression, parameterised conditions, stacking, removal,
// cross-entity-type application, and auto-hit/max-damage mechanics.

load osric/*.ttrpg

// ── Baseline: no conditions ─────────────────────────────────────
// Fighter level 5 (BTHB=4), STR 12, SwordLong vs target AC 14.
// Roll 15 → 15+4=19 >= 14 → Hit. total_mod = 4 (BTHB only).

spawn Character cond_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character cond_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }

rolls 15 6
let baseline = resolve_melee_attack(cond_atk, cond_tgt, SwordLong)
assert_eq baseline.outcome, AttackOutcome.Hit
assert_eq baseline.total_mod, 4
assert_eq baseline.damage, 6

// ── Prone on target: +4 to attack_mod ───────────────────────────

spawn Character prone_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character prone_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(prone_tgt, Prone, Duration.Indefinite)

rolls 15 6
let prone_result = resolve_melee_attack(prone_atk, prone_tgt, SwordLong)
assert_eq prone_result.total_mod, 8
assert_eq prone_result.outcome, AttackOutcome.Hit

// ── Stunned on target: +4 to attack_mod ─────────────────────────

spawn Character stun_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character stun_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(stun_tgt, Stunned, Duration.Indefinite)

rolls 15 6
let stun_result = resolve_melee_attack(stun_atk, stun_tgt, SwordLong)
assert_eq stun_result.total_mod, 8

// ── Staggered on target: +2 to attack_mod ───────────────────────

spawn Character stag_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character stag_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(stag_tgt, Staggered, Duration.Indefinite)

rolls 15 6
let stag_result = resolve_melee_attack(stag_atk, stag_tgt, SwordLong)
assert_eq stag_result.total_mod, 6

// ── Invisible on target: -4 to attack_mod ───────────────────────

spawn Character invis_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character invis_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(invis_tgt, Invisible, Duration.Indefinite)

// BTHB=4 + attack_mod=-4 = 0
rolls 15 6
let invis_result = resolve_melee_attack(invis_atk, invis_tgt, SwordLong)
assert_eq invis_result.total_mod, 0

// ── Invisible on character: +4 to all saving throws ────────────

spawn Character invis_save_tgt { name: "InvisibleSaver", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
let invis_save_base = entity_best_saves(invis_save_tgt)
call apply_condition(invis_save_tgt, Invisible, Duration.Indefinite)

assert_eq entity_best_saves(invis_save_tgt).aimed_magic, max(2, invis_save_base.aimed_magic - 4)
assert_eq entity_best_saves(invis_save_tgt).breath, max(2, invis_save_base.breath - 4)
assert_eq entity_best_saves(invis_save_tgt).death_paralysis_poison, max(2, invis_save_base.death_paralysis_poison - 4)
assert_eq entity_best_saves(invis_save_tgt).petrification_polymorph, max(2, invis_save_base.petrification_polymorph - 4)
assert_eq entity_best_saves(invis_save_tgt).spells, max(2, invis_save_base.spells - 4)

// ── Invisible causes miss on borderline roll ────────────────────

spawn Character invis2_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character invis2_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(invis2_tgt, Invisible, Duration.Indefinite)

// BTHB=0, attack_mod=-4 → total_mod=-4. Roll 17 → 17+(-4)=13 < 14 → Miss
rolls 17
let invis2_result = resolve_melee_attack(invis2_atk, invis2_tgt, SwordLong)
assert_eq invis2_result.outcome, AttackOutcome.Miss
assert_eq invis2_result.total_mod, -4

// ── Paralyzed on target: auto_hit + max_damage ──────────────────
// SwordLong: 1d8 → max = 8. No dice rolls needed.

spawn Character para_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character para_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail }) } }
call apply_condition(para_tgt, Paralyzed, Duration.Indefinite)

rolls clear
let para_result = resolve_melee_attack(para_atk, para_tgt, SwordLong)
assert_eq para_result.outcome, AttackOutcome.Hit
assert_eq para_result.total_mod, 0
assert_eq para_result.damage, 8

// ── Magical Sleeping on target: auto_hit + max_damage ───────────

spawn Character sleep_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character sleep_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail }) } }
call apply_condition(sleep_tgt, Sleeping, Duration.Indefinite)

rolls clear
let sleep_result = resolve_melee_attack(sleep_atk, sleep_tgt, SwordLong)
assert_eq sleep_result.outcome, AttackOutcome.Hit
assert_eq sleep_result.damage, 8

// ── NormalSleep on target: +4, no DEX/shield, not auto-hit ─────

spawn Character nsleep_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character nsleep_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 17, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail }), worn_shield: some(Shield { shield_type: SmallShield }) } }
call apply_condition(nsleep_tgt, NormalSleep, Duration.Indefinite)

rolls 12
let nsleep_result = resolve_melee_attack(nsleep_atk, nsleep_tgt, SwordLong)
assert_eq nsleep_result.total_mod, 4
assert_eq nsleep_result.outcome, AttackOutcome.Miss
assert_eq effective_target_ac(nsleep_tgt), 17

// ── RearAttacked on target: +2 to attack_mod ────────────────────

spawn Character rear_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character rear_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(rear_tgt, RearAttacked, Duration.Indefinite)

rolls 15 6
let rear_result = resolve_melee_attack(rear_atk, rear_tgt, SwordLong)
assert_eq rear_result.total_mod, 6

// ── Paralyzed affects missile attacks (auto_hit + max_damage) ───
// BowLong: 1d6 → max = 6.

spawn Character para_archer { name: "Archer", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character para_miss_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(para_miss_tgt, Paralyzed, Duration.Indefinite)

rolls clear
let para_missile = resolve_missile_attack(para_archer, para_miss_tgt, BowLong, Feet { value: 60 })
assert_eq para_missile.outcome, AttackOutcome.Hit
assert_eq para_missile.total_mod, 2
assert_eq para_missile.damage, 6

// ── Attacker conditions: result override ────────────────────────

// Surprised on attacker forces Miss
spawn Character surp_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character surp_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
call apply_condition(surp_atk, Surprised, Duration.Indefinite)

rolls 18 6
let surp_result = resolve_melee_attack(surp_atk, surp_tgt, SwordLong)
assert_eq surp_result.outcome, AttackOutcome.Miss
assert_eq surp_result.damage, 0

// Fleeing on attacker forces Miss
spawn Character flee_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character flee_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
call apply_condition(flee_atk, Fleeing, Duration.Indefinite)

rolls 18 6
let flee_result = resolve_melee_attack(flee_atk, flee_tgt, SwordLong)
assert_eq flee_result.outcome, AttackOutcome.Miss
assert_eq flee_result.damage, 0

// ── Fleeing on target: +4 to melee attack_mod ───────────────────

spawn Character flee2_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character flee2_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(flee2_tgt, Fleeing, Duration.Indefinite)

rolls 15 6
let flee2_result = resolve_melee_attack(flee2_atk, flee2_tgt, SwordLong)
assert_eq flee2_result.total_mod, 8

// ── Parameterised conditions ────────────────────────────────────

// Concealed(level=1): -1 to attack_mod → BTHB=4 + (-1) = 3
spawn Character conc1_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character conc1_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(conc1_tgt, Concealed(level: 1), Duration.Indefinite)

rolls 15 6
let conc1_result = resolve_melee_attack(conc1_atk, conc1_tgt, SwordLong)
assert_eq conc1_result.total_mod, 3

// Concealed(level=4): -4 to attack_mod → BTHB=4 + (-4) = 0
spawn Character conc4_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character conc4_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(conc4_tgt, Concealed(level: 4), Duration.Indefinite)

rolls 15 6
let conc4_result = resolve_melee_attack(conc4_atk, conc4_tgt, SwordLong)
assert_eq conc4_result.total_mod, 0

// Cover(penalty=2): -2 → BTHB=4 + (-2) = 2
spawn Character cov2_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character cov2_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(cov2_tgt, Cover(penalty: 2), Duration.Indefinite)

rolls 15 6
let cov2_result = resolve_melee_attack(cov2_atk, cov2_tgt, SwordLong)
assert_eq cov2_result.total_mod, 2

// Cover(penalty=10): -10 → BTHB=4 + (-10) = -6. Roll 19 → 19+(-6)=13 < 14 → Miss
spawn Character cov10_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character cov10_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(cov10_tgt, Cover(penalty: 10), Duration.Indefinite)

rolls 19
let cov10_result = resolve_melee_attack(cov10_atk, cov10_tgt, SwordLong)
assert_eq cov10_result.total_mod, -6
assert_eq cov10_result.outcome, AttackOutcome.Miss

// ── Cross-attack-type: Prone on missile attack ──────────────────

spawn Character prone_archer { name: "Archer", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character prone_miss_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(prone_miss_tgt, Prone, Duration.Indefinite)

// BTHB=2 + attack_mod=4 = 6
rolls 15 4
let prone_missile = resolve_missile_attack(prone_archer, prone_miss_tgt, BowLong, Feet { value: 60 })
assert_eq prone_missile.total_mod, 6

// ── Cross-entity-type: Prone on monster attack target ───────────

spawn Monster cond_ogre { name: "Ogre", hit_dice: 4d8+1, max_hp: 26, hp: 26, ac: 15, morale: 7, morale_checks_made: 0, xp_value: 0, intelligence: 1, attacks: [MonsterAttack { name: "Club", damage: 1d10 }], size: Medium, special: [] }
spawn Character prone_victim { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 8, hp: 8 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(prone_victim, Prone, Duration.Indefinite)

// monster_bthb(4d8+1)=5, attack_mod=+4 → total_mod=9
rolls 12 7
let prone_monster = resolve_monster_attack(cond_ogre, prone_victim, MonsterAttack { name: "Club", damage: 1d10 })
assert_eq prone_monster.total_mod, 9

// ── RearAttacked affects monster attacks (+2 via #attack_resolution) ──

spawn Monster rear_ogre { name: "Ogre", hit_dice: 4d8+1, max_hp: 26, hp: 26, ac: 15, morale: 7, morale_checks_made: 0, xp_value: 0, intelligence: 1, attacks: [MonsterAttack { name: "Club", damage: 1d10 }], size: Medium, special: [] }
spawn Character rear_victim { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 8, hp: 8 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(rear_victim, RearAttacked, Duration.Indefinite)

// monster_bthb=5, attack_mod=+2 → total_mod=7
rolls 12 7
let rear_monster = resolve_monster_attack(rear_ogre, rear_victim, MonsterAttack { name: "Club", damage: 1d10 })
assert_eq rear_monster.total_mod, 7

// ── Condition stacking ──────────────────────────────────────────

// Prone (+4) + Staggered (+2) = +6 → BTHB=4 + 6 = 10
spawn Character stack_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character stack_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(stack_tgt, Prone, Duration.Indefinite)
call apply_condition(stack_tgt, Staggered, Duration.Indefinite)

rolls 15 6
let stack_result = resolve_melee_attack(stack_atk, stack_tgt, SwordLong)
assert_eq stack_result.total_mod, 10

// Prone (+4) + Invisible (-4) cancel out → BTHB=4
spawn Character cancel_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character cancel_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(cancel_tgt, Prone, Duration.Indefinite)
call apply_condition(cancel_tgt, Invisible, Duration.Indefinite)

rolls 15 6
let cancel_result = resolve_melee_attack(cancel_atk, cancel_tgt, SwordLong)
assert_eq cancel_result.total_mod, 4

// Concealed does not stack with Invisible
spawn Character invisconc_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character invisconc_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(invisconc_tgt, Invisible, Duration.Indefinite)
call apply_condition(invisconc_tgt, Concealed(level: 3), Duration.Indefinite)

rolls 15 6
let invisconc_result = resolve_melee_attack(invisconc_atk, invisconc_tgt, SwordLong)
assert_eq invisconc_result.total_mod, 0

// Cover(7) + Concealed(2) stack to -9 → BTHB=4 + (-9) = -5
spawn Character covconc_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character covconc_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(covconc_tgt, Cover(penalty: 7), Duration.Indefinite)
call apply_condition(covconc_tgt, Concealed(level: 2), Duration.Indefinite)

rolls 19 6
let covconc_result = resolve_melee_attack(covconc_atk, covconc_tgt, SwordLong)
assert_eq covconc_result.total_mod, -5

// ── Condition removal ───────────────────────────────────────────

// Apply Prone, remove it, verify baseline
spawn Character rem_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character rem_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(rem_tgt, Prone, Duration.Indefinite)
assert_condition rem_tgt, Prone
call remove_condition(rem_tgt, Prone)
assert_no_condition rem_tgt, Prone

rolls 15 6
let rem_result = resolve_melee_attack(rem_atk, rem_tgt, SwordLong)
assert_eq rem_result.total_mod, 4

// Remove one stacked condition, keep the other
spawn Character rem2_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character rem2_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(rem2_tgt, Prone, Duration.Indefinite)
call apply_condition(rem2_tgt, Staggered, Duration.Indefinite)
call remove_condition(rem2_tgt, Prone)
assert_no_condition rem2_tgt, Prone
assert_condition rem2_tgt, Staggered

rolls 15 6
let rem2_result = resolve_melee_attack(rem2_atk, rem2_tgt, SwordLong)
assert_eq rem2_result.total_mod, 6

// Remove parameterised condition
spawn Character rem3_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character rem3_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(rem3_tgt, Concealed(level: 3), Duration.Indefinite)
call remove_condition(rem3_tgt, Concealed(level: 3))
assert_no_condition rem3_tgt, Concealed

rolls 15 6
let rem3_result = resolve_melee_attack(rem3_atk, rem3_tgt, SwordLong)
assert_eq rem3_result.total_mod, 4

// ── Monster bearers ─────────────────────────────────────────────

// Surprised on monster forces its attacks to miss
spawn Monster surp_monster { name: "Ogre", hit_dice: 4d8+1, max_hp: 26, hp: 26, ac: 15, morale: 7, morale_checks_made: 0, xp_value: 0, intelligence: 1, attacks: [MonsterAttack { name: "Club", damage: 1d10 }], size: Medium, special: [] }
spawn Character surp_victim { name: "Victim", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail }) } }
call apply_condition(surp_monster, Surprised, Duration.Indefinite)

rolls 18 8
let surp_mon_result = resolve_monster_attack(surp_monster, surp_victim, MonsterAttack { name: "Club", damage: 1d10 })
assert_eq surp_mon_result.outcome, AttackOutcome.Miss
assert_eq surp_mon_result.damage, 0

// Concealed on target applies to monster attack
spawn Monster conc_goblin { name: "Goblin", hit_dice: 1d8-1, max_hp: 4, hp: 4, ac: 13, morale: 7, morale_checks_made: 0, xp_value: 0, intelligence: 1, attacks: [MonsterAttack { name: "Shortsword", damage: 1d6 }], size: Medium, special: [] }
spawn Character conc_ranger { name: "Ranger", classes: [ClassLevel { class: Ranger, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(conc_ranger, Concealed(level: 3), Duration.Indefinite)

// monster_bthb(1d8-1)=0, attack_mod=-3 → total_mod=-3
rolls 15
let conc_mon_result = resolve_monster_attack(conc_goblin, conc_ranger, MonsterAttack { name: "Shortsword", damage: 1d6 })
assert_eq conc_mon_result.total_mod, -3

