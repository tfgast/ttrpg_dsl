// OSRIC Inventory integration tests
//
// Tests coin purse, container management, item add/remove,
// weight tracking, consumable usage, and treasure XP flow.

load osric/*.ttrpg

// ── CoinPurse derives ─────────────────────────────────────────

let purse = CoinPurse { cp: 100, sp: 50, ep: 20, gp: 10, pp: 5 }
assert_eq coin_count(purse), 185
assert_eq coin_weight(purse), 18
// gp value: 100/100 + 50/10 + 20/2 + 10 + 5*5 = 1+5+10+10+25 = 51
assert_eq coin_gp_value(purse), 51

let empty_purse = CoinPurse {}
assert_eq coin_count(empty_purse), 0
assert_eq coin_weight(empty_purse), 0
assert_eq coin_gp_value(empty_purse), 0

// ── Item weight calculation ───────────────────────────────────

let torch = standard_item("Torch")
assert_eq item_weight(torch), 1

let torches6 = standard_item("Torches (6)")
assert_eq torches6.quantity, 6
assert_eq torches6.bundle_size, 6
assert_eq item_weight(torches6), 6

let arrows = standard_item("Arrows (20)")
assert_eq arrows.quantity, 20
assert_eq arrows.bundle_size, 20
assert_eq item_weight(arrows), 3

let rope = standard_item("Rope (50ft)")
assert_eq item_weight(rope), 10

// ── items_weight ──────────────────────────────────────────────

assert_eq items_weight([]), 0
assert_eq items_weight([torch, rope]), 11

// ── Container type constants ──────────────────────────────────

assert_eq BACKPACK.capacity_lbs, 30
assert_eq BACKPACK.weight_empty, 2
assert_eq SMALL_POUCH.capacity_lbs, 2
assert_eq LARGE_SACK.capacity_lbs, 40
assert_eq CHEST.weight_empty, 10

// ── Container weight and capacity ─────────────────────────────

let empty_bp = Container { container_type: BACKPACK }
assert_eq container_contents_weight(empty_bp), 0
assert_eq container_total_weight(empty_bp), 2
assert_eq container_remaining_capacity(empty_bp), 30

// Container with items
let loaded_bp = Container { container_type: BACKPACK, items: [standard_item("Rope (50ft)"), standard_item("Torch")] }
assert_eq container_contents_weight(loaded_bp), 11
assert_eq container_total_weight(loaded_bp), 13
assert_eq container_remaining_capacity(loaded_bp), 19

// item_fits_in_container
assert_eq item_fits_in_container(loaded_bp, standard_item("Bedroll")), true
let tent = standard_item("Tent")
assert_eq tent.weight, 20
assert_eq item_fits_in_container(loaded_bp, tent), false

// ── Spawn character with Inventory ────────────────────────────

spawn Character char { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, Inventory {} }

// Initially empty
assert_eq inventory_weight(char), 0

// ── Add and remove containers ─────────────────────────────────

call add_container(char, BACKPACK)
assert_eq char.Inventory.containers.len(), 1
// Empty backpack weighs 2
assert_eq inventory_weight(char), 2

call add_container(char, SMALL_POUCH)
assert_eq char.Inventory.containers.len(), 2

call remove_container(char, 1)
assert_eq char.Inventory.containers.len(), 1

// ── Add items to container ────────────────────────────────────

call add_item_to_container(char, 0, standard_item("Rope (50ft)"))
assert_eq inventory_weight(char), 12

call add_item_to_container(char, 0, standard_item("Torch"))
assert_eq inventory_weight(char), 13

// ── Container capacity overflow ───────────────────────────────

// Backpack has 30 lb capacity, currently 11 lbs of items. Tent weighs 20 - won't fit.
assert_err call add_item_to_container(char, 0, standard_item("Tent"))

// ── Remove item from container ────────────────────────────────

call remove_item_from_container(char, 0, "Torch")
assert_eq inventory_weight(char), 12

// ── Loose items ───────────────────────────────────────────────

call add_loose_item(char, standard_item("Bedroll"))
assert_eq inventory_weight(char), 17

call add_loose_item(char, standard_item("Waterskin"))
assert_eq inventory_weight(char), 18

call remove_loose_item(char, "Bedroll")
assert_eq inventory_weight(char), 13

// ── Coin management ──────────────────────────────────────────

call add_coins(char, CoinPurse { gp: 100 })
assert_eq char.Inventory.coins.gp, 100
// 100 coins = 10 lbs
assert_eq inventory_weight(char), 23

call add_coins(char, CoinPurse { sp: 50, cp: 30 })
assert_eq char.Inventory.coins.sp, 50
assert_eq char.Inventory.coins.cp, 30

call spend_coins_gp(char, 40)
assert_eq char.Inventory.coins.gp, 60

// Cannot spend more than you have
assert_err call spend_coins_gp(char, 200)

// ── Consumable use in container ───────────────────────────────

spawn Character consumer { name: "Ranger", classes: [ClassLevel { class: Ranger, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, Inventory {} }
call add_container(consumer, BACKPACK)
call add_item_to_container(consumer, 0, standard_item("Torches (6)"))

// Use one torch - quantity decreases
call use_consumable_in_container(consumer, 0, "Torches (6)")
assert_eq consumer.Inventory.containers[0].items[0].quantity, 5

// Use four more
call use_consumable_in_container(consumer, 0, "Torches (6)")
call use_consumable_in_container(consumer, 0, "Torches (6)")
call use_consumable_in_container(consumer, 0, "Torches (6)")
call use_consumable_in_container(consumer, 0, "Torches (6)")
assert_eq consumer.Inventory.containers[0].items[0].quantity, 1

// Use the last one - item is removed entirely
call use_consumable_in_container(consumer, 0, "Torches (6)")
assert_eq consumer.Inventory.containers[0].items.len(), 0

// ── Consumable use loose ──────────────────────────────────────

call add_loose_item(consumer, standard_item("Rations (7 days)"))
assert_eq consumer.Inventory.loose_items[0].quantity, 7

call use_consumable_loose(consumer, "Rations (7 days)")
assert_eq consumer.Inventory.loose_items[0].quantity, 6

// Use remaining 6
for i in 0..6 {
    call use_consumable_loose(consumer, "Rations (7 days)")
}
assert_eq consumer.Inventory.loose_items.len(), 0

// ── Treasure XP: item XP calculation ─────────────────────────

let mundane = Item { name: "Rope", weight: 10 }
assert_eq kept_item_xp(mundane), 0

let gem = Item { name: "Ruby", weight: 0, gp_value: 500 }
assert_eq kept_item_xp(gem), 500

let potion = Item { name: "Potion", weight: 1, gp_value: 200, kept_xp_divisor: 2 }
assert_eq kept_item_xp(potion), 100

// ── Treasure XP: unawarded items ─────────────────────────────

let items = [gem, potion, mundane]
assert_eq unawarded_items_xp(items), 600

// After marking awarded, should be 0
let awarded = mark_items_awarded(items)
assert_eq unawarded_items_xp(awarded), 0

// ── Treasure XP: award flow ──────────────────────────────────

spawn Character treasure_char { name: "Thief", classes: [ClassLevel { class: Thief, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 6, hp: 6 }, Inventory {} }
call add_container(treasure_char, BACKPACK)
call add_item_to_container(treasure_char, 0, Item { name: "Gold Idol", weight: 5, gp_value: 300 })
call add_loose_item(treasure_char, Item { name: "Silver Necklace", weight: 0, gp_value: 200 })

let item_xp = award_item_treasure_xp(treasure_char)
assert_eq item_xp, 500

// Second call should yield 0 (already awarded)
let item_xp2 = award_item_treasure_xp(treasure_char)
assert_eq item_xp2, 0

// ── Treasure XP: coin treasure ───────────────────────────────

let coin_xp = award_coin_treasure_xp(treasure_char, 1000)
assert_eq coin_xp, 1000
assert_eq treasure_char.Inventory.coin_xp_ledger, 1000

let coin_xp2 = award_coin_treasure_xp(treasure_char, 500)
assert_eq coin_xp2, 500
assert_eq treasure_char.Inventory.coin_xp_ledger, 1500

// ── Inventory weight with no inventory group ─────────────────

spawn Character no_inv { name: "Peasant", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 4, hp: 4 } }
assert_eq inventory_weight(no_inv), 0
