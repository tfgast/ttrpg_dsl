// ── has_stalwart derive ────────────────────────────────────────

assert_eq has_stalwart(Dwarf), true
assert_eq has_stalwart(Gnome), true
assert_eq has_stalwart(Halfling), true
assert_eq has_stalwart(Elf), false
assert_eq has_stalwart(HalfElf), false
assert_eq has_stalwart(HalfOrc), false
assert_eq has_stalwart(Human), false

// ── ancestry_def derive ────────────────────────────────────────

// Human: all adjustments 0, size Medium, movement 120ft, no infravision
let human = ancestry_def(Human)
assert_eq human.ancestry, Ancestry.Human
assert_eq human.size, Size.Medium
assert_eq human.base_movement, Feet { value: 120 }
assert_eq human.infravision, Feet { value: 0 }
assert_eq human.str_adj, 0
assert_eq human.dex_adj, 0
assert_eq human.con_adj, 0
assert_eq human.int_adj, 0
assert_eq human.wis_adj, 0
assert_eq human.cha_adj, 0

// Dwarf: CON +1, CHA -1, Small, movement 90ft
let dwarf = ancestry_def(Dwarf)
assert_eq dwarf.size, Size.Small
assert_eq dwarf.base_movement, Feet { value: 90 }
assert_eq dwarf.str_adj, 0
assert_eq dwarf.con_adj, 1
assert_eq dwarf.cha_adj, -1

// Halfling: STR -1, DEX +1, Small
let halfling = ancestry_def(Halfling)
assert_eq halfling.str_adj, -1
assert_eq halfling.dex_adj, 1
assert_eq halfling.con_adj, 0
assert_eq halfling.size, Size.Small

// Half-Orc: STR +1, CON +1, CHA -2
let halforc = ancestry_def(HalfOrc)
assert_eq halforc.str_adj, 1
assert_eq halforc.con_adj, 1
assert_eq halforc.cha_adj, -2

// ── ancestry_ability_range derive ──────────────────────────────

// Human: 3-18 for all abilities
assert_eq ancestry_ability_range(Human, STR).min, 3
assert_eq ancestry_ability_range(Human, STR).max, 18
assert_eq ancestry_ability_range(Human, DEX).min, 3
assert_eq ancestry_ability_range(Human, DEX).max, 18
assert_eq ancestry_ability_range(Human, CON).min, 3
assert_eq ancestry_ability_range(Human, CON).max, 18
assert_eq ancestry_ability_range(Human, INT).min, 3
assert_eq ancestry_ability_range(Human, INT).max, 18
assert_eq ancestry_ability_range(Human, WIS).min, 3
assert_eq ancestry_ability_range(Human, WIS).max, 18
assert_eq ancestry_ability_range(Human, CHA).min, 3
assert_eq ancestry_ability_range(Human, CHA).max, 18

// Dwarf: STR 8-18, DEX 3-17, CON 12-19, INT 3-18, WIS 3-18, CHA 3-16
assert_eq ancestry_ability_range(Dwarf, STR).min, 8
assert_eq ancestry_ability_range(Dwarf, STR).max, 18
assert_eq ancestry_ability_range(Dwarf, DEX).min, 3
assert_eq ancestry_ability_range(Dwarf, DEX).max, 17
assert_eq ancestry_ability_range(Dwarf, CON).min, 12
assert_eq ancestry_ability_range(Dwarf, CON).max, 19
assert_eq ancestry_ability_range(Dwarf, INT).min, 3
assert_eq ancestry_ability_range(Dwarf, INT).max, 18
assert_eq ancestry_ability_range(Dwarf, WIS).min, 3
assert_eq ancestry_ability_range(Dwarf, WIS).max, 18
assert_eq ancestry_ability_range(Dwarf, CHA).min, 3
assert_eq ancestry_ability_range(Dwarf, CHA).max, 16

// Half-Orc: CON 13-19, WIS 3-14, CHA 3-12
assert_eq ancestry_ability_range(HalfOrc, CON).min, 13
assert_eq ancestry_ability_range(HalfOrc, CON).max, 19
assert_eq ancestry_ability_range(HalfOrc, WIS).min, 3
assert_eq ancestry_ability_range(HalfOrc, WIS).max, 14
assert_eq ancestry_ability_range(HalfOrc, CHA).min, 3
assert_eq ancestry_ability_range(HalfOrc, CHA).max, 12

// ── effective_str_to_hit (entity-based) ─────────────────────────

// STR 16, no exceptional → str_to_hit(16) = 0
spawn Character fighter16 { name: "Fighter16", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 16, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 } }
assert_eq effective_str_to_hit(fighter16), 0

// STR 17 → str_to_hit(17) = 1
spawn Character fighter17 { name: "Fighter17", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 17, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 } }
assert_eq effective_str_to_hit(fighter17), 1

// STR 18, no ExceptionalStrength → str_to_hit(18) = 1
spawn Character cleric18 { name: "Cleric18", classes: [ClassLevel { class: Class.Cleric, level: 1 }], abilities: { STR: 18, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 } }
assert_eq effective_str_to_hit(cleric18), 1

// STR 18, percentile 76 → exc_str_to_hit(76) = 2
spawn Character fighter18_76 { name: "Fighter18_76", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 18, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 }, ExceptionalStrength { percentile: 76 } }
assert_eq effective_str_to_hit(fighter18_76), 2

// STR 18, percentile 100 → exc_str_to_hit(100) = 3
spawn Character fighter18_100 { name: "Fighter18_100", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 18, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 }, ExceptionalStrength { percentile: 100 } }
assert_eq effective_str_to_hit(fighter18_100), 3

// ── effective_str_damage (entity-based) ─────────────────────────

// STR 17, no exceptional → str_damage(17) = 1
spawn Character dmg17 { name: "DmgFighter17", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 17, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 } }
assert_eq effective_str_damage(dmg17), 1

// STR 18, percentile 91 → exc_str_damage(91) = 5
spawn Character dmg18_91 { name: "DmgFighter18_91", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 18, INT: 10, WIS: 10, DEX: 10, CON: 10, CHA: 10 }, HitPoints { max_hp: 10, hp: 10 }, ExceptionalStrength { percentile: 91 } }
assert_eq effective_str_damage(dmg18_91), 5
