assert_eq str_minor_test(19), 5

assert_eq str_minor_extraordinary(3), 0
assert_eq str_minor_extraordinary(10), 0
assert_eq str_minor_extraordinary(15), 0
assert_eq str_minor_extraordinary(18), 0
assert_eq str_minor_extraordinary(19), 2

assert_eq str_major_test(3), 0
assert_eq str_major_test(9), 1
assert_eq str_major_test(11), 2
assert_eq str_major_test(13), 4
assert_eq str_major_test(15), 7
assert_eq str_major_test(16), 10
assert_eq str_major_test(17), 13
assert_eq str_major_test(18), 16
assert_eq str_major_test(19), 40

