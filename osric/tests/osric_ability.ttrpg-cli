// OSRIC Ability modifier tables integration tests
//
// Equivalent of crates/ttrpg_interp/tests/osric_ability_integration.rs
// (table/derive value checks only; AST structure tests remain in Rust)

load osric/*.ttrpg

// ── STR tables ─────────────────────────────────────────────────

assert_eq str_to_hit(3), -3
assert_eq str_to_hit(4), -2
assert_eq str_to_hit(5), -2
assert_eq str_to_hit(7), -1
