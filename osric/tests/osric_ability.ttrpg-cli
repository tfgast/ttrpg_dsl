assert_eq str_to_hit(15), 0
assert_eq str_to_hit(16), 0
assert_eq str_to_hit(17), 1
assert_eq str_to_hit(18), 1
assert_eq str_to_hit(19), 3

assert_eq str_damage(3), -1
