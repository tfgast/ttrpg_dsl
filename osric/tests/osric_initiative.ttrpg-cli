// OSRIC Initiative integration tests
//
// Equivalent of crates/ttrpg_interp/tests/osric_initiative_integration.rs
// Tests surprise_duration, free_surprise_segments, roll_surprise,
// roll_initiative, wrap_segment, action_segment, missile_init_segment,
// assign_segment, fighter multiple attacks, spell timing, speed factor
// tie-breaking, melee_order, movement segments, charge interaction,
// CastingSpell condition, and BeginCasting action.

load osric/*.ttrpg

// ── Surprise duration ───────────────────────────────────────────

// Roll 3+ (default threshold 2): not surprised
assert_eq surprise_duration(3, 0), 0
assert_eq surprise_duration(4, 0), 0
assert_eq surprise_duration(5, 0), 0
assert_eq surprise_duration(6, 0), 0

// Roll 1 with no DEX adj = 1 segment
assert_eq surprise_duration(1, 0), 1

// Roll 2 with no DEX adj = 2 segments
assert_eq surprise_duration(2, 0), 2

// Roll 2 with DEX adj 1 → max(0, 2-1) = 1
assert_eq surprise_duration(2, 1), 1

// High DEX adj fully negates surprise: max(0, 2-3) = 0
assert_eq surprise_duration(2, 3), 0

// ── Expanded surprise thresholds ────────────────────────────────

// Threshold 3, roll 3 → 3 segments
assert_eq surprise_duration(3, 0, 3), 3

// Threshold 4, roll 4 → 4 segments
assert_eq surprise_duration(4, 0, 4), 4

// Threshold 3, roll 4 → not surprised
assert_eq surprise_duration(4, 0, 3), 0

// Threshold 3, roll 3, DEX adj 1 → max(0, 3-1) = 2
assert_eq surprise_duration(3, 1, 3), 2

// ── Free surprise segments ──────────────────────────────────────

// Party more surprised (2 segments vs 0): monsters get 2 free
assert_eq free_surprise_segments(2, 0), 2

// Monster more surprised (0 vs 1): party gets 1 free
assert_eq free_surprise_segments(0, 1), 1

// Equal surprise: no free segments
assert_eq free_surprise_segments(1, 1), 0

// ── roll_surprise mechanic ──────────────────────────────────────

// Party rolls 1 (surprised 1 seg), monster rolls 4 (not surprised)
rolls 1 4
let rs1 = roll_surprise()
assert_eq rs1.party_roll, 1
assert_eq rs1.monster_roll, 4
assert_eq rs1.party_surprised_segments, 1
assert_eq rs1.monster_surprised_segments, 0

// High rolls: neither surprised
rolls 5 3
let rs2 = roll_surprise()
assert_eq rs2.party_surprised_segments, 0
assert_eq rs2.monster_surprised_segments, 0

// Both surprised
rolls 2 1
let rs3 = roll_surprise()
assert_eq rs3.party_surprised_segments, 2
assert_eq rs3.monster_surprised_segments, 1

// Monster threshold 3: party rolls 3, surprised 3 segments
rolls 3 5
let rs4 = roll_surprise(3, 2)
assert_eq rs4.party_roll, 3
assert_eq rs4.party_surprised_segments, 3
assert_eq rs4.monster_surprised_segments, 0

// Party threshold 3: monster rolls 3, surprised 3 segments
rolls 5 3
let rs5 = roll_surprise(2, 3)
assert_eq rs5.party_surprised_segments, 0
assert_eq rs5.monster_surprised_segments, 3

// Asymmetric thresholds: monster surprises 1-4, party 1-2
rolls 4 3
let rs6 = roll_surprise(4, 2)
assert_eq rs6.party_surprised_segments, 4
assert_eq rs6.monster_surprised_segments, 0

// ── roll_initiative mechanic ────────────────────────────────────

// Simultaneous (both roll 3)
rolls 3 3
let ri1 = roll_initiative()
assert_eq ri1.party_roll, 3
assert_eq ri1.monster_roll, 3
assert_eq ri1.party_segment, 3
assert_eq ri1.monster_segment, 3
assert_eq ri1.simultaneous, true

// Not simultaneous (party 2, monster 5)
rolls 2 5
let ri2 = roll_initiative()
assert_eq ri2.party_segment, 2
assert_eq ri2.monster_segment, 5
assert_eq ri2.simultaneous, false

// ── Segment wrapping ────────────────────────────────────────────

// 1-10 unchanged
assert_eq wrap_segment(1), 1
assert_eq wrap_segment(5), 5
assert_eq wrap_segment(10), 10

// Wraps
assert_eq wrap_segment(11), 1
assert_eq wrap_segment(12), 2
assert_eq wrap_segment(20), 10

// ── Action segment assignment ───────────────────────────────────

// Melee: equals initiative segment
assert_eq action_segment(4, MeleeAttackAction), 4

// Move: always segment 1
assert_eq action_segment(1, MoveAction), 1
assert_eq action_segment(3, MoveAction), 1
assert_eq action_segment(6, MoveAction), 1

// Set against charge: always segment 1
assert_eq action_segment(5, SetAgainstChargeAction), 1

// Cast spell: initiative + casting_time - 1
// Initiative 4, casting time 3 → 4+3-1 = 6
assert_eq action_segment(4, CastSpellAction, 3), 6

// Cross-round casting: initiative 6, casting time 7 → 12 (NOT wrapped)
assert_eq action_segment(6, CastSpellAction, 7), 12

// Missile with DEX adj: max(1, init + adj)
// Initiative 4, DEX adj -1 → max(1, 3) = 3
assert_eq action_segment(4, MissileAttackAction, 0, -1), 3

// Missile DEX adj floors to 1: init 1, adj -3 → max(1, -2) = 1
assert_eq action_segment(1, MissileAttackAction, 0, -3), 1

// Simple types all equal initiative
assert_eq action_segment(3, ChargeAction), 3
assert_eq action_segment(3, ParryAction), 3
assert_eq action_segment(3, FleeAction), 3
assert_eq action_segment(3, HoldAction), 3
assert_eq action_segment(3, TwoWeaponAttackAction), 3

// ── missile_init_segment ────────────────────────────────────────

// DEX 16 → dex_init_missile = -1 → base 4 + (-1) = 3
assert_eq missile_init_segment(4, 16), 3

// DEX 3 → dex_init_missile = +3 → base 2 + 3 = 5
assert_eq missile_init_segment(2, 3), 5

// ── assign_segment ──────────────────────────────────────────────

// Melee: segment = initiative, speed_factor from arg
let as1 = assign_segment(3, MeleeAttackAction, 5)
assert_eq as1.segment, 3
assert_eq as1.speed_factor, 5
assert_eq as1.action_type, DeclaredActionType.MeleeAttackAction

// Casting: segment adjusted by casting_time
let as2 = assign_segment(2, CastSpellAction, 0, 5)
assert_eq as2.segment, 6

// ── Fighter multiple attacks ────────────────────────────────────

// has_fighter_multi_attack
assert_eq has_fighter_multi_attack(Fighter, 8), true
assert_eq has_fighter_multi_attack(Fighter, 7), false
assert_eq has_fighter_multi_attack(Paladin, 8), true
assert_eq has_fighter_multi_attack(Thief, 10), false

// fighter_attacks_this_round: level < 8 always 1
assert_eq fighter_attacks_this_round(6, 1), 1
assert_eq fighter_attacks_this_round(6, 2), 1
assert_eq fighter_attacks_this_round(6, 3), 1

// Level 8-12: alternates (odd=1, even=2)
assert_eq fighter_attacks_this_round(7, 1), 1
assert_eq fighter_attacks_this_round(7, 2), 1
assert_eq fighter_attacks_this_round(8, 1), 1
assert_eq fighter_attacks_this_round(8, 2), 2
assert_eq fighter_attacks_this_round(9, 1), 1
assert_eq fighter_attacks_this_round(9, 2), 2

// Level 13+: always 2
assert_eq fighter_attacks_this_round(13, 1), 2
assert_eq fighter_attacks_this_round(13, 2), 2
assert_eq fighter_attacks_this_round(13, 3), 2

// fighter_attack_segments
assert_eq fighter_attack_segments(8, 2, 4), [4, 10]
assert_eq fighter_attack_segments(8, 1, 4), [4]
assert_eq fighter_attack_segments(13, 1, 6), [6, 10]
assert_eq fighter_attack_segments(13, 2, 6), [6, 10]
assert_eq fighter_attack_segments(7, 1, 5), []

// ── Spell timing ────────────────────────────────────────────────

// spell_effect_segment: initiative + casting_time - 1
assert_eq spell_effect_segment(4, 3), 6

// Cross-round: 9 + 5 - 1 = 13 (NOT wrapped)
assert_eq spell_effect_segment(9, 5), 13

// Instant cast: 2 + 1 - 1 = 2
assert_eq spell_effect_segment(2, 1), 2

// is_casting_at_segment: during casting range
// Starts 4, casting time 3 → casting during 4,5,6
assert_eq is_casting_at_segment(4, 3, 4), true
assert_eq is_casting_at_segment(4, 3, 5), true

// Before start
assert_eq is_casting_at_segment(4, 3, 3), false

// After completion (segment 7 >= cast_start + casting_time = 7 → false)
assert_eq is_casting_at_segment(4, 3, 7), false

// spell_completed_at_segment
// Completes at 4+3-1=6
assert_eq spell_completed_at_segment(4, 3, 6), true
assert_eq spell_completed_at_segment(4, 3, 8), true
assert_eq spell_completed_at_segment(4, 3, 5), false

// ── Speed factor tie-breaking ───────────────────────────────────

assert_eq acts_first_by_speed(2, 5), true
assert_eq acts_first_by_speed(5, 2), false
assert_eq acts_first_by_speed(4, 4), false

// ── Melee order (by weapon speed factor) ────────────────────────

// Dagger SF=2 vs SwordLong SF=5
assert_eq melee_order(Dagger, SwordLong), true
assert_eq melee_order(SwordLong, Dagger), false

// Same weapon: false
assert_eq melee_order(SwordLong, SwordLong), false

// Halberd SF=9 vs FistOrKick SF=1
assert_eq melee_order(Halberd, FistOrKick), false
assert_eq melee_order(FistOrKick, Halberd), true

// ── Movement segments ───────────────────────────────────────────

// movement_per_segment: base/10
assert_eq movement_per_segment(Feet { value: 120 }), Feet { value: 12 }
assert_eq movement_per_segment(Feet { value: 60 }), Feet { value: 6 }
assert_eq movement_per_segment(Feet { value: 90 }), Feet { value: 9 }

// movement_through_segment: (base/10) * segment
assert_eq movement_through_segment(Feet { value: 120 }, 1), Feet { value: 12 }
assert_eq movement_through_segment(Feet { value: 120 }, 5), Feet { value: 60 }
assert_eq movement_through_segment(Feet { value: 120 }, 10), Feet { value: 120 }

// ── Charge interaction ──────────────────────────────────────────

assert_eq SET_WEAPON_DAMAGE_MULTIPLIER, 2

// Valid set-against-charge weapons
assert_eq can_set_against_charge(Spear), true
assert_eq can_set_against_charge(Javelin), true
assert_eq can_set_against_charge(Lance), true
assert_eq can_set_against_charge(PoleArm), true
assert_eq can_set_against_charge(Trident), true

// Invalid set-against-charge weapons
assert_eq can_set_against_charge(SwordLong), false
assert_eq can_set_against_charge(Dagger), false
assert_eq can_set_against_charge(Club), false
assert_eq can_set_against_charge(Staff), false
assert_eq can_set_against_charge(BattleAxe), false

// ── CastingSpell condition modifies attack resolution ───────────
rolls clear

// Baseline: without CastingSpell, attack hits normally
spawn Character cs_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character cs_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }

rolls 15 6
let cs_base = resolve_melee_attack(cs_atk, cs_tgt, SwordLong)
assert_eq cs_base.outcome, AttackOutcome.Hit
assert_eq cs_base.damage, 6

// CastingSpell on attacker forces Miss
spawn Character cs2_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character cs2_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(cs2_atk, CastingSpell, Duration.Indefinite)

rolls 20 8
let cs2_result = resolve_melee_attack(cs2_atk, cs2_tgt, SwordLong)
assert_eq cs2_result.outcome, AttackOutcome.Miss
assert_eq cs2_result.damage, 0

// CastingSpell on target strips DEX AC (standard DEX 12, no visible change)
spawn Character cs3_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
spawn Character cs3_tgt { name: "Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(cs3_tgt, CastingSpell, Duration.Indefinite)

rolls 15 6
let cs3_result = resolve_melee_attack(cs3_atk, cs3_tgt, SwordLong)
assert_eq cs3_result.outcome, AttackOutcome.Hit
assert_eq cs3_result.damage, 6

// CastingSpell on high-DEX target strips DEX +2 AC bonus, enabling a hit
// Target: armor AC 14, DEX 16 → +2 AC. Without CastingSpell: effective AC 16.
// With CastingSpell: effective AC 14. Roll 15 + BTHB 0 = 15 >= 14 → Hit.
spawn Character cs4_atk { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character cs4_tgt { name: "Target", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 16, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, EquipmentSlots { worn_armor: some(Armor { armour_type: ScaleLamellar }) } }
call apply_condition(cs4_tgt, CastingSpell, Duration.Indefinite)

rolls 15 6
let cs4_result = resolve_melee_attack(cs4_atk, cs4_tgt, SwordLong)
assert_eq cs4_result.outcome, AttackOutcome.Hit
assert_eq cs4_result.damage, 6

// ── BeginCasting action applies CastingSpell condition ──────────

spawn Character bc_caster { name: "Mage", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 }, Spellcasting { spell_slots: [], slots_used: [], memorised_spells: [] } }

assert_no_condition bc_caster, CastingSpell
do BeginCasting(bc_caster, 3)
assert_condition bc_caster, CastingSpell

// ── Spell interruption: damage removes CastingSpell ─────────────

spawn Character si_caster { name: "Mage", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, Spellcasting { spell_slots: [], slots_used: [], memorised_spells: [] } }
spawn Character si_fighter { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }

call apply_condition(si_caster, CastingSpell, Duration.Indefinite)
assert_condition si_caster, CastingSpell

// Attack the caster — triggers SpellInterruption hook
rolls 18 5
do MeleeAttack(si_fighter, si_caster)

// CastingSpell should be removed by the hook
assert_no_condition si_caster, CastingSpell
// Caster took 5 damage: 20 - 5 = 15
assert_eq si_caster.hp, 15


// ── resolve_round: declared spell uses CastSpell path ───────────
// Spell is consumed at cast start, then resolves at completion.
rolls clear

spawn Character rs_success_caster { name: "Round Spell Success", classes: [ClassLevel { class: Cleric, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 10 }, Spellcasting { spell_slots: [2], slots_used: [0], memorised_spells: [] } }

do MemoriseSpell(rs_success_caster, CureLightWounds, 1)
assert_eq rs_success_caster.Spellcasting.memorised_spells.len(), 1
assert_eq rs_success_caster.Spellcasting.slots_used[0], 1

let rs_success_init = InitiativeResult { party_roll: 2, monster_roll: 6, party_segment: 2, monster_segment: 6, simultaneous: false }
let rs_success_action = build_round_action(rs_success_caster, CastSpellAction, 2, true, none, none, none, none, 0ft, 5, 0, some(CureLightWounds), [rs_success_caster])

// Cure Light Wounds heals 4 at completion: 10 + 4 = 14.
rolls 4
call resolve_round(1, [rs_success_caster], rs_success_init, [rs_success_action])

assert_eq rs_success_caster.hp, 14
assert_eq rs_success_caster.Spellcasting.memorised_spells.len(), 0
assert_eq rs_success_caster.Spellcasting.slots_used[0], 0
assert_no_condition rs_success_caster, CastingSpell


// ── resolve_round: interrupted declared spell is lost ───────────
// Damage before completion removes CastingSpell and prevents effect.
rolls clear

spawn Character rs_interrupt_caster { name: "Round Spell Interrupted", classes: [ClassLevel { class: Cleric, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 12 }, Spellcasting { spell_slots: [2], slots_used: [0], memorised_spells: [] } }
spawn Character rs_interrupt_foe { name: "Spell Breaker", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 24, hp: 24 }, EquipmentSlots {} }

do MemoriseSpell(rs_interrupt_caster, CureLightWounds, 1)
let rs_interrupt_init = InitiativeResult { party_roll: 2, monster_roll: 3, party_segment: 2, monster_segment: 3, simultaneous: false }
let rs_interrupt_spell = build_round_action(rs_interrupt_caster, CastSpellAction, 2, true, none, none, none, none, 0ft, 5, 0, some(CureLightWounds), [rs_interrupt_caster])
let rs_interrupt_attack = build_round_action(rs_interrupt_foe, MeleeAttackAction, 3, false, some(rs_interrupt_caster), some(SwordLong))

// Foe hits for 5 on segment 3; the queued heal must never resolve.
rolls 18 5 4
call resolve_round(1, [rs_interrupt_caster, rs_interrupt_foe], rs_interrupt_init, [rs_interrupt_spell, rs_interrupt_attack])

assert_eq rs_interrupt_caster.hp, 7
assert_eq rs_interrupt_caster.Spellcasting.memorised_spells.len(), 0
assert_eq rs_interrupt_caster.Spellcasting.slots_used[0], 0
assert_no_condition rs_interrupt_caster, CastingSpell


// ── resolve_round: blocked declared spell never starts ──────────
// Spellcasting gates such as Grappling must prevent both start and effect.
rolls clear

spawn Character rs_blocked_caster { name: "Round Spell Blocked", classes: [ClassLevel { class: Cleric, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 12 }, Spellcasting { spell_slots: [2], slots_used: [0], memorised_spells: [] } }
spawn Character rs_blocked_grappler { name: "Grappler", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 24, hp: 24 } }

do MemoriseSpell(rs_blocked_caster, CureLightWounds, 1)
call apply_condition(rs_blocked_caster, Grappling(opponent: rs_blocked_grappler, hold: ArmGrab, is_controlling: false, hold_roll: 4), Duration.Indefinite)

let rs_blocked_init = InitiativeResult { party_roll: 2, monster_roll: 6, party_segment: 2, monster_segment: 6, simultaneous: false }
let rs_blocked_spell = build_round_action(rs_blocked_caster, CastSpellAction, 2, true, none, none, none, none, 0ft, 5, 0, some(CureLightWounds), [rs_blocked_caster])

// If CastSpell gating is honored, no healing occurs and the memorised spell remains.
rolls 4
call resolve_round(1, [rs_blocked_caster], rs_blocked_init, [rs_blocked_spell])

assert_eq rs_blocked_caster.hp, 12
assert_eq rs_blocked_caster.Spellcasting.memorised_spells.len(), 1
assert_eq rs_blocked_caster.Spellcasting.slots_used[0], 1
assert_no_condition rs_blocked_caster, CastingSpell


// ══════════════════════════════════════════════════════════════════
//  MONSTER INITIATIVE INTEGRATION TESTS
//
//  Tests that the initiative system handles Monster combatants:
//  is_alive, build_round_action, resolve_action, resolve_round,
//  expire_conditions, and process_periodic_conditions.
// ══════════════════════════════════════════════════════════════════

// ── is_alive derive ──────────────────────────────────────────────

spawn Character alive_char { name: "Alive", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character dead_char { name: "Dead", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 0 } }
spawn Monster alive_orc { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }
spawn Monster dead_orc { name: "Dead Orc", hit_dice: 1d8, max_hp: 8, hp: 0, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }

assert_eq is_alive(alive_char), true
assert_eq is_alive(dead_char), false
assert_eq is_alive(alive_orc), true
assert_eq is_alive(dead_orc), false


// ── build_round_action with Monster combatant ────────────────────

spawn Monster bra_ogre { name: "Ogre", hit_dice: 4d8 + 1, max_hp: 26, hp: 26, ac: 15, attacks: [MonsterAttack { name: "Club", damage: 1d10 }] }
spawn Character bra_target { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }

// Monster natural melee action at initiative segment 3
let bra_ma = build_round_action(bra_ogre, MeleeAttackAction, 3, false, some(bra_target), none, none, some(MonsterAttack { name: "Club", damage: 1d10 }))
assert_eq bra_ma.combatant, bra_ogre
assert_eq bra_ma.segment, 3
assert_eq bra_ma.action_type, DeclaredActionType.MeleeAttackAction
assert_eq bra_ma.party_side, false
assert_eq bra_ma.monster_attack.is_some(), true


// ── resolve_action: Monster natural melee attack ─────────────────
rolls clear

spawn Monster ra_ogre { name: "Ogre", hit_dice: 4d8 + 1, max_hp: 26, hp: 26, ac: 15, attacks: [MonsterAttack { name: "Club", damage: 1d10 }] }
spawn Character ra_victim { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

let ra_monster_action = build_round_action(ra_ogre, MeleeAttackAction, 4, false, some(ra_victim), none, none, some(MonsterAttack { name: "Club", damage: 1d10 }))

// Roll 18 hits, damage 7
rolls 18 7
call resolve_action(ra_monster_action, [ra_monster_action])
assert_eq ra_victim.hp, 13


// ── resolve_action: Character melee attack vs Monster ────────────
rolls clear

spawn Character ra_fighter { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots {} }
spawn Monster ra_target_orc { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }

let ra_char_action = build_round_action(ra_fighter, MeleeAttackAction, 3, true, some(ra_target_orc), some(SwordLong))

// Roll 16 hits, damage 5
rolls 16 5
call resolve_action(ra_char_action, [ra_char_action])
assert_eq ra_target_orc.hp, 3


// ── resolve_round: mixed Character + Monster combat ──────────────
// Party wins initiative (2 vs 5). Fighter attacks orc, orc attacks fighter.
// Party side resolves first within each segment.
rolls clear

spawn Character rr_fighter { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots {} }
spawn Monster rr_orc { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }

let rr_init = InitiativeResult { party_roll: 2, monster_roll: 5, party_segment: 2, monster_segment: 5, simultaneous: false }
let rr_fighter_action = build_round_action(rr_fighter, MeleeAttackAction, 2, true, some(rr_orc), some(SwordLong))
let rr_orc_action = build_round_action(rr_orc, MeleeAttackAction, 5, false, some(rr_fighter), none, none, some(MonsterAttack { name: "Club", damage: 1d6 }))

// Fighter hits in segment 2 (roll 15, damage 6), orc hits in segment 5 (roll 17, damage 4)
rolls 15 6 17 4
call resolve_round(1, [rr_fighter, rr_orc], rr_init, [rr_fighter_action, rr_orc_action])

// Fighter: 30 - 4 = 26
assert_eq rr_fighter.hp, 26
// Orc: 8 - 6 = 2
assert_eq rr_orc.hp, 2


// ── resolve_round: Monster kills target, simultaneous initiative ──
// Both act in segment 3. Speed factor breaks tie: dagger (SF 2) before club.
rolls clear

spawn Character rr2_rogue { name: "Rogue", classes: [ClassLevel { class: Thief, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 16, CON: 12, CHA: 12 }, HitPoints { max_hp: 15, hp: 15 }, EquipmentSlots {} }
spawn Monster rr2_goblin { name: "Goblin", hit_dice: 1d8 - 1, max_hp: 3, hp: 3, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }

let rr2_init = InitiativeResult { party_roll: 3, monster_roll: 3, party_segment: 3, monster_segment: 3, simultaneous: true }

// Goblin natural attack SF=0, rogue dagger SF=2. Lower SF acts first,
// so goblin strikes before rogue in simultaneous initiative.
let rr2_rogue_action = build_round_action(rr2_rogue, MeleeAttackAction, 3, true, some(rr2_goblin), some(Dagger))
let rr2_goblin_action = build_round_action(rr2_goblin, MeleeAttackAction, 3, false, some(rr2_rogue), none, none, some(MonsterAttack { name: "Club", damage: 1d6 }))

// Goblin hits rogue first (roll 18, damage 4), rogue hits goblin second (roll 15, damage 3)
rolls 18 4 15 3
call resolve_round(1, [rr2_rogue, rr2_goblin], rr2_init, [rr2_rogue_action, rr2_goblin_action])

// Goblin killed: 3 - 3 = 0
assert_eq rr2_goblin.hp, 0
assert_condition rr2_goblin, Dead
// Rogue took goblin's hit first: 15 - 4 = 11
assert_eq rr2_rogue.hp, 11


// ── resolve_action: Monster charge via initiative ────────────────
// Armed monster charges Character through the initiative system.
rolls clear

spawn Monster rmc_ogre { name: "Ogre", hit_dice: 4d8 + 1, max_hp: 26, hp: 26, ac: 15, attacks: [MonsterAttack { name: "Club", damage: 1d10 }], EquipmentSlots {} }
spawn Character rmc_victim { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

let rmc_charge = build_round_action(rmc_ogre, ChargeAction, 4, false, some(rmc_victim), some(SwordLong))

// Roll 12 + BTHB 5 + charge 2 = 19 >= 14, damage 6
rolls 12 6
call resolve_action(rmc_charge, [rmc_charge])
assert_eq rmc_victim.hp, 14
assert_condition rmc_ogre, ChargeRecovery


// ── resolve_action: Monster charge with set weapon opposition ────
// Character sets spear against charging monster. Spear is longer than
// sword, so defender strikes first with double damage.
rolls clear

spawn Monster rmc2_orc { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Sword", damage: 1d8 }], EquipmentSlots {} }
spawn Character rmc2_defender { name: "Defender", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots {} }

let rmc2_charge = build_round_action(rmc2_orc, ChargeAction, 3, false, some(rmc2_defender), some(SwordLong))
let rmc2_set = build_round_action(rmc2_defender, SetAgainstChargeAction, 1, true, some(rmc2_orc), some(Spear))

// Defender set weapon hit (roll 15, damage 4 → doubled to 8), orc charge hit (roll 16, damage 5)
rolls 15 4 16 5
call resolve_action(rmc2_charge, [rmc2_charge, rmc2_set])
// Orc takes doubled set weapon damage: 8 → dead (8 - 8 = 0)
assert_eq rmc2_orc.hp, 0
assert_condition rmc2_orc, Dead
// Defender unscathed (orc died before charging)
assert_eq rmc2_defender.hp, 30


// ── resolve_action: Set weapon still wins vs longer charger ─────
rolls clear

spawn Monster rmc3_lancer { name: "Lancer", hit_dice: 1d8 + 1, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Lance", damage: 1d8 }], EquipmentSlots {} }
spawn Character rmc3_defender { name: "Pikeman", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots {} }

let rmc3_charge = build_round_action(rmc3_lancer, ChargeAction, 3, false, some(rmc3_defender), some(Lance))
let rmc3_set = build_round_action(rmc3_defender, SetAgainstChargeAction, 1, true, some(rmc3_lancer), some(Javelin))

// Even though the charge weapon is longer, the set weapon strikes first.
rolls 15 4 16 5
call resolve_action(rmc3_charge, [rmc3_charge, rmc3_set])
assert_eq rmc3_lancer.hp, 0
assert_condition rmc3_lancer, Dead
assert_eq rmc3_defender.hp, 30


// ── resolve_round: Monster charges in full round ─────────────────
// Monster side charges, party side does melee. Initiative: party 2, monster 4.
rolls clear

spawn Monster rrmc_hobgoblin { name: "Hobgoblin", hit_dice: 1d8 + 1, max_hp: 8, hp: 8, ac: 15, attacks: [MonsterAttack { name: "Sword", damage: 1d8 }], EquipmentSlots {} }
spawn Character rrmc_fighter { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots {} }

let rrmc_init = InitiativeResult { party_roll: 2, monster_roll: 4, party_segment: 2, monster_segment: 4, simultaneous: false }
let rrmc_fighter_action = build_round_action(rrmc_fighter, MeleeAttackAction, 2, true, some(rrmc_hobgoblin), some(SwordLong))
let rrmc_hob_action = build_round_action(rrmc_hobgoblin, ChargeAction, 4, false, some(rrmc_fighter), some(SwordLong))

// Fighter hits in segment 2 (roll 14, damage 5), hobgoblin charges in segment 4 (roll 15, damage 4)
rolls 14 5 15 4
call resolve_round(1, [rrmc_fighter, rrmc_hobgoblin], rrmc_init, [rrmc_fighter_action, rrmc_hob_action])

// Fighter: 30 - 4 = 26
assert_eq rrmc_fighter.hp, 26
// Hobgoblin: 8 - 5 = 3
assert_eq rrmc_hobgoblin.hp, 3
assert_condition rrmc_hobgoblin, ChargeRecovery


// ── resolve_action: Monster natural-weapon charge via initiative ──
// Bear with natural Claw attack charges through initiative system.
rolls clear

spawn Monster rnc_bear { name: "Bear", hit_dice: 5d8, max_hp: 30, hp: 30, ac: 14, attacks: [MonsterAttack { name: "Claw", damage: 1d8 }, MonsterAttack { name: "Bite", damage: 2d6 }] }
spawn Character rnc_victim { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

let rnc_charge = build_round_action(rnc_bear, ChargeAction, 4, false, some(rnc_victim), none, none, some(MonsterAttack { name: "Claw", damage: 1d8 }))

// Roll 10 + BTHB 5 + charge 2 = 17 >= 14, damage 6
rolls 10 6
call resolve_action(rnc_charge, [rnc_charge])
assert_eq rnc_victim.hp, 14
assert_condition rnc_bear, ChargeRecovery
assert_condition rnc_bear, Charging


// ── resolve_round: Monster natural charge in full round ──────────
// Natural-weapon monster charges, party does melee. Initiative: party 2, monster 4.
rolls clear

spawn Monster rrnc_wolf { name: "Wolf", hit_dice: 2d8 + 2, max_hp: 12, hp: 12, ac: 13, attacks: [MonsterAttack { name: "Bite", damage: 1d4 + 1 }] }
spawn Character rrnc_fighter { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 }, EquipmentSlots {} }

let rrnc_init = InitiativeResult { party_roll: 2, monster_roll: 4, party_segment: 2, monster_segment: 4, simultaneous: false }
let rrnc_fighter_action = build_round_action(rrnc_fighter, MeleeAttackAction, 2, true, some(rrnc_wolf), some(SwordLong))
let rrnc_wolf_action = build_round_action(rrnc_wolf, ChargeAction, 4, false, some(rrnc_fighter), none, none, some(MonsterAttack { name: "Bite", damage: 1d4 + 1 }))

// Fighter hits in segment 2 (roll 14, damage 5), wolf charges in segment 4 (roll 12, damage roll 4 → 4+1=5)
rolls 14 5 12 4
call resolve_round(1, [rrnc_fighter, rrnc_wolf], rrnc_init, [rrnc_fighter_action, rrnc_wolf_action])

// Fighter: 30 - 5 = 25
assert_eq rrnc_fighter.hp, 25
// Wolf: 12 - 5 = 7
assert_eq rrnc_wolf.hp, 7
assert_condition rrnc_wolf, ChargeRecovery


// ── expire_conditions: EndOfRound removed from Monster ───────────

spawn Monster ec_orc { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }
call apply_condition(ec_orc, Charging, Duration.EndOfRound)
assert_condition ec_orc, Charging
call expire_conditions([ec_orc])
assert_no_condition ec_orc, Charging


// ── RoundEndDamage event: Bleeding skips Monsters ────────────────
// Monsters die at 0 HP — they don't use the bleeding/unconscious system.

spawn Monster pb_orc { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 3, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }
// Manually apply Bleeding to a monster (shouldn't happen in practice, but tests the guard)
call apply_condition(pb_orc, Bleeding, Duration.Indefinite)
emit RoundEndDamage(combatant: pb_orc)
// Monster hp unchanged — Bleeding handler has `if bearer is Character` guard
assert_eq pb_orc.hp, 3


// ══════════════════════════════════════════════════════════════════
//  UNARMED COMBAT INITIATIVE INTEGRATION TESTS
//
//  Tests that BrawlingAction, GrappleAction, and OverbearAction
//  are wired into resolve_action with the fend-off pipeline,
//  condition application, grapple follow-up, and temp healing.
// ══════════════════════════════════════════════════════════════════

// ── action_segment: unarmed types equal initiative segment ────

assert_eq action_segment(3, BrawlingAction), 3
assert_eq action_segment(3, GrappleAction), 3
assert_eq action_segment(3, OverbearAction), 3
assert_eq action_segment(5, BrawlingAction), 5
assert_eq action_segment(1, OverbearAction), 1

// ── entity_movement + combat_movement_rate: Character vs Monster ──

spawn Character cmr_human { name: "Human", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Monster cmr_orc { name: "Orc", hit_dice: 1d8, max_hp: 8, hp: 8, ac: 14, attacks: [MonsterAttack { name: "Club", damage: 1d6 }] }
spawn Monster cmr_fast { name: "Fast Beast", hit_dice: 2d8, max_hp: 12, hp: 12, ac: 12, base_movement: 180ft, attacks: [MonsterAttack { name: "Claw", damage: 1d6 }] }

// entity_movement returns Feet
assert_eq entity_movement(cmr_human), 120ft
assert_eq entity_movement(cmr_orc), 120ft
assert_eq entity_movement(cmr_fast), 180ft

// combat_movement_rate returns int (for table lookups)
assert_eq combat_movement_rate(cmr_human), 120
assert_eq combat_movement_rate(cmr_orc), 120
assert_eq combat_movement_rate(cmr_fast), 180


// ── resolve_action: BrawlingAction — unarmed target, no fend-off ──
// Both unarmed. No fend-off attempt. MeleeAttack with FistOrKick (1d2).
rolls clear

spawn Character brawl_atk { name: "Brawler", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character brawl_tgt { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

let brawl_action = build_round_action(brawl_atk, BrawlingAction, 3, true, some(brawl_tgt))

// d20=18 (hit), d2=2 (FistOrKick damage)
rolls 18 2
call resolve_action(brawl_action, [brawl_action])
assert_eq brawl_tgt.hp, 18


// ── resolve_action: BrawlingAction — armed target fends off ───────
// Target has SwordLong wielded. Fend-off succeeds, blocking the brawl.
rolls clear

spawn Character brawl2_atk { name: "Brawler", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character brawl2_tgt { name: "Defender", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }

let brawl2_action = build_round_action(brawl2_atk, BrawlingAction, 3, true, some(brawl2_tgt))

// Fend-off: d20=15 (BTHB=4, 15+4=19 >= attacker AC 10 → hit), d8=6 (damage consumed)
// Fend-off succeeds → brawl blocked. No further rolls consumed.
rolls 15 6
call resolve_action(brawl2_action, [brawl2_action])
// Target HP unchanged — brawling was fended off
assert_eq brawl2_tgt.hp, 20


// ── resolve_action: BrawlingAction — fend-off misses ─────────────
// Armed target tries fend-off but misses. Brawling attack proceeds.
rolls clear

spawn Character brawl3_atk { name: "Brawler", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character brawl3_tgt { name: "Defender", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }

let brawl3_action = build_round_action(brawl3_atk, BrawlingAction, 3, true, some(brawl3_tgt))

// Fend-off: d20=1 (natural 1 always misses) → fend-off fails
// Brawl: d20=18 (hit), d2=1 (damage)
rolls 1 18 1
call resolve_action(brawl3_action, [brawl3_action])
assert_eq brawl3_tgt.hp, 19


// ── resolve_action: GrappleAction — success, holds established ───
// Both unarmed. No fend-off. Grapple succeeds, both get Grappling.
rolls clear

spawn Character grap_atk { name: "Grappler", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character grap_tgt { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

let grap_action = build_round_action(grap_atk, GrappleAction, 3, true, some(grap_tgt))

// d20=15 (unarmed to-hit → hit), d8=5 (grapple results: modified=5, WaistLock)
// grappling_temp_damage(5)=4, grappling_real_damage(5)=1
rolls 15 5
call resolve_action(grap_action, [grap_action])
assert_condition grap_atk, Grappling
assert_condition grap_tgt, Grappling
// Target took: 4 temp + 1 real damage → hp = 20 - 1 = 19, temp_damage = 4
assert_eq grap_tgt.hp, 19
assert_eq grap_tgt.temp_damage, 4


// ── resolve_action: GrappleAction — armed target fends off ───────
rolls clear

spawn Character grap2_atk { name: "Grappler", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character grap2_tgt { name: "Defender", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }

let grap2_action = build_round_action(grap2_atk, GrappleAction, 3, true, some(grap2_tgt))

// Fend-off: d20=15, d8=6 → hit → fend-off succeeds
rolls 15 6
call resolve_action(grap2_action, [grap2_action])
assert_no_condition grap2_atk, Grappling
assert_no_condition grap2_tgt, Grappling
assert_eq grap2_tgt.hp, 20


// ── resolve_action: OverbearAction — TotalFailure (attacker Prone) ──
// d6=1 → modified=1 → TotalFailure. Attacker falls prone, no damage.
rolls clear

spawn Character ob_tf_atk { name: "Overbear", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character ob_tf_tgt { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

let ob_tf_action = build_round_action(ob_tf_atk, OverbearAction, 3, true, some(ob_tf_tgt))

// d20=15 (unarmed to-hit → hit), d6=1 → TotalFailure
rolls 15 1
call resolve_action(ob_tf_action, [ob_tf_action])
assert_condition ob_tf_atk, Prone
assert_no_condition ob_tf_tgt, Prone
assert_eq ob_tf_tgt.hp, 20


// ── resolve_action: OverbearAction — PartialSuccess (target Staggered) ──
// d6=3 → modified=3 → PartialSuccess. Target gets Staggered, no damage.
rolls clear

spawn Character ob_ps_atk { name: "Overbear", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character ob_ps_tgt { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

let ob_ps_action = build_round_action(ob_ps_atk, OverbearAction, 3, true, some(ob_ps_tgt))

// d20=15 (hit), d6=3 → PartialSuccess
rolls 15 3
call resolve_action(ob_ps_action, [ob_ps_action])
assert_condition ob_ps_tgt, Staggered
assert_no_condition ob_ps_tgt, Prone
assert_eq ob_ps_tgt.hp, 20


// ── resolve_action: OverbearAction — Success (target Prone + Overborne) ──
// d6=5 → modified=5 → Success. temp=4, real=1.
rolls clear

spawn Character ob_s_atk { name: "Overbear", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character ob_s_tgt { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

let ob_s_action = build_round_action(ob_s_atk, OverbearAction, 3, true, some(ob_s_tgt))

// d20=15 (hit), d6=5 → Success: temp=max(0,5-1)=4, real=1
rolls 15 5
call resolve_action(ob_s_action, [ob_s_action])
assert_condition ob_s_tgt, Prone
assert_condition ob_s_tgt, Overborne
assert_eq ob_s_tgt.hp, 19
assert_eq ob_s_tgt.temp_damage, 4


// ── resolve_action: OverbearAction — TotalSuccess with grapple follow-up ──
// STR 16 → overbearing_attacker_str_mod=+1. d6=6+1=7 → TotalSuccess.
// temp=max(0,7-2)=5, real=2. Then immediate GrapplingAttack with +2 bonus.
rolls clear

spawn Character ob_ts_atk { name: "Overbear", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 16, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character ob_ts_tgt { name: "Victim", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }

let ob_ts_action = build_round_action(ob_ts_atk, OverbearAction, 3, true, some(ob_ts_tgt))

// Overbear: d20=15 (hit), d6=6 → modified=6+1=7 → TotalSuccess
// temp=5, real=2, grappling_followup_bonus=2
// Grapple follow-up: d20=15 (hit), d8=4 → modified=4 → ArmGrab
// grappling_temp_damage(4)=3, grappling_real_damage(4)=1
rolls 15 6 15 4
call resolve_action(ob_ts_action, [ob_ts_action])
// Overbearing conditions
assert_condition ob_ts_tgt, Prone
assert_condition ob_ts_tgt, Overborne
// Grappling conditions from follow-up
assert_condition ob_ts_atk, Grappling
assert_condition ob_ts_tgt, Grappling
// Damage: overbear real=2, grapple real=1 → hp = 30-2-1 = 27
assert_eq ob_ts_tgt.hp, 27
// Temp: overbear temp=5, grapple temp=3 → 8
assert_eq ob_ts_tgt.temp_damage, 8


// ── resolve_action: OverbearAction — armed target fends off ──────
rolls clear

spawn Character ob_fo_atk { name: "Overbear", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character ob_fo_tgt { name: "Defender", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, EquipmentSlots { wielded_main: some(Melee(SwordLong)) } }

let ob_fo_action = build_round_action(ob_fo_atk, OverbearAction, 3, true, some(ob_fo_tgt))

// Fend-off: d20=15, d8=6 → hit → fend-off succeeds
rolls 15 6
call resolve_action(ob_fo_action, [ob_fo_action])
assert_no_condition ob_fo_tgt, Prone
assert_no_condition ob_fo_tgt, Overborne
assert_no_condition ob_fo_atk, Prone
assert_eq ob_fo_tgt.hp, 20


// ── process_temp_healing in resolve_round ────────────────────────
// Character with temp_damage recovers 1 HP of temp at end of round.
rolls clear

spawn Character th_fighter { name: "Fighter", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
set th_fighter.temp_damage = 5

let th_init = InitiativeResult { party_roll: 3, monster_roll: 5, party_segment: 3, monster_segment: 5, simultaneous: false }

// Empty action list — just run end-of-round bookkeeping
call resolve_round(1, [th_fighter], th_init, [])
// temp_damage should decrease by 1: 5 → 4
assert_eq th_fighter.temp_damage, 4

// Run another round
call resolve_round(2, [th_fighter], th_init, [])
assert_eq th_fighter.temp_damage, 3


// ── resolve_round: unarmed combat in full round ──────────────────
// Brawler attacks in segment 3, target does melee in segment 5.
// Both sides resolve in order. Verifies unarmed actions work in
// the full segment loop, not just isolated resolve_action calls.
rolls clear

spawn Character rr_brawler { name: "Brawler", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 30, hp: 30 } }
spawn Character rr_defender { name: "Defender", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 }, EquipmentSlots {} }

let rr_uc_init = InitiativeResult { party_roll: 3, monster_roll: 5, party_segment: 3, monster_segment: 5, simultaneous: false }
let rr_brawl = build_round_action(rr_brawler, BrawlingAction, 3, true, some(rr_defender))
let rr_melee = build_round_action(rr_defender, MeleeAttackAction, 5, false, some(rr_brawler), some(SwordLong))

// Brawl at segment 3: d20=18 (hit), d2=2 (damage)
// Melee at segment 5: d20=14 (hit), d8=5 (damage)
rolls 18 2 14 5
call resolve_round(1, [rr_brawler, rr_defender], rr_uc_init, [rr_brawl, rr_melee])

// Defender: 20 - 2 = 18
assert_eq rr_defender.hp, 18
// Brawler: 30 - 5 = 25
assert_eq rr_brawler.hp, 25
