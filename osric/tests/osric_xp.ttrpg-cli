// OSRIC XP Award Calculation integration tests
//
// Tests xp_hd_tier derive, monster_xp_row table,
// calculate_monster_xp derive, treasure/magic item XP,
// and party XP share with prime requisite bonus.
//
// Reference: OSRIC 3.0 GM Guide, §2.1.4 Table 2.1.4a (p.7)

load osric/*.ttrpg

// ── xp_hd_tier: sub-d8 and weak monsters → tier 0 ───────────

assert_eq xp_hd_tier(0d8), 0
assert_eq xp_hd_tier(1d4), 0
assert_eq xp_hd_tier(1d6), 0
assert_eq xp_hd_tier(1d8 - 2), 0

// ── xp_hd_tier: 1-1 to 1 HD → tier 1 ───────────────────────

assert_eq xp_hd_tier(1d8 - 1), 1
assert_eq xp_hd_tier(1d8), 1

// ── xp_hd_tier: 1+1 to 2 HD → tier 2 ───────────────────────

assert_eq xp_hd_tier(1d8 + 1), 2
assert_eq xp_hd_tier(2d8), 2

// ── xp_hd_tier: mid-range tiers ─────────────────────────────

assert_eq xp_hd_tier(2d8 + 1), 3
assert_eq xp_hd_tier(3d8), 3
assert_eq xp_hd_tier(3d8 + 1), 4
assert_eq xp_hd_tier(5d8), 5
assert_eq xp_hd_tier(5d8 + 3), 6
assert_eq xp_hd_tier(8d8), 8
assert_eq xp_hd_tier(8d8 + 1), 9

// ── xp_hd_tier: high-HD tiers ───────────────────────────────

assert_eq xp_hd_tier(10d8), 10
assert_eq xp_hd_tier(10d8 + 1), 11
assert_eq xp_hd_tier(15d8), 15
assert_eq xp_hd_tier(21d8), 21
assert_eq xp_hd_tier(21d8 + 1), 22
assert_eq xp_hd_tier(25d8), 25

// ── monster_xp_row: spot checks on table values ─────────────

let row0 = monster_xp_row(0)
assert_eq row0.base, 5
assert_eq row0.special, 3
assert_eq row0.exceptional, 25
assert_eq row0.per_hp, 1

let row4 = monster_xp_row(4)
assert_eq row4.base, 75
assert_eq row4.special, 30
assert_eq row4.exceptional, 70
assert_eq row4.per_hp, 3

let row9 = monster_xp_row(9)
assert_eq row9.base, 600
assert_eq row9.special, 300
assert_eq row9.exceptional, 400
assert_eq row9.per_hp, 12

let row21 = monster_xp_row(21)
assert_eq row21.base, 4500
assert_eq row21.special, 2350
assert_eq row21.exceptional, 2750
assert_eq row21.per_hp, 33

// Wildcard tier (21+1 and up)
let row99 = monster_xp_row(99)
assert_eq row99.base, 5000

// ── calculate_monster_xp: GMG example (§2.1.4) ──────────────
// "3 hit die monster with one Special and one Exceptional ability"
// Base 50 + Special 15 + Exceptional 60 = 125, plus 2/hp.
// With 14 hp: 125 + 28 = 153

assert_eq calculate_monster_xp(3d8, 14, 1, 1), 153

// ── calculate_monster_xp: simple 1 HD monster, no abilities ──

assert_eq calculate_monster_xp(1d8, 4), 14

// ── calculate_monster_xp: weak sub-d8 monster ────────────────

assert_eq calculate_monster_xp(1d4, 2), 7

// ── calculate_monster_xp: powerful monster ───────────────────
// 8 HD, 36 hp, 2 special, 1 exceptional
// Tier 8: base 350 + 200*2 + 300*1 + 10*36 = 1410

assert_eq calculate_monster_xp(8d8, 36, 2, 1), 1410

// ── calculate_monster_xp: dragon-class (10+1 HD) ────────────
// 10d8+1 → tier 11: base 900 + 500*2 + 600*1 + 14*50 = 3200

assert_eq calculate_monster_xp(10d8 + 1, 50, 2, 1), 3200

// ── calculate_monster_xp: max tier (21+ HD) ─────────────────
// 25d8, 100 hp, 3 special, 2 exceptional
// Tier 25 → wildcard: base 5000 + 2600*3 + 3000*2 + 35*100 = 22300

assert_eq calculate_monster_xp(25d8, 100, 3, 2), 22300

// ── treasure_xp ──────────────────────────────────────────────

assert_eq treasure_xp(0), 0
assert_eq treasure_xp(500), 500
assert_eq treasure_xp(10000), 10000

// ── magic_item_xp: standard items ───────────────────────────

assert_eq magic_item_xp(1000), 100
assert_eq magic_item_xp(500), 50
assert_eq magic_item_xp(5000), 500

// ── magic_item_xp: potions (half rate) ──────────────────────

assert_eq magic_item_xp(1000, true), 50
assert_eq magic_item_xp(500, true), 25

// ── kept_item_xp: inventory uses per-item kept rates ─────────

let gem = Item { name: "Gem", weight: 0, gp_value: 500 }
let ring = Item { name: "Magic Ring", weight: 0, gp_value: 1000, kept_xp_divisor: 10 }
let potion = potion_item(Healing)
let divine_scroll = spell_scroll_item(CureLightWounds, Divine)

assert_eq kept_item_xp(gem), 500
assert_eq kept_item_xp(ring), 100
assert_eq kept_item_xp(potion), 20
assert_eq kept_item_xp(divine_scroll), floor(divine_scroll.gp_value / 10)

// ── award_item_treasure_xp: kept magic items use reduced XP ──

spawn Character loot_holder {
    name: "Loot Holder",
    classes: [ClassLevel { class: Fighter, level: 1 }],
    abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 },
    HitPoints { max_hp: 10, hp: 10 },
    Inventory {
        loose_items: [
            Item { name: "Gem", weight: 0, gp_value: 500 },
            Item { name: "Magic Ring", weight: 0, gp_value: 1000, kept_xp_divisor: 10 },
            potion_item(Healing),
            spell_scroll_item(CureLightWounds, Divine)
        ]
    }
}

let kept_xp = award_item_treasure_xp(loot_holder)
assert_eq kept_xp, 650
assert loot_holder.Inventory.loose_items[0].xp_awarded
assert loot_holder.Inventory.loose_items[1].xp_awarded
assert loot_holder.Inventory.loose_items[2].xp_awarded
assert loot_holder.Inventory.loose_items[3].xp_awarded

// ── xp_share: equal division, no bonus ──────────────────────

assert_eq xp_share(1000, 4), 250
assert_eq xp_share(1500, 4), 375

// ── xp_share: with 10% prime requisite bonus ────────────────

assert_eq xp_share(1000, 4, 10), 275
assert_eq xp_share(2000, 5, 10), 440

// ── xp_share: uneven division floors correctly ──────────────

assert_eq xp_share(1000, 3), 333
assert_eq xp_share(100, 3, 10), 36
