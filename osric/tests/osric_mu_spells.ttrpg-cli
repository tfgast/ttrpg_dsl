spawn Monster scare_target_2 { name: "Brave Orc", hit_dice: 1d8, max_hp: 6, hp: 6, ac: 14, morale: 7, morale_checks_made: 0, xp_value: 0, intelligence: 1, attacks: [MonsterAttack { name: "Club", damage: 1d6 }], size: Medium, special: [] }

