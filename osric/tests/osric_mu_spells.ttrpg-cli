// ══════════════════════════════════════════════════════════════
//  MOVEMENT BUFF SPELLS
// ══════════════════════════════════════════════════════════════

// ── MovementMode enum & get_movement_speed ────────────────────

// Walk speed delegates to entity_movement
spawn Character mv_fighter { name: "MV Fighter", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
assert_eq get_movement_speed(mv_fighter, Walk).value, 120
assert_eq get_movement_speed(mv_fighter, Fly).value, 0
assert_eq get_movement_speed(mv_fighter, Climb).value, 0
assert_eq get_movement_speed(mv_fighter, Levitate).value, 0
assert (has_movement_mode(mv_fighter, Walk)) == true
assert (has_movement_mode(mv_fighter, Fly)) == false

// Monster with extra movement modes
spawn Monster mv_dragon { name: "MV Dragon", hit_dice: 10d8, max_hp: 50, hp: 50, ac: 18, morale: 10, morale_checks_made: 0, xp_value: 0, intelligence: 12, base_movement: 90ft, movement_modes: { Fly: 240ft }, attacks: [MonsterAttack { name: "Bite", damage: 3d8 }], size: Huge, special: [] }
assert_eq get_movement_speed(mv_dragon, Walk).value, 90
assert_eq get_movement_speed(mv_dragon, Fly).value, 240
assert (has_movement_mode(mv_dragon, Fly)) == true
assert (has_movement_mode(mv_dragon, Swim)) == false

// Monster with swim speed
spawn Monster mv_shark { name: "MV Shark", hit_dice: 5d8, max_hp: 25, hp: 25, ac: 14, morale: 8, morale_checks_made: 0, xp_value: 0, intelligence: 1, base_movement: 0ft, movement_modes: { Swim: 180ft }, attacks: [MonsterAttack { name: "Bite", damage: 2d6 }], size: Large, special: [] }
assert_eq get_movement_speed(mv_shark, Walk).value, 0
assert_eq get_movement_speed(mv_shark, Swim).value, 180
assert (has_movement_mode(mv_shark, Swim)) == true

// ── Feather Fall SpellDef ─────────────────────────────────────

assert_eq FEATHER_FALL_DEF.level, 1
assert_eq FEATHER_FALL_DEF.school, SpellSchool.Transmutation

// ── Feather Fall resolve: condition applied ──────────────────

spawn Character ff_caster { name: "FF Caster", classes: [ClassLevel { class: MagicUser, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 8, hp: 8 } }
spawn Character ff_target { name: "FF Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
call resolve_feather_fall(ff_caster, [ff_target])
assert_condition ff_target, FeatherFalling

// ── Feather Fall via FinishCasting ──────────────────────────

spawn Character ff_dispatch_caster { name: "FF Dispatch", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 } }
spawn Character ff_dispatch_target { name: "FF Dispatch Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
do ff_dispatch_caster.FinishCasting(id: FeatherFall, targets: [ff_dispatch_target])
assert_condition ff_dispatch_target, FeatherFalling

// ── Spider Climb SpellDef ─────────────────────────────────────

assert_eq SPIDER_CLIMB_DEF.level, 1
assert_eq SPIDER_CLIMB_DEF.school, SpellSchool.Transmutation

// ── Spider Climb resolve: grants climb speed ────────────────

spawn Character sc_caster { name: "SC Caster", classes: [ClassLevel { class: MagicUser, level: 3 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 8, hp: 8 } }
spawn Character sc_target { name: "SC Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

// No climb speed before spell
assert_eq get_movement_speed(sc_target, Climb).value, 0

rolls clear
// Touch attack d20=18 (hit)
rolls 18
do sc_caster.FinishCasting(id: SpiderClimb, targets: [sc_target])
assert_condition sc_target, SpiderClimbing

// Climb speed is now 30ft
assert_eq get_movement_speed(sc_target, Climb).value, 30
assert (has_movement_mode(sc_target, Climb)) == true

// Walk speed unchanged
assert_eq get_movement_speed(sc_target, Walk).value, 120

// ── Levitate SpellDef ─────────────────────────────────────────

assert_eq LEVITATE_DEF.level, 2
assert_eq LEVITATE_DEF.school, SpellSchool.Transmutation

// ── Levitate resolve: self-cast → 20ft/round ────────────────

spawn Character lev_self_caster { name: "Lev Self", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 } }

rolls clear
call resolve_levitate(lev_self_caster, [lev_self_caster])
assert_condition lev_self_caster, Levitating
assert_eq get_movement_speed(lev_self_caster, Levitate).value, 20

// ── Levitate resolve: other target, failed save → 10ft/round ──

spawn Character lev_other_caster { name: "Lev Other Caster", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 } }
spawn Character lev_other_target { name: "Lev Other Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
rolls 1
call resolve_levitate(lev_other_caster, [lev_other_target])
assert_condition lev_other_target, Levitating
assert_eq get_movement_speed(lev_other_target, Levitate).value, 10

// ── Levitate resolve: other target, save succeeds → no effect ──

spawn Character lev_save_caster { name: "Lev Save Caster", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 } }
spawn Character lev_save_target { name: "Lev Save Target", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
rolls 20
call resolve_levitate(lev_save_caster, [lev_save_target])
assert_no_condition lev_save_target, Levitating
assert_eq get_movement_speed(lev_save_target, Levitate).value, 0

// ── Jump SpellDef ─────────────────────────────────────────────

assert_eq JUMP_DEF.level, 1
assert_eq JUMP_DEF.school, SpellSchool.Transmutation

// ── Jump resolve: caster level 1 → 1 leap ───────────────────

spawn Character jmp_caster_1 { name: "Jump Caster L1", classes: [ClassLevel { class: MagicUser, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 4, hp: 4 } }
spawn Character jmp_target_1 { name: "Jump Target 1", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
call resolve_jump(jmp_caster_1, [jmp_target_1])
assert_condition jmp_target_1, Jumping

// Use the leap — condition should be removed after 1 use
do UseJump(jmp_target_1)
assert_no_condition jmp_target_1, Jumping

// ── Jump resolve: caster level 4 → 2 leaps ──────────────────

spawn Character jmp_caster_4 { name: "Jump Caster L4", classes: [ClassLevel { class: MagicUser, level: 4 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }
spawn Character jmp_target_4 { name: "Jump Target 4", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
call resolve_jump(jmp_caster_4, [jmp_target_4])
assert_condition jmp_target_4, Jumping

// First leap — still has condition
do UseJump(jmp_target_4)
assert_condition jmp_target_4, Jumping

// Second leap — condition removed
do UseJump(jmp_target_4)
assert_no_condition jmp_target_4, Jumping

// ── Jump resolve: caster level 7 → 3 leaps ──────────────────

spawn Character jmp_caster_7 { name: "Jump Caster L7", classes: [ClassLevel { class: MagicUser, level: 7 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 16, hp: 16 } }
spawn Character jmp_target_7 { name: "Jump Target 7", classes: [ClassLevel { class: Fighter, level: 1 }], abilities: { STR: 12, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 10, hp: 10 } }

rolls clear
call resolve_jump(jmp_caster_7, [jmp_target_7])
assert_condition jmp_target_7, Jumping

do UseJump(jmp_target_7)
assert_condition jmp_target_7, Jumping
do UseJump(jmp_target_7)
assert_condition jmp_target_7, Jumping
do UseJump(jmp_target_7)
assert_no_condition jmp_target_7, Jumping


// ══════════════════════════════════════════════════════════════
//  SHIELD (§1.8.5.1)
// ══════════════════════════════════════════════════════════════

// ── Shield SpellDef ──────────────────────────────────────────

assert_eq SHIELD_DEF.level, 1
assert_eq SHIELD_DEF.school, SpellSchool.Evocation
assert_eq SHIELD_DEF.range, SpellRange.Caster

// ── Shield resolve: applies Shielded condition ───────────────

spawn Character shd_caster_1 { name: "Shield Caster L3", classes: [ClassLevel { class: MagicUser, level: 3 }], abilities: { STR: 10, INT: 16, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 8, hp: 8 } }

rolls clear
call resolve_shield(shd_caster_1)
assert_condition shd_caster_1, Shielded

// ── Shield AC: unarmored MU (AC 10) → AC 16 ─────────────────
// DEX 12 gives no bonus, so base AC is 10. Shield sets min 16.

assert_eq effective_target_ac(shd_caster_1), 16

// ── Shield AC: missile context → AC 17 (propelled) / 18 (hurled) ──

assert_eq effective_target_ac(shd_caster_1, is_missile: true, is_hurled: false), 17
assert_eq effective_target_ac(shd_caster_1, is_missile: true, is_hurled: true), 18

// ── Shield + better armour: Shield doesn't downgrade ─────────
// A character with plate mail (AC 17) keeps 17 for melee,
// but Shield gives 18 vs hurled missiles.

spawn Character shd_armored { name: "Armored Shielder", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 }, EquipmentSlots { worn_armor: some(Armor { armour_type: PlateMail, magic_bonus: 0 }) } }

rolls clear
call resolve_shield(shd_armored)
assert_condition shd_armored, Shielded

// Plate mail = AC 17. Shield gives min 16, so plate is still used.
assert_eq effective_target_ac(shd_armored), 17

// Missile (propelled): max(17, 17) = 17
assert_eq effective_target_ac(shd_armored, is_missile: true, is_hurled: false), 17

// Missile (hurled): max(17, 18) = 18 — Shield helps here
assert_eq effective_target_ac(shd_armored, is_missile: true, is_hurled: true), 18

// ── Shield blocks Magic Missiles ─────────────────────────────

spawn Character shd_mm_caster { name: "MM Caster", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 10, INT: 16, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 } }
spawn Character shd_mm_target { name: "Shielded Target", classes: [ClassLevel { class: MagicUser, level: 3 }], abilities: { STR: 10, INT: 16, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 8, hp: 8 } }

// Apply Shield to target
rolls clear
call resolve_shield(shd_mm_target)
assert_condition shd_mm_target, Shielded

// Fire 3 magic missiles at Shielded target — no damage
rolls clear
rolls 3 2 4
call resolve_magic_missile(shd_mm_caster, [shd_mm_target, shd_mm_target, shd_mm_target])
assert_eq shd_mm_target.hp, 8


// ══════════════════════════════════════════════════════════════
//  INVISIBILITY (§1.8.5.2)
// ══════════════════════════════════════════════════════════════

// ── Invisibility SpellDef ────────────────────────────────────

assert_eq INVISIBILITY_DEF.level, 2
assert_eq INVISIBILITY_DEF.school, SpellSchool.Illusion
assert_eq INVISIBILITY_DEF.range, SpellRange.Touch

// ── Invisibility resolve: applies Invisible condition ────────

spawn Character inv_caster { name: "Invis Caster L5", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 10, INT: 16, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 } }
spawn Character inv_target { name: "Invis Target", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 20, hp: 20 } }

rolls clear
call resolve_invisibility(inv_caster, [inv_target])
assert_condition inv_target, Invisible

// ── Invisibility on self ─────────────────────────────────────

rolls clear
call resolve_invisibility(inv_caster, [inv_caster])
assert_condition inv_caster, Invisible


// ══════════════════════════════════════════════════════════════
//  STRENGTH (§1.8.5.2)
// ══════════════════════════════════════════════════════════════

// ── Strength SpellDef ────────────────────────────────────────

assert_eq STRENGTH_DEF.level, 2
assert_eq STRENGTH_DEF.school, SpellSchool.Transmutation
assert_eq STRENGTH_DEF.range, SpellRange.Touch

// ── Strength resolve: non-fighter gets d6 ────────────────────

spawn Character str_caster { name: "Str Caster L5", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 10, INT: 16, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 } }
spawn Character str_target_mu { name: "Weak Wizard", classes: [ClassLevel { class: MagicUser, level: 3 }], abilities: { STR: 10, INT: 16, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 8, hp: 8 } }

// Roll d6 = 4, no fighter bonus → STR bonus of 4
rolls clear
rolls 4
call resolve_strength(str_caster, [str_target_mu])
assert_condition str_target_mu, Strengthened

// STR was 10, now effective STR is 14
assert_eq effective_ability(str_target_mu, STR), 14

// ── Strength resolve: fighter gets d6 + 1 ────────────────────

spawn Character str_target_ftr { name: "Strong Fighter", classes: [ClassLevel { class: Fighter, level: 3 }], abilities: { STR: 15, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 25, hp: 25 } }

// Roll d6 = 3, fighter bonus +1 → STR bonus of 4
rolls clear
rolls 3
call resolve_strength(str_caster, [str_target_ftr])
assert_condition str_target_ftr, Strengthened

// STR was 15, now effective STR is 19
assert_eq effective_ability(str_target_ftr, STR), 19

// ── Strength resolve: paladin gets fighter bonus ─────────────

spawn Character str_target_pal { name: "Paladin", classes: [ClassLevel { class: Paladin, level: 4 }], abilities: { STR: 14, INT: 12, WIS: 14, DEX: 12, CON: 12, CHA: 17 }, HitPoints { max_hp: 30, hp: 30 } }

// Roll d6 = 5, paladin gets fighter bonus +1 → STR bonus of 6
rolls clear
rolls 5
call resolve_strength(str_caster, [str_target_pal])
assert_condition str_target_pal, Strengthened
assert_eq effective_ability(str_target_pal, STR), 20

// ── Strength resolve: ranger gets fighter bonus ──────────────

spawn Character str_target_rng { name: "Ranger", classes: [ClassLevel { class: Ranger, level: 3 }], abilities: { STR: 13, INT: 12, WIS: 14, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 22, hp: 22 } }

// Roll d6 = 2, ranger gets fighter bonus +1 → STR bonus of 3
rolls clear
rolls 2
call resolve_strength(str_caster, [str_target_rng])
assert_condition str_target_rng, Strengthened
assert_eq effective_ability(str_target_rng, STR), 16


// ══════════════════════════════════════════════════════════════
//  MIRROR IMAGE (§1.8.5.2)
// ══════════════════════════════════════════════════════════════

// ── Mirror Image SpellDef ─────────────────────────────────────

assert_eq MIRROR_IMAGE_DEF.level, 2
assert_eq MIRROR_IMAGE_DEF.school, SpellSchool.Illusion
assert_eq MIRROR_IMAGE_DEF.range, SpellRange.Caster

// ── Mirror Image resolve: creates condition with images ───────

spawn Character mi_caster { name: "MI Caster L5", classes: [ClassLevel { class: MagicUser, level: 5 }], abilities: { STR: 10, INT: 16, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 12, hp: 12 } }
spawn Character mi_attacker { name: "MI Attacker", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 16, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 } }

// Roll 1d4 = 3 images on apply
rolls clear
rolls 3
call resolve_mirror_image(mi_caster)
assert_condition mi_caster, MirrorImageActive

// ── Image absorbs attack: roll targets image ──────────────────
// 3 images → roll 1d4: values 1-3 = image, 4 = caster.
// TakeDamage(source: Attack) emits DamageIncoming, handler rolls targeting.
// Roll targeting = 2 → image absorbs, damage zeroed.
rolls clear
rolls 2
do mi_caster.TakeDamage(mi_attacker, 5, DamageType.Slashing, DamageSource.Attack)
assert_eq mi_caster.hp, 12
assert_condition mi_caster, MirrorImageActive

// ── Real target hit: roll misses images ───────────────────────
// 2 images left → roll 1d3: values 1-2 = image, 3 = caster.
// Roll targeting = 3 → real caster hit, full damage applied.
rolls clear
rolls 3
do mi_caster.TakeDamage(mi_attacker, 4, DamageType.Slashing, DamageSource.Attack)
assert_eq mi_caster.hp, 8
assert_condition mi_caster, MirrorImageActive

// ── Spell damage ignores mirror images ────────────────────────
// DamageSource.Spell should not trigger image absorption.
rolls clear
do mi_caster.TakeDamage(mi_attacker, 3, DamageType.Fire, DamageSource.Spell)
assert_eq mi_caster.hp, 5
assert_condition mi_caster, MirrorImageActive

// ── Destroy remaining images one by one ───────────────────────
// 2 images left. Roll = 1 → image absorbs.
rolls clear
rolls 1
do mi_caster.TakeDamage(mi_attacker, 5, DamageType.Slashing, DamageSource.Attack)
assert_eq mi_caster.hp, 5
assert_condition mi_caster, MirrorImageActive

// 1 image left. Roll = 1 → last image absorbs, condition removed.
rolls clear
rolls 1
do mi_caster.TakeDamage(mi_attacker, 5, DamageType.Slashing, DamageSource.Attack)
assert_eq mi_caster.hp, 5
assert_no_condition mi_caster, MirrorImageActive

// ── No absorption after images gone ───────────────────────────
rolls clear
do mi_caster.TakeDamage(mi_attacker, 3, DamageType.Slashing, DamageSource.Attack)
assert_eq mi_caster.hp, 2
