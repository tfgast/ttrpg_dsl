spawn Monster scare_target_immune { name: "Hill Giant", hit_dice: 8d8, max_hp: 40, hp: 40, ac: 16, morale: 10, morale_checks_made: 0, xp_value: 0, intelligence: 6, attacks: [MonsterAttack { name: "Club", damage: 2d8 }], size: Large, special: [] }

