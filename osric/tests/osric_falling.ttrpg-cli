// OSRIC falling damage integration tests
//
// Equivalent of crates/ttrpg_interp/tests/osric_falling_integration.rs
// Tests falling_damage_dice and apply_falling_damage.

load osric/*.ttrpg

// ── falling_damage_dice ───────────────────────────────────────

assert_eq falling_damage_dice(5), 0d6
assert_eq falling_damage_dice(10), 1d6
assert_eq falling_damage_dice(20), 3d6
assert_eq falling_damage_dice(30), 6d6
assert_eq falling_damage_dice(40), 10d6
assert_eq falling_damage_dice(50), 15d6
assert_eq falling_damage_dice(100), 20d6

// ── apply_falling_damage without save ─────────────────────────

rolls 3 4 5
let no_save = apply_falling_damage(
    20,
    SavingThrows {
        aimed_magic: 13,
        breath: 13,
        death_paralysis_poison: 11,
        petrification_polymorph: 12,
        spells: 14
    },
    false,
    0
)
assert_eq no_save.distance_ft, 20
assert_eq no_save.base_damage, 12
assert_eq no_save.saved, false
assert_eq no_save.damage_taken, 12

// ── apply_falling_damage with successful save ────────────────

rolls clear
rolls 2 3 4 1 2 6 15
let saved = apply_falling_damage(
    30,
    SavingThrows {
        aimed_magic: 13,
        breath: 13,
        death_paralysis_poison: 11,
        petrification_polymorph: 12,
        spells: 14
    },
    true,
    0
)
assert_eq saved.base_damage, 18
assert_eq saved.saved, true
assert_eq saved.damage_taken, 9

// ── apply_falling_damage with failed save ─────────────────────

rolls clear
rolls 3 3 3 3 3 3 5
let failed_save = apply_falling_damage(
    30,
    SavingThrows {
        aimed_magic: 13,
        breath: 13,
        death_paralysis_poison: 11,
        petrification_polymorph: 12,
        spells: 14
    },
    true,
    0
)
assert_eq failed_save.base_damage, 18
assert_eq failed_save.saved, false
assert_eq failed_save.damage_taken, 18

// ── <10ft falls do not attempt save or deal damage ───────────

rolls clear
let short_fall = apply_falling_damage(
    5,
    SavingThrows {
        aimed_magic: 13,
        breath: 13,
        death_paralysis_poison: 11,
        petrification_polymorph: 12,
        spells: 14
    },
    true,
    0
)
assert_eq short_fall.base_damage, 0
assert_eq short_fall.saved, false
assert_eq short_fall.damage_taken, 0

// ── FallDamage action (damage pipeline integration) ────────

rolls clear

// 20ft fall: 3d6 damage, rolls 3+4+5 = 12
// TakeDamage applies DamageType.Fall through the standard pipeline
spawn Character faller { name: "Faller", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 }, saving_throws: some(fighter_saves(5)) }
rolls 3 4 5
do FallDamage(faller, 20)
assert_eq faller.hp, 28

// Short fall (<10ft): no damage
rolls clear
spawn Character short_faller { name: "ShortFaller", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 }, saving_throws: some(fighter_saves(5)) }
do FallDamage(short_faller, 5)
assert_eq short_faller.hp, 40

// ── Feather Fall negates falling damage ──────────────────────

spawn Character ff_faller { name: "Feathered Faller", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 }, saving_throws: some(fighter_saves(5)) }

// Apply FeatherFalling condition
call apply_condition(ff_faller, FeatherFalling, Duration.Segments(5))

// 50ft fall would normally deal 15d6 — with feather fall, 0 damage
rolls clear
rolls 6 6 6 6 6 6 6 6 6 6 6 6 6 6 6
do FallDamage(ff_faller, 50)
assert_eq ff_faller.hp, 40

// Without feather fall: confirm damage still works
spawn Character no_ff_faller { name: "Normal Faller 2", classes: [ClassLevel { class: Fighter, level: 5 }], abilities: { STR: 14, INT: 12, WIS: 12, DEX: 12, CON: 12, CHA: 12 }, HitPoints { max_hp: 40, hp: 40 }, saving_throws: some(fighter_saves(5)) }
rolls clear
rolls 3 4 5
do FallDamage(no_ff_faller, 20)
assert_eq no_ff_faller.hp, 28

rolls clear
