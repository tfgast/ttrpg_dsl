// Polymorph prototype — testing the suspend + summon pattern
//
// Tests whether transformations can be modeled by:
// 1. Suspending the original entity (off-board)
// 2. Spawning a form entity with new stats but original's HP
// 3. Linking form back to original via a Polymorphed condition
// 4. On removal: despawn form, restore original, sync HP
//
// Note: `let` bindings are immutable, so entity field mutations
// must happen inside functions that receive entities as params.

// ── Test 1: Full polymorph cycle (Character → Monster) ───────
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
    level: int = 1
}

entity Monster {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
}

condition Polymorphed(original: Character, suspension_key: int) on bearer: Monster
    stacking first
{
    on_remove {
        original.hp = bearer.hp
        remove_suspension_source(original, source_id: suspension_key)
        despawn(bearer)
    }
}

// All-in-one: polymorph, take damage, revert, return original's HP.
function test_polymorph_cycle(target: Character, damage: int) -> int {
    suspend_with_source(target, source_id: 1001,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)

    let form = Monster {
        name: "Troll",
        hp: target.hp,
        max_hp: target.max_hp,
        ac: 16
    }
    let poly_id = apply_condition(form, Polymorphed(original: target, suspension_key: 1001),
        Duration.Indefinite)
    if !poly_id.is_some() { error("expected polymorph condition to apply") }

    // Apply damage via helper (let bindings are immutable)
    damage_entity(form, damage)

    // Revert
    let poly = conditions(form)[0]
    if poly.id != poly_id.unwrap() { error("apply_condition returned wrong id") }
    remove_condition(form, "Polymorphed")

    target.hp
}

function damage_entity(target: Monster, amount: int) {
    target.hp = target.hp - amount
}
END

spawn Character hero { name: "Merlin", hp: 30, max_hp: 30, ac: 15, level: 7 }

assert is_suspended(hero) == false
assert hero.hp == 30

let final_hp = test_polymorph_cycle(hero, 12)
assert final_hp == 18

assert is_suspended(hero) == false
assert hero.hp == 18
assert hero.ac == 15


// ── Test 2: Inline entity construction in polymorph ──────────
source -s <<END
enum Duration {
    Rounds(count: int),
    Indefinite
}

entity Character {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
}

entity Monster {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
}

condition Polymorphed(original: Character, suspension_key: int) on bearer: Monster
    stacking first
{
    on_remove {
        original.hp = bearer.hp
        remove_suspension_source(original, source_id: suspension_key)
        despawn(bearer)
    }
}

function damage_monster(target: Monster, amount: int) {
    target.hp = target.hp - amount
}

function test_eagle_polymorph(target: Character, damage: int) -> int {
    suspend_with_source(target, source_id: 5001,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)

    let form = Monster {
        name: "Giant Eagle",
        hp: target.hp,
        max_hp: target.max_hp,
        ac: 13
    }
    let poly_id = apply_condition(form, Polymorphed(original: target, suspension_key: 5001),
        Duration.Rounds(count: 10))
    if !poly_id.is_some() { error("expected polymorph condition to apply") }

    damage_monster(form, damage)
    let poly = conditions(form)[0]
    if poly.id != poly_id.unwrap() { error("apply_condition returned wrong id") }
    remove_condition(form, "Polymorphed")

    target.hp
}
END

spawn Character druid { name: "Druid", hp: 40, max_hp: 40, ac: 12 }

let druid_hp = test_eagle_polymorph(druid, 15)
assert druid_hp == 25
assert is_suspended(druid) == false
assert druid.hp == 25
assert druid.ac == 12


// ── Test 3: Flesh to Stone (suspend only, no form) ──────────
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
}

condition Petrified on bearer: entity
    stacking first
{
    on_apply {
        suspend(bearer, Presence.OnMap, freeze_turns: true, freeze_durations: true)
    }
}
END

spawn Character victim { name: "Unlucky", hp: 15, max_hp: 15 }

let petrified_id = apply_condition(victim, Petrified, Duration.Indefinite)
assert petrified_id.is_some()

assert is_suspended(victim) == true
assert is_off_board(victim) == false
assert are_turns_frozen(victim) == true

call remove_condition(victim, "Petrified")

assert is_suspended(victim) == false
assert victim.hp == 15


// ── Test 4: Suspended entity field access ────────────────────
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
    level: int = 1
}

function suspend_and_read(target: Character, key: int) -> int {
    suspend_with_source(target, source_id: key,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)
    target.level
}

function write_suspended(target: Character) {
    target.hp = 99
}
END

spawn Character test_char { name: "Test", hp: 10, max_hp: 10, level: 5 }

let lvl = suspend_and_read(test_char, 3001)
assert lvl == 5

call write_suspended(test_char)
assert test_char.hp == 99

call remove_suspension_source(test_char, source_id: 3001)
assert is_suspended(test_char) == false


// ── Test 5: Lethal damage while polymorphed ──────────────────
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
}

entity Monster {
    name: string
    hp: int
    max_hp: int
}

condition Polymorphed(original: Character, suspension_key: int) on bearer: Monster
    stacking first
{
    on_remove {
        original.hp = bearer.hp
        remove_suspension_source(original, source_id: suspension_key)
        despawn(bearer)
    }
}

function damage_monster(target: Monster, amount: int) {
    target.hp = target.hp - amount
}

function test_lethal_polymorph(target: Character) -> int {
    suspend_with_source(target, source_id: 9001,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)

    let form = Monster {
        name: "Bear",
        hp: target.hp,
        max_hp: target.max_hp
    }
    let poly_id = apply_condition(form, Polymorphed(original: target, suspension_key: 9001),
        Duration.Indefinite)
    if !poly_id.is_some() { error("expected polymorph condition to apply") }

    // Overkill the form
    damage_monster(form, 25)

    let poly = conditions(form)[0]
    if poly.id != poly_id.unwrap() { error("apply_condition returned wrong id") }
    remove_condition(form, "Polymorphed")

    target.hp
}
END

spawn Character doomed { name: "Doomed", hp: 20, max_hp: 20 }

let doomed_hp = test_lethal_polymorph(doomed)
assert doomed_hp == -5
assert is_suspended(doomed) == false
assert doomed.hp == -5


// ── Test 6: Sequential form changes (Shape Change pattern) ───
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
}

entity Monster {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
}

condition Polymorphed(original: Character, suspension_key: int) on bearer: Monster
    stacking first
{
    on_remove {
        original.hp = bearer.hp
        remove_suspension_source(original, source_id: suspension_key)
        despawn(bearer)
    }
}

function damage_monster(target: Monster, amount: int) {
    target.hp = target.hp - amount
}

function do_polymorph(target: Character, form_name: string, form_ac: int, key: int) -> Monster {
    suspend_with_source(target, source_id: key,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)

    let form = Monster {
        name: form_name,
        hp: target.hp,
        max_hp: target.max_hp,
        ac: form_ac
    }
    let poly_id = apply_condition(form, Polymorphed(original: target, suspension_key: key),
        Duration.Indefinite)
    if !poly_id.is_some() { error("expected polymorph condition to apply") }
    let poly = conditions(form)[0]
    if poly.id != poly_id.unwrap() { error("apply_condition returned wrong id") }
    form
}

function revert(form: Monster) {
    remove_condition(form, "Polymorphed")
}

// Bear -> revert -> Eagle -> revert
function test_double_polymorph(target: Character) -> int {
    // First form: bear
    let bear = do_polymorph(target, "Bear", 14, 7001)
    damage_monster(bear, 10)
    revert(bear)

    // target should now have 40-10 = 30 HP
    // Second form: eagle
    let eagle = do_polymorph(target, "Eagle", 13, 7002)
    damage_monster(eagle, 5)
    revert(eagle)

    target.hp
}
END

spawn Character shapechanger { name: "ShapeChanger", hp: 40, max_hp: 40 }

let sc_hp = test_double_polymorph(shapechanger)
// 40 - 10 (bear) - 5 (eagle) = 25
assert sc_hp == 25
assert shapechanger.hp == 25
assert is_suspended(shapechanger) == false


// ── Test 7: transfer_conditions on polymorph revert ─────────
// Blessed (tagged #transferable) transfers back to original on revert.
// Poisoned (tagged #physical) stays on the form (lost on despawn).
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
}

entity Monster {
    name: string
    hp: int
    max_hp: int
}

tag transferable
tag physical

condition Blessed on bearer: entity stacking all {
    tags: #transferable
}

condition Poisoned on bearer: entity stacking all {
    tags: #physical
}

condition Polymorphed(original: Character, suspension_key: int) on bearer: Monster
    stacking first
{
    on_remove {
        transfer_conditions(bearer, original, "transferable")
        original.hp = bearer.hp
        remove_suspension_source(original, source_id: suspension_key)
        despawn(bearer)
    }
}

function do_polymorph(target: Character, key: int) -> Monster {
    suspend_with_source(target, source_id: key,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)

    let form = Monster {
        name: "Troll",
        hp: target.hp,
        max_hp: target.max_hp
    }
    // Transfer existing transferable conditions to the form
    transfer_conditions(target, form, "transferable")
    let poly_id = apply_condition(form, Polymorphed(original: target, suspension_key: key),
        Duration.Indefinite)
    if !poly_id.is_some() { error("expected polymorph condition to apply") }
    let poly = conditions(form)[1]
    if poly.id != poly_id.unwrap() { error("apply_condition returned wrong id") }
    form
}

function revert(form: Monster) {
    remove_condition(form, "Polymorphed")
}

function damage_monster(target: Monster, amount: int) {
    target.hp = target.hp - amount
}
END

spawn Character mage { name: "Mage", hp: 30, max_hp: 30 }

// Bless the mage before polymorph
let blessed_id = apply_condition(mage, Blessed, Duration.Indefinite)
assert blessed_id.is_some()
assert has_condition(mage, "Blessed") == true

// Polymorph — Blessed should transfer to form
let troll = do_polymorph(mage, 8001)
assert has_condition(troll, "Blessed") == true
assert has_condition(mage, "Blessed") == false

// Apply Poisoned on the troll form (physical — won't transfer back)
let poisoned_id = apply_condition(troll, Poisoned, Duration.Indefinite)
assert poisoned_id.is_some()
assert has_condition(troll, "Poisoned") == true

call damage_monster(troll, 7)

// Revert — Blessed transfers back, Poisoned is lost with the form
call revert(troll)

assert has_condition(mage, "Blessed") == true
assert has_condition(mage, "Poisoned") == false
assert mage.hp == 23
assert is_suspended(mage) == false


// ── Test 8: Multiple transferable conditions ────────────────
// Both Blessed and Shielded (tagged #transferable) should transfer.
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
}

entity Monster {
    name: string
    hp: int
    max_hp: int
}

tag transferable

condition Blessed on bearer: entity stacking all {
    tags: #transferable
}

condition Shielded on bearer: entity stacking all {
    tags: #transferable
}

condition Polymorphed(original: Character, suspension_key: int) on bearer: Monster
    stacking first
{
    on_remove {
        transfer_conditions(bearer, original, "transferable")
        original.hp = bearer.hp
        remove_suspension_source(original, source_id: suspension_key)
        despawn(bearer)
    }
}

function do_polymorph(target: Character, key: int) -> Monster {
    suspend_with_source(target, source_id: key,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)
    let form = Monster {
        name: "Bear",
        hp: target.hp,
        max_hp: target.max_hp
    }
    transfer_conditions(target, form, "transferable")
    let poly_id = apply_condition(form, Polymorphed(original: target, suspension_key: key),
        Duration.Indefinite)
    if !poly_id.is_some() { error("expected polymorph condition to apply") }
    let poly = conditions(form)[2]
    if poly.id != poly_id.unwrap() { error("apply_condition returned wrong id") }
    form
}

function revert(form: Monster) {
    remove_condition(form, "Polymorphed")
}
END

spawn Character cleric { name: "Cleric", hp: 25, max_hp: 25 }

let bless_id = apply_condition(cleric, Blessed, Duration.Indefinite)
let shield_id = apply_condition(cleric, Shielded, Duration.Indefinite)
assert bless_id.is_some()
assert shield_id.is_some()

let bear = do_polymorph(cleric, 8501)

// Both conditions moved to form
assert has_condition(bear, "Blessed") == true
assert has_condition(bear, "Shielded") == true
assert has_condition(cleric, "Blessed") == false
assert has_condition(cleric, "Shielded") == false

// Revert — both come back
call revert(bear)

assert has_condition(cleric, "Blessed") == true
assert has_condition(cleric, "Shielded") == true
assert is_suspended(cleric) == false


// ── Test 9: Condition applied to form transfers back ────────
// A transferable condition gained during polymorph returns to original.
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
}

entity Monster {
    name: string
    hp: int
    max_hp: int
}

tag transferable

condition Cursed on bearer: entity stacking all {
    tags: #transferable
}

condition Polymorphed(original: Character, suspension_key: int) on bearer: Monster
    stacking first
{
    on_remove {
        transfer_conditions(bearer, original, "transferable")
        original.hp = bearer.hp
        remove_suspension_source(original, source_id: suspension_key)
        despawn(bearer)
    }
}

function do_polymorph(target: Character, key: int) -> Monster {
    suspend_with_source(target, source_id: key,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)
    let form = Monster {
        name: "Wolf",
        hp: target.hp,
        max_hp: target.max_hp
    }
    let poly_id = apply_condition(form, Polymorphed(original: target, suspension_key: key),
        Duration.Indefinite)
    if !poly_id.is_some() { error("expected polymorph condition to apply") }
    let poly = conditions(form)[0]
    if poly.id != poly_id.unwrap() { error("apply_condition returned wrong id") }
    form
}

function revert(form: Monster) {
    remove_condition(form, "Polymorphed")
}
END

spawn Character ranger { name: "Ranger", hp: 35, max_hp: 35 }

let wolf = do_polymorph(ranger, 9501)

// Someone curses the wolf form — it's transferable, should go back to ranger
let curse_id = apply_condition(wolf, Cursed, Duration.Indefinite)
assert curse_id.is_some()
assert has_condition(wolf, "Cursed") == true

call revert(wolf)

assert has_condition(ranger, "Cursed") == true
assert ranger.hp == 35
assert is_suspended(ranger) == false


// ── Test 10: Toggle pattern (Statue / Tree) ──────────────────
// Freely shift between suspended and normal states during a duration.
// Validates repeated suspend/unsuspend cycles work correctly.
// Uses suspend_with_source/remove_suspension_source for toggle control.
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
}

tag transferable

condition Blessed on bearer: entity stacking all {
    tags: #transferable
}

// Use a fixed source_id so we can add/remove suspension independently
function statue_on(target: Character) {
    suspend_with_source(target, source_id: 4001,
        Presence.OnMap, freeze_turns: true, freeze_durations: true)
}

function statue_off(target: Character) {
    remove_suspension_source(target, source_id: 4001)
}
END

spawn Character sculptor { name: "Sculptor", hp: 20, max_hp: 20, ac: 14 }

// Apply Blessed before going statue (should persist through toggles)
let sculptor_bless = apply_condition(sculptor, Blessed, Duration.Indefinite)
assert sculptor_bless.is_some()
assert has_condition(sculptor, "Blessed") == true

// Turn to statue
call statue_on(sculptor)
assert is_suspended(sculptor) == true
assert are_turns_frozen(sculptor) == true

// Shift back to flesh
call statue_off(sculptor)
assert is_suspended(sculptor) == false

// Blessed should still be there through the cycle
assert has_condition(sculptor, "Blessed") == true
assert sculptor.hp == 20

// Shift back to statue again
call statue_on(sculptor)
assert is_suspended(sculptor) == true

// And back to flesh
call statue_off(sculptor)
assert is_suspended(sculptor) == false
assert has_condition(sculptor, "Blessed") == true
assert sculptor.hp == 20


// ── Test 11: Re-polymorph while polymorphed (form swap) ──────
// Go from Bear → Eagle without reverting to original first.
// Transferable conditions should follow: original → bear → eagle → original.
source -s <<END
entity Character {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
}

entity Monster {
    name: string
    hp: int
    max_hp: int
    ac: int = 10
}

tag transferable

condition Blessed on bearer: entity stacking all {
    tags: #transferable
}

condition Polymorphed(original: Character, suspension_key: int) on bearer: Monster
    stacking first
{
    on_remove {
        transfer_conditions(bearer, original, "transferable")
        original.hp = bearer.hp
        remove_suspension_source(original, source_id: suspension_key)
        despawn(bearer)
    }
}

function damage_monster(target: Monster, amount: int) {
    target.hp = target.hp - amount
}

function do_polymorph(target: Character, form_name: string, form_ac: int, key: int) -> Monster {
    suspend_with_source(target, source_id: key,
        Presence.OffBoard, freeze_turns: true, freeze_durations: true)
    let form = Monster {
        name: form_name,
        hp: target.hp,
        max_hp: target.max_hp,
        ac: form_ac
    }
    transfer_conditions(target, form, "transferable")
    let poly_id = apply_condition(form, Polymorphed(original: target, suspension_key: key),
        Duration.Indefinite)
    if !poly_id.is_some() { error("expected polymorph condition to apply") }
    let poly = conditions(form)[1]
    if poly.id != poly_id.unwrap() { error("apply_condition returned wrong id") }
    form
}

function revert(form: Monster) {
    remove_condition(form, "Polymorphed")
}

// Swap directly from one form to another:
// Revert current form, immediately polymorph into new form.
function swap_form(current_form: Monster, new_name: string, new_ac: int, new_key: int) -> Monster {
    // Grab original ref from the condition before reverting
    // For now, revert then re-polymorph (original is briefly restored)
    revert(current_form)
    // After revert, original is unsuspended with synced HP
    // We need the original — but we can't extract it from the condition.
    // This pattern requires the caller to hold the original reference.
    // See test body for the actual calling pattern.
    // (This function won't work as-is — see below)
    Monster { name: "dummy", hp: 0, max_hp: 0 }
}
END

spawn Character shifter { name: "Shifter", hp: 50, max_hp: 50, ac: 12 }

// Bless before any polymorph
let shifter_bless = apply_condition(shifter, Blessed, Duration.Indefinite)
assert shifter_bless.is_some()
assert has_condition(shifter, "Blessed") == true

// First form: Bear
let bear = do_polymorph(shifter, "Bear", 14, 7001)
assert has_condition(bear, "Blessed") == true
assert has_condition(shifter, "Blessed") == false

// Take some damage as bear
call damage_monster(bear, 10)
assert bear.hp == 40

// Revert bear, immediately re-polymorph as eagle
// (caller holds the original ref — this is the practical pattern)
call revert(bear)
assert shifter.hp == 40
assert has_condition(shifter, "Blessed") == true
assert is_suspended(shifter) == false

// Second form: Eagle (HP carries from bear damage)
let eagle = do_polymorph(shifter, "Eagle", 13, 7002)
assert has_condition(eagle, "Blessed") == true
assert has_condition(shifter, "Blessed") == false
assert eagle.hp == 40

// Take more damage as eagle
call damage_monster(eagle, 8)
assert eagle.hp == 32

// Final revert
call revert(eagle)
assert shifter.hp == 32
assert has_condition(shifter, "Blessed") == true
assert is_suspended(shifter) == false
assert shifter.ac == 12
